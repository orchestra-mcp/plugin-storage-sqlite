    - event_type: PostToolUse
      session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
      tool_name: Read
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: acceptEdits
        session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Apps/macOS/OrchestraApp.swift
            limit: 25
            offset: 290
        tool_name: Read
        tool_response:
            file:
                content: |4-
                        let host = UserDefaults.standard.string(forKey: "orchestrator_host") ?? "127.0.0.1"
                        let port = UserDefaults.standard.integer(forKey: "orchestrator_port")
                        let resolvedPort = port > 0 ? UInt16(port) : 50101
                        debugLog("[connectAndFetchTools] connecting to \(host):\(resolvedPort)")
                        await OrchestraClient.shared.connect(host: host, port: resolvedPort)

                        // Wait for the probe connection to succeed (up to 15 seconds).
                        // orchestra serve may take a few seconds to start listening.
                        for i in 0..<30 {
