            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/InputBarContent.swift
        tool_name: Read
        tool_response:
            file:
                content: |
                    #if os(macOS)
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - InputBarContent
                    //
                    // Unified inner content for the macOS input bar, used by both:
                    //   - DockedInputBar (in-window, isFloating = false)
                    //   - SmartFloatingContent expanded card (NSPanel, isFloating = true)
                    //
                    // This component owns the text field, quick actions row, trigger autocomplete,
                    // file attachment chips, voice mode indicator, and send/stop button. It does NOT
                    // own the outer glass card background or panel chrome — callers wrap it.

                    struct InputBarContent: View {
                        let chatPlugin: ChatPlugin?
                        let sessionId: UUID?
                        let isFloating: Bool
                        var onDock: (() -> Void)? = nil
                        var onDetach: (() -> Void)? = nil
                        var onHeightChange: (() -> Void)? = nil

                        @ObservedObject private var state = SmartInputState.shared
                        @FocusState private var inputFocused: Bool
                        @ObservedObject private var voiceService = VoiceService.shared
                        @ObservedObject private var screenshotService = ScreenshotService.shared
                        @ObservedObject private var browserService = BrowserContextService.shared
                        @State private var chevronRotation: Double = 0
                        @State private var voiceModeMessageCount: Int = 0
                        @State private var showSuggestionsPopover = false
                        @State private var showBrowserPopover = false
                        @State private var showScreenshotPopover = false

                        // MARK: - Body

                        var body: some View {
                            contentVStack
                                .onChange(of: state.text) { _, _ in
                                    state.processTextChange()
                                    if let trigger = state.activeTrigger {
                                        Task {
                                            let results = await TriggerService.shared.search(trigger: trigger, query: state.triggerQuery)
                                            state.triggerResults = results
                                        }
                                    }
                                }
                                .onChange(of: inputFocused) { _, focused in
                                    state.isFocused = focused
                                    state.processTextChange()
                                }
                                .background {
                                    // Hidden keyboard shortcuts for trigger navigation and paste
                                    Button("") { navigateTriggerUp() }
                                        .keyboardShortcut(.upArrow, modifiers: [])
                                        .opacity(0)
                                    Button("") { navigateTriggerDown() }
                                        .keyboardShortcut(.downArrow, modifiers: [])
                                        .opacity(0)
                                    Button("") { applySelectedTrigger() }
                                        .keyboardShortcut(.tab, modifiers: [])
                                        .opacity(0)
                                    Button("") { pasteFilesFromPasteboard() }
                                        .keyboardShortcut("v", modifiers: .command)
                                        .opacity(0)
                                }
                                .onAppear {
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) { inputFocused = true }
                                    browserService.startPolling()
                                    setupVoiceCallbacks()
                                }
                                .onReceive(NotificationCenter.default.publisher(for: .orchestraActivateSmartInput)) { _ in
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 0.05) { inputFocused = true }
                                }
                                .onReceive(NotificationCenter.default.publisher(for: .orchestraTriggerAutoSend)) { _ in
                                    sendMessage()
                                }
                                // Auto-speak agent response when voice mode is active.
                                // Uses a stable Timer publisher to poll instead of objectWillChange,
                                // which causes re-render cascades and crashes in the floating panel.
                                .onReceive(Timer.publish(every: 1.0, on: .main, in: .common).autoconnect()) { _ in
                                    guard voiceService.voiceModeActive else { return }
                                    guard let plugin = chatPlugin, !plugin.isSending else { return }
                                    guard let sid = resolvedSessionId,
                                          let session = plugin.sessions.first(where: { $0.id == sid }),
                                          let lastAssistant = session.messages.last(where: { $0.role == .assistant }) else { return }
                                    let msgCount = session.messages.count
                                    if msgCount > voiceModeMessageCount {
                                        voiceModeMessageCount = msgCount
                                        voiceService.speakAgentResponse(lastAssistant.content)
                                    }
                                }
                        }

                        // MARK: - Content Stack

                        private var contentVStack: some View {
                            VStack(spacing: 0) {
                                // File attachment chips
                                if !state.attachedFiles.isEmpty {
                                    fileAttachmentChips
                                }

                                inputRow
                                    .padding(.horizontal, 20)
                                    .padding(.vertical, isFloating ? 14 : 12)

                                if state.showQuickActions {
                                    Divider()
                                        .background(Color.white.opacity(0.08))
                                        .padding(.horizontal, 16)
                                    quickActionsRow
                                }

                                if state.activeTrigger != nil {
                                    InputToolbar()
                                }
                            }
                        }

                        // MARK: - Input Row

                        private var inputRow: some View {
                            HStack(spacing: 10) {
                                Image("OrchestraLogo")
                                    .resizable()
                                    .scaledToFit()
                                    .colorMultiply(.white)
                                    .brightness(1)
                                    .frame(width: isFloating ? 26 : 24, height: isFloating ? 26 : 24)

                                if !SmartInputWindowManager.isTrayMode {
                                    dockDetachButton
                                }

                                // Voice mode: overlay indicator on top of text field using ZStack + opacity.
                                // Avoids swapping the view tree which crashes NSHostingView in floating panel.
                                ZStack {
                                    TextField(
                                        state.isChatMode ? "Message..." : "Ask anything...",
                                        text: $state.text
                                    )
                                    .textFieldStyle(.plain)
                                    .font(.system(size: 15, weight: .regular))
                                    .foregroundStyle(.white)
                                    .focused($inputFocused)
                                    .opacity(voiceService.voiceModeActive ? 0 : 1)
                                    .background {
                                        Button("") {
                                            if state.activeTrigger != nil, state.triggerSelectedIndex < state.triggerResults.count {
                                                let shouldSend = state.applyTriggerResult(state.triggerResults[state.triggerSelectedIndex])
                                                if shouldSend { sendMessage() }
                                            } else {
                                                sendMessage()
                                            }
                                        }
                                        .keyboardShortcut(.return, modifiers: [])
                                        .opacity(0)
                                        Button("") { sendMessage() }
                                            .keyboardShortcut(.return, modifiers: .command)
                                            .opacity(0)
                                        if isFloating {
                                            Button("") {
                                                NotificationCenter.default.post(name: .orchestraCollapseSmartInput, object: nil)
                                                DispatchQueue.main.asyncAfter(deadline: .now() + 0.25) {
                                                    SmartInputWindowManager.shared.collapse()
                                                }
                                            }
                                            .keyboardShortcut(.escape, modifiers: [])
                                            .opacity(0)
                                        }
                                    }

                                    if voiceService.voiceModeActive {
                                        voiceInlineIndicator
                                    }
                                }

                                Spacer(minLength: 0)
                                quickActionToggle
                            }
                        }

                        // MARK: - Voice Inline Indicator

                        private var voiceInlineIndicator: some View {
                            HStack(spacing: 8) {
                                // Animated phase dot
                                Circle()
                                    .fill(voicePhaseColor)
                                    .frame(width: 10, height: 10)
                                    .scaleEffect(voiceService.phase == .listening ? CGFloat(1.0 + Double(voiceService.audioLevel) * 0.5) : 1.0)

                                // Phase label
                                Text(voicePhaseLabelShort)
                                    .font(.system(size: 13, weight: .medium))
                                    .foregroundStyle(.white.opacity(0.6))

                                // Transcribed text (truncated)
                                if voiceService.phase == .listening && !voiceService.transcribedText.isEmpty {
                                    Text(voiceService.transcribedText)
                                        .font(.system(size: 14, weight: .regular))
                                        .foregroundStyle(.white)
                                        .lineLimit(1)
                                        .truncationMode(.tail)
                                }
                            }
                            .frame(maxWidth: .infinity, alignment: .leading)
                        }

                        private var voicePhaseLabelShort: String {
                            switch voiceService.phase {
                            case .idle:       return "Voice"
                            case .listening:  return "Listening..."
                            case .processing: return "Thinking..."
                            case .speaking:   return "Speaking..."
                            }
                        }

                        private var voicePhaseColor: Color {
                            switch voiceService.phase {
                            case .idle, .listening:  return .blue
                            case .processing:        return .purple
                            case .speaking:          return .green
                            }
                        }

                        // MARK: - Send or Stop Button
                        //
                        // Uses ZStack + opacity to keep the view tree stable.
                        // Swapping views via if/else crashes NSHostingView in the floating panel.

                        private var sendOrStopButton: some View {
                            ZStack {
                                // Voice stop button
                                Button {
                                    if voiceService.phase == .speaking {
                                        voiceService.interrupt()
                                    } else {
                                        voiceService.stopVoiceMode()
                                    }
                                } label: {
                                    ZStack {
                                        Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                                        Circle().fill(Color.red.opacity(0.25)).frame(width: 30, height: 30)
                                        Image(systemName: voiceService.phase == .speaking ? "hand.raised.fill" : "stop.fill")
                                            .font(.system(size: 12, weight: .bold))
                                            .foregroundStyle(.red)
                                    }
                                }
                                .buttonStyle(.plain)
                                .opacity(voiceService.voiceModeActive ? 1 : 0)
                                .allowsHitTesting(voiceService.voiceModeActive)

                                // Loading dots
                                loadingDots.frame(width: 36, height: 32)
                                    .opacity(!voiceService.voiceModeActive && state.isLoading ? 1 : 0)

                                // Send button
                                Button(action: sendMessage) {
                                    ZStack {
                                        Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                                        Circle().fill(Color.white.opacity(canSend ? 0.18 : 0.07)).frame(width: 30, height: 30)
                                        Image(systemName: "arrow.up")
                                            .font(.system(size: 12, weight: .bold))
                                            .foregroundStyle(canSend ? .white : Color.white.opacity(0.30))
                                    }
                                }
                                .buttonStyle(.plain)
                                .disabled(!canSend)
                                .scaleEffect(canSend ? 1.0 : 0.85)
                                .opacity(!voiceService.voiceModeActive && !state.isLoading ? 1 : 0)
                                .allowsHitTesting(!voiceService.voiceModeActive && !state.isLoading)
                            }
                            .frame(width: 36, height: 32)
                        }

                        // MARK: - Loading Dots

                        private var loadingDots: some View {
                            InputBarLoadingDots()
                        }

                        // MARK: - Dock / Detach Button

                        private var dockDetachButton: some View {
                            Button {
                                if isFloating {
                                    onDock?()
                                } else {
                                    onDetach?()
                                }
                            } label: {
                                Image(systemName: isFloating
                                    ? "arrow.down.right.and.arrow.up.left"
                                    : "arrow.up.left.and.arrow.down.right")
                                    .font(.system(size: 10, weight: .medium))
                                    .foregroundStyle(Color.white.opacity(0.45))
                                    .frame(width: 24, height: 24)
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(0.07)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(Color.white.opacity(0.12), lineWidth: 0.75).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .glassTooltip(isFloating ? "Dock" : "Detach")
                        }

                        // MARK: - Quick Action Toggle

                        private var quickActionToggle: some View {
                            Button {
                                if isFloating {
                                    // Floating: animate chevron only (safe -- does not change layout)
                                    let willShow = !state.showQuickActions
                                    withAnimation(.spring(response: 0.35, dampingFraction: 0.78)) {
                                        chevronRotation = willShow ? 180 : 0
                                    }
                                    if willShow {
                                        state.showQuickActions = true
                                        onHeightChange?()
                                    } else {
                                        state.showQuickActions = false
                                        DispatchQueue.main.async {
                                            onHeightChange?()
                                        }
                                    }
                                } else {
                                    // Docked: safe to use withAnimation
                                    withAnimation(.spring(response: 0.35, dampingFraction: 0.78)) {
                                        state.showQuickActions.toggle()
                                        chevronRotation = state.showQuickActions ? 180 : 0
                                    }
                                }
                            } label: {
                                Image(systemName: "chevron.down")
                                    .font(.system(size: 11, weight: .semibold))
                                    .foregroundStyle(state.showQuickActions ? .white : .white.opacity(0.35))
                                    .rotationEffect(.degrees(chevronRotation))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(state.showQuickActions ? 0.07 : 0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        LinearGradient(colors: [Color.white.opacity(0.12)],
                                                       startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .glassTooltip(state.showQuickActions ? "Hide toolbar" : "Show toolbar")
                        }

                        // MARK: - Quick Actions Row

                        /// Resolve session ID: explicit param or active chat session.
                        private var resolvedSessionId: UUID? {
                            sessionId ?? chatPlugin?.selectedSession?.id
                        }

                        private var quickActionsRow: some View {
                            HStack(spacing: 8) {
                                // Model / Mode / Think pickers -- only when chat session available
                                if let plugin = chatPlugin, let sid = resolvedSessionId {
                                    SessionModelButton(plugin: plugin, sessionId: sid)
                                    SessionModeButton(plugin: plugin, sessionId: sid)
                                    SessionThinkingButton(plugin: plugin, sessionId: sid)
                                }

                                // Vision (context) — right after thinking
                                contextButton
                                suggestionsButton
                                browserButton
                                screenshotButton

                                Spacer()

                                micButton
                                sendOrStopButton
                            }
                            .padding(.horizontal, 20)
                            .padding(.top, 6)
                            .padding(.bottom, isFloating ? 10 : 6)
                        }

                        // MARK: - Suggestions Button

                        private var suggestionsButton: some View {
                            Button {
                                showSuggestionsPopover.toggle()
                            } label: {
                                Image(systemName: "text.bubble")
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(.white.opacity(0.35))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        LinearGradient(colors: [Color.white.opacity(0.12)],
                                                       startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .popover(isPresented: $showSuggestionsPopover, arrowEdge: .bottom) {
                                suggestionsPopoverContent
                            }
                        }

                        private var suggestionsPopoverContent: some View {
                            let prompts = SuggestedPromptsProvider.shared.suggestions()
                            return VStack(alignment: .leading, spacing: 2) {
                                PopoverHeader(icon: "sparkles", title: "Suggestions")

                                ForEach(prompts) { prompt in
                                    PopoverMenuItem(icon: prompt.icon, label: prompt.text) {
                                        state.text = prompt.text
                                        inputFocused = true
                                        showSuggestionsPopover = false
                                    }
                                }
                            }
                            .padding(8)
                            .frame(width: 260)
                            .background(.ultraThinMaterial)
                            .preferredColorScheme(.dark)
                        }

                        // MARK: - Context Button

                        private var contextButton: some View {
                            ContextToggle()
                        }

                        // MARK: - Browser Button

                        private var browserButton: some View {
                            let isActive = browserService.isAvailable && browserService.includeBrowserContext
                            return Button {
                                showBrowserPopover.toggle()
                            } label: {
                                Image(systemName: "globe")
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(isActive ? .white : .white.opacity(0.35))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(isActive ? 0.07 : 0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        isActive
                                            ? LinearGradient(colors: [Color.cyan.opacity(0.40), Color.blue.opacity(0.30)],
                                                             startPoint: .topLeading, endPoint: .bottomTrailing)
                                            : LinearGradient(colors: [Color.white.opacity(0.12)],
                                                             startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .popover(isPresented: $showBrowserPopover, arrowEdge: .bottom) {
                                browserPopoverContent
                            }
                        }

                        private var browserPopoverContent: some View {
                            VStack(alignment: .leading, spacing: 2) {
                                PopoverHeader(icon: "globe", title: "Browser Context")

                                PopoverMenuItem(
                                    icon: browserService.includeBrowserContext ? "eye.slash" : "eye",
                                    label: browserService.includeBrowserContext ? "Disable Browser Context" : "Enable Browser Context"
                                ) {
                                    browserService.includeBrowserContext.toggle()
                                    showBrowserPopover = false
                                }

                                Divider().background(Color.white.opacity(0.1)).padding(.horizontal, 6)

                                if browserService.tabs.isEmpty {
                                    HStack(spacing: 8) {
                                        Image(systemName: "globe.badge.chevron.backward")
                                            .font(.system(size: 11, weight: .medium))
                                            .foregroundStyle(.white.opacity(0.3))
                                            .frame(width: 18)
                                        Text("No tabs detected")
                                            .font(.system(size: 12, weight: .regular))
                                            .foregroundStyle(.white.opacity(0.4))
                                    }
                                    .padding(.horizontal, 10)
                                    .padding(.vertical, 7)
                                } else {
                                    ForEach(browserService.tabs) { tab in
                                        HStack(spacing: 8) {
                                            Image(systemName: "doc.text")
                                                .font(.system(size: 11, weight: .medium))
                                                .foregroundStyle(.white.opacity(0.3))
                                                .frame(width: 18)
                                            Text(tab.title)
                                                .font(.system(size: 12, weight: .regular))
                                                .foregroundStyle(.white.opacity(0.5))
                                                .lineLimit(1)
                                        }
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 5)
                                    }
                                }

                                Divider().background(Color.white.opacity(0.1)).padding(.horizontal, 6)

                                PopoverMenuItem(icon: "arrow.clockwise", label: "Refresh Tabs") {
                                    browserService.refreshTabs()
                                    showBrowserPopover = false
                                }
                            }
                            .padding(8)
                            .frame(width: 240)
                            .background(.ultraThinMaterial)
                            .preferredColorScheme(.dark)
                        }

                        // MARK: - Screenshot Button

                        private var screenshotButton: some View {
                            Button {
                                showScreenshotPopover.toggle()
                            } label: {
                                Image(systemName: screenshotService.isCapturing ? "camera.fill" : "camera")
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(screenshotService.isCapturing ? .white : .white.opacity(0.35))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(screenshotService.isCapturing ? 0.07 : 0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        screenshotService.isCapturing
                                            ? LinearGradient(colors: [Color.blue.opacity(0.40), Color.cyan.opacity(0.30)],
                                                             startPoint: .topLeading, endPoint: .bottomTrailing)
                                            : LinearGradient(colors: [Color.white.opacity(0.12)],
                                                             startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .popover(isPresented: $showScreenshotPopover, arrowEdge: .bottom) {
                                screenshotPopoverContent
                            }
                        }

                        private var screenshotPopoverContent: some View {
                            VStack(alignment: .leading, spacing: 2) {
                                PopoverHeader(icon: "camera", title: "Screenshot")

                                PopoverMenuItem(icon: "rectangle.dashed", label: "Capture Region") {
                                    showScreenshotPopover = false
                                    captureScreenshot(mode: .interactiveRegion)
                                }
                                PopoverMenuItem(icon: "macwindow", label: "Capture Window") {
                                    showScreenshotPopover = false
                                    captureScreenshot(mode: .interactiveWindow)
                                }
                                PopoverMenuItem(icon: "desktopcomputer", label: "Full Screen") {
                                    showScreenshotPopover = false
                                    captureScreenshot(mode: .fullScreen)
                                }
                            }
                            .padding(8)
                            .frame(width: 200)
                            .background(.ultraThinMaterial)
                            .preferredColorScheme(.dark)
                        }

                        // MARK: - Mic Button

                        private var micButton: some View {
                            Button {
                                if voiceService.voiceModeActive {
                                    voiceService.stopVoiceMode()
                                } else {
                                    startVoiceMode()
                                }
                            } label: {
                                Image(systemName: voiceService.voiceModeActive ? "waveform.circle.fill" : "mic")
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(voiceService.voiceModeActive ? .white : .white.opacity(0.35))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(voiceService.voiceModeActive ? 0.07 : 0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        voiceService.voiceModeActive
                                            ? LinearGradient(colors: [Color.red.opacity(0.40), Color.orange.opacity(0.30)],
                                                             startPoint: .topLeading, endPoint: .bottomTrailing)
                                            : LinearGradient(colors: [Color.white.opacity(0.12)],
                                                             startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .glassTooltip(voiceService.voiceModeActive ? "Voice: On" : "Voice")
                        }

                        // MARK: - File Attachment Chips

                        private var fileAttachmentChips: some View {
                            ScrollView(.horizontal, showsIndicators: false) {
                                HStack(spacing: 6) {
                                    ForEach(state.attachedFiles) { file in
                                        HStack(spacing: 4) {
                                            Image(systemName: fileIcon(for: file.url))
                                                .font(.system(size: 9, weight: .medium))
                                                .foregroundStyle(Color.white.opacity(0.7))
                                            Text(file.name)
                                                .font(.system(size: 10, weight: .medium))
                                                .foregroundStyle(Color.white.opacity(0.85))
                                                .lineLimit(1)
                                            Button {
                                                state.removeFile(file.id)
                                            } label: {
                                                Image(systemName: "xmark")
                                                    .font(.system(size: 8, weight: .bold))
                                                    .foregroundStyle(Color.white.opacity(0.5))
                                            }
                                            .buttonStyle(.plain)
                                        }
                                        .padding(.horizontal, 8)
                                        .padding(.vertical, 4)
                                        .background(.ultraThinMaterial, in: Capsule())
                                        .overlay(Capsule().strokeBorder(Color.white.opacity(0.15), lineWidth: 0.5))
                                    }
                                }
                                .padding(.horizontal, 20)
                            }
                            .padding(.top, 8)
                        }

                        // MARK: - Helpers

                        private var canSend: Bool {
                            !state.text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && !state.isLoading
                        }

                        private func fileIcon(for url: URL) -> String {
                            let ext = url.pathExtension.lowercased()
                            switch ext {
                            case "swift", "rs", "go", "py", "js", "ts", "rb", "java", "kt", "c", "cpp", "h", "cs":
                                return "chevron.left.forwardslash.chevron.right"
                            case "json", "yaml", "yml", "toml", "xml", "plist":
                                return "doc.text"
                            case "md", "txt", "rtf":
                                return "doc.plaintext"
                            case "png", "jpg", "jpeg", "gif", "svg", "webp", "ico":
                                return "photo"
                            case "pdf":
                                return "doc.richtext"
                            case "zip", "tar", "gz", "dmg":
                                return "archivebox"
                            default:
                                return "doc"
                            }
                        }

                        // MARK: - Voice

                        private func setupVoiceCallbacks() {
                            voiceService.onAutoSend = { text in
                                Task { @MainActor in
                                    if let chat = state.activeChatPlugin {
                                        await chat.sendMessage(text)
                                    } else {
                                        state.text = text
                                        sendMessage()
                                    }
                                }
                            }
                        }

                        private func startVoiceMode() {
                            if let plugin = chatPlugin, let sid = resolvedSessionId {
                                voiceModeMessageCount = plugin.sessions.first { $0.id == sid }?.messages.count ?? 0
                            }
                            voiceService.startVoiceMode()
                        }

                        // MARK: - Trigger Navigation

                        private func navigateTriggerUp() {
                            guard state.activeTrigger != nil, !state.triggerResults.isEmpty else { return }
                            state.triggerSelectedIndex = max(0, state.triggerSelectedIndex - 1)
                        }

                        private func navigateTriggerDown() {
                            guard state.activeTrigger != nil, !state.triggerResults.isEmpty else { return }
                            state.triggerSelectedIndex = min(state.triggerResults.count - 1, state.triggerSelectedIndex + 1)
                        }

                        private func applySelectedTrigger() {
                            guard state.activeTrigger != nil,
                                  state.triggerSelectedIndex < state.triggerResults.count else { return }
                            let shouldSend = state.applyTriggerResult(state.triggerResults[state.triggerSelectedIndex])
                            if shouldSend { sendMessage() }
                        }

                        private func captureScreenshot(mode: ScreenshotService.CaptureMode) {
                            Task {
                                if let url = await screenshotService.capture(mode: mode) {
                                    state.attachFile(url)
                                }
                            }
                        }

                        private func pasteFilesFromPasteboard() {
                            let pb = NSPasteboard.general
                            guard let urls = pb.readObjects(forClasses: [NSURL.self], options: [
                                .urlReadingFileURLsOnly: true
                            ]) as? [URL], !urls.isEmpty else { return }
                            for url in urls {
                                state.attachFile(url)
                            }
                        }

                        // MARK: - Send

                        private func sendMessage() {
                            if state.isChatMode {
                                var prompt = state.text.trimmingCharacters(in: .whitespacesAndNewlines)
                                guard !prompt.isEmpty, let chat = state.activeChatPlugin else { return }
                                if !state.attachedFiles.isEmpty {
                                    let filePaths = state.attachedFiles.map { "- @\($0.url.path)" }.joined(separator: "\n")
                                    prompt = "Context files:\n\(filePaths)\n\n\(prompt)"
                                    state.clearFiles()
                                }
                                if let browserCtx = BrowserContextService.shared.browserContext() {
                                    prompt = "\(browserCtx)\n\n\(prompt)"
                                }
                                state.text = ""
                                Task { await chat.sendMessage(prompt) }
                            } else {
                                var prompt = state.text.trimmingCharacters(in: .whitespacesAndNewlines)
                                guard !prompt.isEmpty else { return }
                                if !state.attachedFiles.isEmpty {
                                    let filePaths = state.attachedFiles.map { "- @\($0.url.path)" }.joined(separator: "\n")
                                    prompt = "Context files:\n\(filePaths)\n\n\(prompt)"
                                    state.clearFiles()
                                }
                                if let browserCtx = BrowserContextService.shared.browserContext() {
                                    prompt = "\(browserCtx)\n\n\(prompt)"
                                }
                                state.text = ""
                                state.isLoading = true
                                let systemCtx = state.useContext ? AppContext.shared.systemContext() : nil
                                let mgr = isFloating ? SmartInputWindowManager.shared : nil
                                Task {
                                    do {
                                        var args: [String: Any] = ["prompt": prompt, "wait": true, "provider": "claude"]
                                        if let ctx = systemCtx { args["system_prompt"] = ctx }
                                        let result = try await ToolService.shared.call(tool: "ai_prompt", arguments: args)
                                        await MainActor.run {
                                            state.isLoading = false
                                            state.lastResponse = result
                                            withAnimation { state.showingResponse = true }
                                            if let mgr {
                                                let msgs = [
                                                    MiniChatMessage(role: .user, content: prompt),
                                                    MiniChatMessage(role: .assistant, content: result)
                                                ]
                                                SiriResponseWindowManager.shared.showMessages(msgs, bubbleManager: mgr)
                                            }
                                        }
                                    } catch {
                                        await MainActor.run {
                                            state.isLoading = false
                                            state.lastResponse = "Error: \(error.localizedDescription)"
                                            withAnimation { state.showingResponse = true }
                                            if let mgr {
                                                let msgs = [
                                                    MiniChatMessage(role: .user, content: prompt),
                                                    MiniChatMessage(role: .assistant, content: "Error: \(error.localizedDescription)")
                                                ]
                                                SiriResponseWindowManager.shared.showMessages(msgs, bubbleManager: mgr)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // MARK: - Session Button Views
                    //
                    // Each button is its own struct with @ObservedObject so that ChatPlugin changes
                    // trigger re-renders scoped to that single button. This avoids TupleView geometry
                    // issues that caused hit-test misalignment in the floating panel.

                    private struct SessionModelButton: View {
                        @ObservedObject var plugin: ChatPlugin
                        let sessionId: UUID
                        @State private var showPopover = false

                        var body: some View {
                            let session = plugin.sessions.first { $0.id == sessionId }
                            let currentModel = session?.model ?? "claude-sonnet-4-6"
                            let isDefault = currentModel == "claude-sonnet-4-6"
                            Button {
                                showPopover.toggle()
                            } label: {
                                Image(systemName: isDefault ? "cpu" : "cpu.fill")
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(isDefault ? .white.opacity(0.35) : .white)
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(isDefault ? 0.0 : 0.07)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        isDefault
                                            ? LinearGradient(colors: [Color.white.opacity(0.12)],
                                                             startPoint: .leading, endPoint: .trailing)
                                            : LinearGradient(colors: [Color.orange.opacity(0.40), Color.yellow.opacity(0.30)],
                                                             startPoint: .topLeading, endPoint: .bottomTrailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .popover(isPresented: $showPopover, arrowEdge: .bottom) {
                                VStack(alignment: .leading, spacing: 2) {
                                    PopoverHeader(icon: "cpu", title: "Model")
                                    ForEach(ChatSession.modelOptions, id: \.id) { option in
                                        PopoverMenuItem(
                                            icon: option.id == currentModel ? "checkmark.circle.fill" : "circle",
                                            label: option.label
                                        ) {
                                            plugin.updateSessionModel(sessionId, model: option.id)
                                            if !ChatSession.thinkingModels.contains(option.id) {
                                                plugin.updateSessionThinking(sessionId, enabled: false)
                                            }
                                            showPopover = false
                                        }
                                    }
                                }
                                .padding(8)
                                .frame(width: 200)
                                .background(.ultraThinMaterial)
                                .preferredColorScheme(.dark)
                            }
                        }
                    }

                    private struct SessionModeButton: View {
                        @ObservedObject var plugin: ChatPlugin
                        let sessionId: UUID
                        @State private var showPopover = false

                        private func modeIcon(_ mode: String) -> String {
                            switch mode {
                            case "plan":   return "list.bullet.clipboard.fill"
                            case "manual": return "hand.raised.fill"
