                        var reply = yield bus.call (
                            "org.freedesktop.systemd1",
                            "/org/freedesktop/systemd1",
                            "org.freedesktop.systemd1.Manager",
                            "ListUnits",
                            null, null, DBusCallFlags.NONE, -1
                        );
                        // Parse unit list into ServiceInfo objects
                    }
                    ```

