                        private func pasteFilesFromPasteboard() {
                            let pb = NSPasteboard.general
                            guard let urls = pb.readObjects(forClasses: [NSURL.self], options: [
                                .urlReadingFileURLsOnly: true
                            ]) as? [URL], !urls.isEmpty else { return }
                            for url in urls {
