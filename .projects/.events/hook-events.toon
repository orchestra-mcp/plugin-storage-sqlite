                  if grep -q "orchestra-mcp/gen-go v" "$gomod" 2>/dev/null; then
                    sed -i '' 's|orchestra-mcp/gen-go v[0-9]*\.[0-9]*\.[0-9]*[^ ]*|orchestra-mcp/gen-go v0.1.3|g' "$gomod"
                  fi
                  if grep -q "orchestra-mcp/sdk-go v" "$gomod" 2>/dev/null; then
                    sed -i '' 's|orchestra-mcp/sdk-go v[0-9]*\.[0-9]*\.[0-9]*[^ ]*|orchestra-mcp/sdk-go v0.1.3|g' "$gomod"
                  fi
