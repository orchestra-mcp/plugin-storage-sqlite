                       308→
                       309→    // MARK: - Quick Action Toggle
                       310→
                       311→    private var quickActionToggle: some View {
                       312→        Button {
                       313→            if isFloating {
                       314→                // Floating: animate chevron only (safe -- does not change layout)
                       315→                let willShow = !state.showQuickActions
                       316→                withAnimation(.spring(response: 0.35, dampingFraction: 0.78)) {
                       317→                    chevronRotation = willShow ? 180 : 0
                       318→                }
                       319→                if willShow {
                       320→                    state.showQuickActions = true
