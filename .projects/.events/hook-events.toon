                                    ForEach(ChatSession.modeOptions, id: \.id) { option in
                                        PopoverMenuItem(
                                            icon: option.id == currentMode ? "checkmark.circle.fill" : modeIcon(option.id),
                                            label: option.label
                                        ) {
                                            plugin.updateSessionMode(sessionId, mode: option.id)
