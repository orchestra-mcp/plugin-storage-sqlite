                                      <i className="bx bx-log-out" style={{ marginRight: 8 }} /> Sign out
                                    </DropdownMenuItem>
                                  </DropdownMenuContent>
                                </DropdownMenu>
                              </header>

                              {/* Page content */}
                              <main style={{ flex: 1, overflowY: 'auto' }}>
                                {children}
                              </main>
                            </div>
                          </div>
                        </div>
                      )
                    }
