                    #if os(macOS)
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - SmartFloatingContent
                    //
                    // SwiftUI content rendered inside the floating NSPanel managed by SmartInputWindowManager.
                    // Switches between two visual modes driven by manager.isExpanded:
                    //
                    //   Bubble   — 64x64pt circle (idle / draggable)
                    //   Expanded — 560pt wide glass card, expands leftward from bubble position
                    //
                    // The expanded card delegates all input bar logic to InputBarContent (shared with DockedInputBar).
                    // Dragging in bubble mode is handled entirely by TransparentPanel.sendEvent.

                    struct SmartFloatingContent: View {
                        @ObservedObject var manager: SmartInputWindowManager
                        @ObservedObject private var state = SmartInputState.shared
                        let chatPlugin: ChatPlugin?

                        var body: some View {
                            if manager.isExpanded {
                                expandedCard
                            } else {
                                bubbleButton
                            }
                        }

                        // MARK: - Bubble

                        @State private var bubbleRotation: Double = 0

                        private var bubbleButton: some View {
                            ZStack {
                                Image("OrchestraLogo")
                                    .resizable()
                                    .scaledToFit()
                                    .frame(width: 26, height: 26)
                                    .colorMultiply(.white)
                                    .brightness(1)
                                    .rotationEffect(.degrees(bubbleRotation))
                            }
                            .frame(width: 64, height: 64)
                            .background(.ultraThinMaterial, in: Circle())
                            .overlay(Circle().fill(Color.white.opacity(0.10)))
                            .overlay(Circle().strokeBorder(Color.white.opacity(0.25), lineWidth: 0.75))
                            .shadow(color: .black.opacity(0.18), radius: 4, x: 0, y: 2)
                            .contentShape(Circle())
                            .onTapGesture {
                                withAnimation(.smooth(duration: 0.7)) {
                                    bubbleRotation -= 360
                                }
                                DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                                    manager.expand()
                                }
                            }
                            .onHover { inside in
                                if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() }
                            }
                            .onReceive(NotificationCenter.default.publisher(for: .orchestraCollapseSmartInput)) { _ in
                                withAnimation(.smooth(duration: 0.7)) {
                                    bubbleRotation += 360
                                }
                            }
                        }

                        // MARK: - Expanded card

                        private var expandedCard: some View {
                            expandedCardContent
                                .onChange(of: state.activeTrigger) { _, _ in notifyHeightChange() }
                                .onChange(of: state.triggerResults.count) { _, _ in notifyHeightChange() }
                        }

                        private var expandedCardContent: some View {
                            InputBarContent(
                                chatPlugin: chatPlugin,
                                sessionId: nil,
                                isFloating: true,
                                onDock: SmartInputWindowManager.isTrayMode ? nil : { manager.dockToChat() },
                                onHeightChange: { notifyHeightChange() }
                            )
                            // Kill ALL implicit SwiftUI animations inside the floating panel.
                            // Any SwiftUI animation that changes layout size triggers
                            // NSHostingView.updateAnimatedWindowSize → SIGABRT.
                            .transaction { $0.disablesAnimations = true }
                            .frame(maxWidth: .infinity, maxHeight: .infinity)
                            .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: 22, style: .continuous))
                            .overlay(
                                RoundedRectangle(cornerRadius: 22, style: .continuous)
                                    .fill(Color.white.opacity(0.10))
                                    .allowsHitTesting(false)
                            )
                            .overlay(
                                RoundedRectangle(cornerRadius: 22, style: .continuous)
                                    .strokeBorder(Color.white.opacity(0.25), lineWidth: 0.75)
                                    .allowsHitTesting(false)
                            )
                            .shadow(color: .black.opacity(0.15), radius: 6, x: 0, y: 3)
                        }

                        private func notifyHeightChange() {
                            NotificationCenter.default.post(name: .orchestraInputHeightChanged, object: nil)
                        }
                    }
                    #endif
