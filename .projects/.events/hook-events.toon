                    │       │   │   └── notes-view.vala
                    │       │   ├── devtools-plugin/
                    │       │   │   ├── devtools-plugin.vala
                    │       │   │   └── devtools-view.vala
                    │       │   └── settings-plugin/
                    │       │       ├── settings-plugin.vala
                    │       │       └── settings-view.vala
                    │       ├── widgets/
                    │       │   ├── status-badge.vala
                    │       │   ├── connection-indicator.vala
                    │       │   └── empty-state-view.vala
                    │       └── theme/
                    │           ├── orchestra-theme.vala     # Color tokens + CSS provider
                    │           └── style.css               # GTK4 CSS overrides
                    ├── desktop/                            # GNOME desktop app entry point
                    │   ├── meson.build
