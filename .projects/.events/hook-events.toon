                // MARK: - MiniChatBubble (for floating card)

                private struct MiniChatBubble: View {
                    let message: MiniChatMessage
                    private var isUser: Bool { message.role == .user }

                    var body: some View {
                        HStack(alignment: .top, spacing: 0) {
                            if isUser { Spacer(minLength: 40) }
                            VStack(alignment: isUser ? .trailing : .leading, spacing: 0) {
                                if isUser {
                                    Text(message.content)
                                        .font(.system(size: 12.5))
                                        .foregroundStyle(.white)
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 6)
                                        .background(Color.accentColor.opacity(0.85))
                                        .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                                        .textSelection(.enabled)
                                } else {
                                    MarkdownContentView(markdown: message.content)
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 6)
                                        .background(Color.white.opacity(0.08))
                                        .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                                }
                            }
                            if !isUser { Spacer(minLength: 40) }
                        }
                    }
                }

                // MARK: - MiniTypingIndicator

                private struct MiniTypingIndicator: View {
                    @State private var dotPhase = 0
                    @State private var pulseScale: CGFloat = 1.0
                    private let timer = Timer.publish(every: 0.5, on: .main, in: .common).autoconnect()

                    private let gradientColors: [Color] = [
                        Color(red: 0.00, green: 0.90, blue: 1.00),  // Cyan
                        Color(red: 0.66, green: 0.00, blue: 1.00),  // Purple
                    ]

                    var body: some View {
                        HStack(alignment: .bottom, spacing: 0) {
                            HStack(spacing: 4) {
                                Text("Thinking" + String(repeating: ".", count: dotPhase + 1))
                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(
                                        LinearGradient(
                                            colors: gradientColors,
                                            startPoint: .leading,
                                            endPoint: .trailing
                                        )
                                    )
                                    .scaleEffect(pulseScale)
                                    .animation(.easeInOut(duration: 1.0).repeatForever(autoreverses: true), value: pulseScale)
                            }
                            .padding(.horizontal, 10)
                            .padding(.vertical, 6)
                            .background(Color.white.opacity(0.08))
                            .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                            Spacer(minLength: 40)
                        }
                        .onReceive(timer) { _ in dotPhase = (dotPhase + 1) % 3 }
                        .onAppear { pulseScale = 1.03 }
                    }
                }

                // MARK: - MiniStatusBar

                private struct MiniStatusBar: View {
                    let metadata: SessionMetadata

                    var body: some View {
                        HStack(spacing: 8) {
                            if !metadata.model.isEmpty {
                                miniMetaItem(icon: "cpu", text: shortModel(metadata.model))
                            }
                            if metadata.tokenCount > 0 {
                                miniMetaItem(icon: "number", text: "\(metadata.tokenCount)")
                            }
                            if !metadata.duration.isEmpty {
                                miniMetaItem(icon: "clock", text: metadata.duration)
                            }
                            if !metadata.cost.isEmpty {
                                miniMetaItem(icon: "dollarsign.circle", text: metadata.cost)
                            }
                            Spacer()
                        }
                    }

                    private func miniMetaItem(icon: String, text: String) -> some View {
                        HStack(spacing: 3) {
                            Image(systemName: icon)
                                .font(.system(size: 8, weight: .medium))
                            Text(text)
                                .font(.system(size: 10))
                        }
                        .foregroundStyle(.white.opacity(0.45))
                        .padding(.horizontal, 6)
                        .padding(.vertical, 2)
                        .background(Color.white.opacity(0.06), in: Capsule())
                    }

                    /// Shorten model names like "claude-opus-4-6" to "Opus 4.6"
                    private func shortModel(_ m: String) -> String {
                        if m.contains("opus") { return "Opus 4.6" }
                        if m.contains("sonnet") { return "Sonnet 4.6" }
                        if m.contains("haiku") { return "Haiku 4.5" }
                        return m
                    }
                }
                #endif
