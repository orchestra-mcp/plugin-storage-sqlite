            originalFile: |
                .PHONY: proto build build-orchestrator build-storage-markdown build-tools-features build-transport-stdio build-cli test test-unit test-e2e clean install release build-test-example

                # Directories
                BIN_DIR := bin
                PROTO_DIR := libs/proto
