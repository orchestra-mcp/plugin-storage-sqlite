                # the internal dependency versions need to match the release).
                GOMOD_VERSION="${VERSION#v}"

                info "Bumping internal dependencies to ${VERSION} in all go.mod files..."

                if $DRY_RUN; then
                  info "(dry-run) would update go.mod files"
