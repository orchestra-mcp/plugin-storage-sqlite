                            Color(red: 0.66, green: 0.00, blue: 1.00),  // #a900ff purple
                        ]
                        private let radius: CGFloat = 18

                        // MARK: - Body

                        var body: some View {
                            VStack(spacing: 10) {

                                // Smart response card — floats above bar in non-chat mode
                                if !state.isChatMode, state.showingResponse, let response = state.lastResponse {
                                    SmartResponseCard(
                                        response: response,
                                        gradientColors: gradientColors,
                                        onDismiss: {
