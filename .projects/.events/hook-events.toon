                       516→    private func append(_ message: ChatMessage, to session: inout ChatSession) {
                       517→        session.messages.append(message)
                       518→        if let idx = sessions.firstIndex(where: { $0.id == session.id }) {
                       519→            sessions[idx] = session
                       520→        }
                       521→        selectedSession = session
                       522→    }
                       523→
                       524→    enum ChatError: Error, LocalizedError {
                       525→        case noBridgeSession
                       526→        case sessionIdNotFound(String)
                       527→
                       528→        var errorDescription: String? {
                       529→            switch self {
                       530→            case .noBridgeSession:
                       531→                return "No bridge session established."
                       532→            case .sessionIdNotFound(let response):
                       533→                return "Could not parse session ID from response: \(response.prefix(200))"
                       534→            }
                       535→        }
                       536→    }
                       537→
                       538→    // MARK: - Loading Words
                       539→
                       540→    public static let loadingWords: [String] = [
                       541→        "Thinking", "Pondering", "Brewing", "Conjuring", "Weaving",
                       542→        "Crafting", "Dreaming", "Exploring", "Imagining", "Composing",
                       543→        "Analyzing", "Processing", "Computing", "Decoding", "Synthesizing"
                       544→    ]
                       545→
                       546→    private var loadingWordTimer: Timer?
                       547→    private var loadingWordIndex: Int = 0
                       548→
                       549→    private func startLoadingWordTimer() {
                       550→        loadingWordIndex = 0
                       551→        loadingWord = Self.loadingWords[0]
                       552→        loadingWordTimer = Timer.scheduledTimer(withTimeInterval: 2.0, repeats: true) { [weak self] _ in
                       553→            Task { @MainActor [weak self] in
                       554→                guard let self = self else { return }
                       555→                self.loadingWordIndex = (self.loadingWordIndex + 1) % Self.loadingWords.count
                       556→                self.loadingWord = Self.loadingWords[self.loadingWordIndex]
                       557→            }
                       558→        }
                       559→    }
                       560→
                       561→    private func stopLoadingWordTimer() {
                       562→        loadingWordTimer?.invalidate()
                       563→        loadingWordTimer = nil
                       564→        loadingWord = "Thinking"
                       565→    }
                       566→}
                       567→
                       568→// MARK: - Color / Icon palette helpers
                       569→
                       570→extension ChatSession {
                       571→    static let colorOptions: [(name: String, color: Color)] = [
                       572→        ("",         .accentColor),
                       573→        ("red",      .red),
                       574→        ("orange",   .orange),
                       575→        ("yellow",   .yellow),
                       576→        ("green",    .green),
                       577→        ("teal",     .teal),
                       578→        ("blue",     .blue),
                       579→        ("indigo",   .indigo),
                       580→        ("purple",   .purple),
                       581→        ("pink",     .pink),
                       582→        ("gray",     .gray),
                       583→    ]
                       584→
                       585→    static let iconOptions: [String] = [
                       586→        "bubble.left", "star", "bolt", "flame", "heart",
                       587→        "brain", "wand.and.stars", "sparkles", "cpu",
                       588→        "doc.text", "terminal", "code", "pencil", "paintbrush",
                       589→    ]
                       590→
                       591→    var resolvedColor: Color {
                       592→        ChatSession.colorOptions.first { $0.name == colorName }?.color ?? .accentColor
                       593→    }
                       594→
                       595→    var resolvedIcon: String {
                       596→        iconName.isEmpty ? "bubble.left" : iconName
                       597→    }
                       598→}
                       599→
                       600→// MARK: - Column 2: Session List
                       601→// searchText is passed from the shared sidebar filter bar (SidebarFilterBar).
                       602→// The + button in that bar posts .orchestraNewItem which is handled here.
                       603→
                       604→struct ChatSessionListView: View {
                       605→    @ObservedObject var plugin: ChatPlugin
                       606→    let searchText: String
                       607→    @State private var editingSession: ChatSession? = nil
                       608→    @State private var renamingSession: ChatSession? = nil
                       609→    @State private var renameText: String = ""
                       610→    @State private var deletingSession: ChatSession? = nil   // single-delete confirmation
                       611→    @State private var confirmDeleteSelected = false          // bulk-delete confirmation
                       612→    @Namespace private var selectionNamespace
                       613→
                       614→    private var filtered: [ChatSession] {
                       615→        guard !searchText.isEmpty else { return plugin.sessions }
                       616→        let q = searchText.lowercased()
                       617→        return plugin.sessions.filter { $0.title.lowercased().contains(q) }
                       618→    }
                       619→
                       620→    var body: some View {
                       621→        VStack(spacing: 0) {
                       622→            // ── Select mode header ────────────────────────────────
                       623→            if plugin.isSelecting {
                       624→                HStack(spacing: 6) {
                       625→                    Button("Cancel") { plugin.clearSelection() }
                       626→                        .buttonStyle(.plain)
                       627→                        .font(.system(size: 12))
                       628→                        .foregroundStyle(.secondary)
                       629→                    Spacer()
                       630→                    if !plugin.selectedIds.isEmpty {
                       631→                        Button(role: .destructive) {
                       632→                            confirmDeleteSelected = true
                       633→                        } label: {
                       634→                            Image(systemName: "trash")
                       635→                                .font(.system(size: 12))
                       636→                        }
                       637→                        .buttonStyle(.plain)
                       638→                        .foregroundStyle(.red)
                       639→                    }
                       640→                }
                       641→                .padding(.horizontal, 12)
                       642→                .padding(.vertical, 7)
                       643→                Divider()
                       644→            }
                       645→
                       646→            // ── List ──────────────────────────────────────────────
                       647→            if plugin.sessions.isEmpty {
                       648→                Spacer()
                       649→                VStack(spacing: 8) {
                       650→                    Image(systemName: "bubble.left")
                       651→                        .font(.system(size: 28))
                       652→                        .foregroundStyle(.tertiary)
                       653→                    Text("No chats yet")
                       654→                        .font(.caption)
                       655→                        .foregroundStyle(.secondary)
                       656→                    Button("New Chat") { plugin.newSession() }
                       657→                        .buttonStyle(.bordered)
                       658→                        .controlSize(.small)
                       659→                }
                       660→                Spacer()
                       661→            } else if filtered.isEmpty {
                       662→                Spacer()
                       663→                VStack(spacing: 6) {
                       664→                    Image(systemName: "magnifyingglass")
                       665→                        .font(.system(size: 24))
                       666→                        .foregroundStyle(.tertiary)
                       667→                    Text("No results")
                       668→                        .font(.caption)
                       669→                        .foregroundStyle(.secondary)
                       670→                }
                       671→                Spacer()
                       672→            } else {
                       673→                ScrollView {
                       674→                    LazyVStack(spacing: 4) {
                       675→                        ForEach(filtered, id: \.id) { session in
                       676→                            let isSelected = plugin.selectedSession?.id == session.id
                       677→                            SessionRow(
                       678→                                session: session,
                       679→                                isSelected: isSelected,
                       680→                                isChecked: plugin.selectedIds.contains(session.id),
                       681→                                isSelecting: plugin.isSelecting,
                       682→                                selectionNamespace: selectionNamespace,
                       683→                                onPin: { plugin.togglePin(session) },
                       684→                                onDelete: { deletingSession = session },
                       685→                                onTap: {
                       686→                                    if plugin.isSelecting {
                       687→                                        plugin.toggleSelect(session.id)
                       688→                                    } else {
                       689→                                        withAnimation(.spring(response: 0.32, dampingFraction: 0.78)) {
                       690→                                            plugin.selectedSession = session
                       691→                                        }
                       692→                                        NotificationCenter.default.post(name: .orchestraPluginActivated, object: plugin.id)
                       693→                                    }
                       694→                                },
                       695→                                onLongPress: {
                       696→                                    withAnimation(.spring(response: 0.3, dampingFraction: 0.75)) {
                       697→                                        if !plugin.isSelecting { plugin.isSelecting = true }
                       698→                                        plugin.toggleSelect(session.id)
                       699→                                    }
                       700→                                }
                       701→                            )
                       702→                            .padding(.horizontal, 10)
                       703→                            // ── Context menu ──────────────────────
                       704→                            .contextMenu {
                       705→                                Button {
                       706→                                    renameText = session.title
                       707→                                    renamingSession = session
                       708→                                } label: {
                       709→                                    Label("Rename", systemImage: "pencil")
                       710→                                }
                       711→
                       712→                                Button {
                       713→                                    plugin.togglePin(session)
                       714→                                } label: {
                       715→                                    Label(session.isPinned ? "Unpin" : "Pin",
                       716→                                          systemImage: session.isPinned ? "pin.slash" : "pin")
                       717→                                }
                       718→
                       719→                                Button { editingSession = session } label: {
                       720→                                    Label("Color & Icon", systemImage: "paintpalette")
                       721→                                }
                       722→
                       723→                                Divider()
                       724→
                       725→                                Button {
                       726→                                    if !plugin.isSelecting { plugin.isSelecting = true }
                       727→                                    plugin.toggleSelect(session.id)
                       728→                                } label: {
                       729→                                    Label("Select", systemImage: "checkmark.circle")
                       730→                                }
                       731→
                       732→                                Divider()
                       733→
                       734→                                Button(role: .destructive) {
                       735→                                    deletingSession = session
                       736→                                } label: {
                       737→                                    Label("Delete", systemImage: "trash")
                       738→                                }
                       739→                            }
                       740→                        }
                       741→                    }
                       742→                    .padding(.top, 12)
                       743→                }
                       744→                .scrollIndicators(.never)
                       745→            }
                       746→        }
                       747→        .frame(maxWidth: .infinity, maxHeight: .infinity)
                       748→        // ── Keyboard shortcuts ────────────────────────────────────
                       749→        .onKeyPress(.escape) {
                       750→            if plugin.isSelecting {
                       751→                plugin.clearSelection()
                       752→                return .handled
                       753→            }
                       754→            return .ignored
                       755→        }
                       756→        .background {
                       757→            Group {
                       758→                // CMD+A — select all only when already in selection mode
                       759→                Button("") {
                       760→                    guard plugin.isSelecting, !filtered.isEmpty else { return }
                       761→                    withAnimation(.spring(response: 0.3, dampingFraction: 0.75)) {
                       762→                        plugin.selectedIds = Set(filtered.map(\.id))
                       763→                    }
                       764→                }
                       765→                .keyboardShortcut("a", modifiers: .command)
                       766→                .opacity(0)
                       767→                // CMD+F — trigger search
                       768→                Button("") {
                       769→                    NotificationCenter.default.post(name: .orchestraShowSearch, object: nil)
                       770→                }
                       771→                .keyboardShortcut("f", modifiers: .command)
                       772→                .opacity(0)
                       773→            }
                       774→        }
                       775→        .onKeyPress(.delete) {
                       776→            if plugin.isSelecting && !plugin.selectedIds.isEmpty {
                       777→                confirmDeleteSelected = true
                       778→                return .handled
                       779→            }
                       780→            return .ignored
                       781→        }
                       782→        // ── New chat from sidebar + button ────────────────────────
                       783→        .onReceive(NotificationCenter.default.publisher(for: .orchestraNewItem)) { note in
                       784→            if note.object as? String == "chat" || note.object == nil {
                       785→                plugin.newSession()
                       786→            }
                       787→        }
                       788→        // ── Appearance sheet ──────────────────────────────────────
                       789→        .sheet(item: $editingSession) { session in
                       790→            SessionAppearanceSheet(session: session) { colorName, iconName in
                       791→                plugin.updateSession(session.id, colorName: colorName, iconName: iconName)
                       792→            }
                       793→        }
                       794→        // ── Rename alert ──────────────────────────────────────────
                       795→        .alert("Rename Chat", isPresented: Binding(
                       796→            get: { renamingSession != nil },
                       797→            set: { if !$0 { renamingSession = nil } }
                       798→        )) {
                       799→            TextField("Chat name", text: $renameText)
                       800→            Button("Rename") {
                       801→                if let session = renamingSession {
                       802→                    let trimmed = renameText.trimmingCharacters(in: .whitespacesAndNewlines)
                       803→                    if !trimmed.isEmpty {
                       804→                        plugin.updateSession(session.id, title: trimmed)
                       805→                    }
                       806→                }
                       807→                renamingSession = nil
                       808→            }
                       809→            .keyboardShortcut(.defaultAction)
                       810→            Button("Cancel", role: .cancel) { renamingSession = nil }
                       811→        } message: {
                       812→            if let session = renamingSession {
                       813→                Text("Enter a new name for \"\(session.title)\"")
                       814→            }
                       815→        }
                       816→        // ── Single delete confirmation ────────────────────────────
                       817→        .alert("Delete Chat", isPresented: Binding(
                       818→            get: { deletingSession != nil },
                       819→            set: { if !$0 { deletingSession = nil } }
                       820→        )) {
                       821→            Button("Delete", role: .destructive) {
                       822→                if let session = deletingSession {
                       823→                    plugin.deleteSession(session)
                       824→                }
                       825→                deletingSession = nil
                       826→            }
                       827→            Button("Cancel", role: .cancel) { deletingSession = nil }
                       828→        } message: {
                       829→            if let session = deletingSession {
                       830→                Text("Delete \"\(session.title)\"? This cannot be undone.")
                       831→            }
                       832→        }
                       833→        // ── Bulk delete confirmation ──────────────────────────────
                       834→        .alert("Delete \(plugin.selectedIds.count) Chats", isPresented: $confirmDeleteSelected) {
                       835→            Button("Delete All", role: .destructive) {
                       836→                plugin.deleteSelected()
                       837→            }
                       838→            Button("Cancel", role: .cancel) {}
                       839→        } message: {
                       840→            Text("This will permanently delete \(plugin.selectedIds.count) chat\(plugin.selectedIds.count == 1 ? "" : "s"). This cannot be undone.")
                       841→        }
                       842→    }
                       843→}
                       844→
