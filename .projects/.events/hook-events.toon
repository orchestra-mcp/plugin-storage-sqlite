                       258→                .opacity(!voiceService.voiceModeActive && state.isLoading ? 1 : 0)
                       259→
                       260→            // Send button
                       261→            Button(action: sendMessage) {
                       262→                ZStack {
                       263→                    Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                       264→                    Circle().fill(Color.white.opacity(canSend ? 0.18 : 0.07)).frame(width: 30, height: 30)
                       265→                    Image(systemName: "arrow.up")
                       266→                        .font(.system(size: 12, weight: .bold))
                       267→                        .foregroundStyle(canSend ? .white : Color.white.opacity(0.30))
                       268→                }
                       269→            }
                       270→            .buttonStyle(.plain)
                       271→            .disabled(!canSend)
                       272→            .scaleEffect(canSend ? 1.0 : 0.85)
                       273→            .opacity(!voiceService.voiceModeActive && !state.isLoading ? 1 : 0)
                       274→            .allowsHitTesting(!voiceService.voiceModeActive && !state.isLoading)
                       275→        }
                       276→        .frame(width: 36, height: 32)
