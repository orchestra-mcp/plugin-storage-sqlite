                    apiFetch<Project[] | { projects: Project[] }>('/api/projects')
                      .then(r => { setProjects(Array.isArray(r) ? r : (r.projects ?? [])); setLoading(false) })
                      .catch(() => setLoading(false))
                  }, [])

                  const filtered = projects.filter(p =>
                    p.name.toLowerCase().includes(search.toLowerCase()) ||
                    (p.description ?? '').toLowerCase().includes(search.toLowerCase())
                  )

                  async function handleCreate() {
                    if (!newName.trim()) return
                    setCreating(true); setCreateError(null)
                    try {
                      if (isDevSeed()) {
                        // Fake it locally
                        const fake: Project = { id: crypto.randomUUID(), name: newName.trim(), description: newDesc.trim() || undefined, created_at: new Date().toISOString() }
