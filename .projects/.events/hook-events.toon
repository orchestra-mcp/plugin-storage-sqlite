                    func (t *Transport) dispatch(method string, params []byte) ([]byte, error) {
                    	switch method {
                    	case "initialize":
                    		return t.handleInitialize(params)
                    	case "ping":
                    		return []byte("{}"), nil
                    	default:
                    		return nil, fmt.Errorf("method not found: %s", method)
                    	}
                    }

