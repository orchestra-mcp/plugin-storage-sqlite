                        if let session = plugin.selectedSession {
                            plugin.sessions[0].messages = [
                                ChatMessage(sessionId: session.id, role: .user, content: "Hello!"),
                                ChatMessage(sessionId: session.id, role: .assistant, content: "Hi! How can I help?"),
                            ]
                            plugin.selectedSession = plugin.sessions[0]
                        }
                        return HStack(spacing: 0) {
                            plugin.makePanelView(searchText: "").frame(width: 260)
                            Divider()
                            plugin.makeView()
                        }
                        .frame(width: 800, height: 500)
                    }
