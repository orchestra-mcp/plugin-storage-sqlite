                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - Notification

                    extension Notification.Name {
                        public static let orchestraActivateSmartInput = Notification.Name("orchestra.activateSmartInput")
                        public static let orchestraCollapseSmartInput = Notification.Name("orchestra.collapseSmartInput")
                        /// Posted when a trigger result (e.g. quick action `!`) should auto-send the message.
                        public static let orchestraTriggerAutoSend    = Notification.Name("orchestra.triggerAutoSend")
                    }

                    // MARK: - Smart Input Bar
                    //
                    // On macOS: returns EmptyView — the floating NSPanel (SmartInputWindowManager) is used instead.
                    // On iOS/iPadOS: renders the full two-row glass card.

                    public struct SmartInputBar: View {
                        let chatPlugin: ChatPlugin?

                        public init(chatPlugin: ChatPlugin? = nil) {
                            self.chatPlugin = chatPlugin
                        }

                        public var body: some View {
                            #if os(macOS)
                            EmptyView()  // macOS uses DockedInputBar (in ChatDetailView) or floating SmartFloatingContent
                            #else
                            SmartInputContent(chatPlugin: chatPlugin)
                            #endif
                        }
                    }

                    // MARK: - SmartInputContent (iOS / non-macOS full implementation)
                    //
                    // Visual system — identical tokens to the nav pill and session rows:
                    //   background : .ultraThinMaterial
                    //   fill tint  : Color.white.opacity(0.10)
                    //   border     : Color.white.opacity(0.12), lineWidth: 0.75  (rest)
                    //              : gradient cyan→purple, lineWidth: 1.2         (focused / loading)
                    //   shadow     : .black.opacity(0.18), radius: 8, y: 4
                    //
                    // Layout (matches Zap-style two-row card):
                    //   ┌─────────────────────────────────────────────────┐
                    //   │  Ask anything… / Message…                       │  row 1 — text field
                    //   ├╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┤  inner divider
                    //   │  [chip] [chip] [chip] …            [icon]  [↑]  │  row 2 — actions
                    //   └─────────────────────────────────────────────────┘
                    //
                    //   cornerRadius: 18  (rounded rect, not capsule)
                    //   Enter = send · Shift+Enter = newline

                    private struct SmartInputContent: View {
                        @ObservedObject private var state   = SmartInputState.shared
                        @ObservedObject private var context = AppContext.shared

                        let chatPlugin: ChatPlugin?

                        @FocusState private var inputFocused: Bool
                        @State private var useContext  = true
                        @State private var hoverDetach = false

                        // Exact same gradient as every other accent in the app
