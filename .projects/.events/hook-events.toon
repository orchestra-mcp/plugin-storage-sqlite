    - event_type: PostToolUse
      session_id: 699c140c-f58a-4c9e-85ef-b3ec2c825fd9
      tool_name: Edit
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: acceptEdits
        session_id: 699c140c-f58a-4c9e-85ef-b3ec2c825fd9
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/next/src/app/(app)/notes/page.tsx
