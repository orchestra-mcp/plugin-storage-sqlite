                    // MARK: - GlassTooltip
                    //
                    // Custom hover tooltip for toolbar buttons. Shows a small glass label above the
                    // button after a brief delay. Works in the floating NSPanel where native .help()
                    // tooltips don't appear.

                    struct GlassTooltip: ViewModifier {
                        let text: String
                        @State private var showTooltip = false
                        @State private var hoverTask: Task<Void, Never>?

                        func body(content: Content) -> some View {
                            content
                                .popover(isPresented: $showTooltip, arrowEdge: .bottom) {
                                    Text(text)
                                        .font(.system(size: 11, weight: .medium))
                                        .foregroundStyle(.white.opacity(0.9))
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 6)
                                        .fixedSize()
                                        .background(.ultraThinMaterial)
                                        .preferredColorScheme(.dark)
                                }
                                .onHover { inside in
                                    if inside {
                                        NSCursor.pointingHand.push()
                                        hoverTask?.cancel()
                                        hoverTask = Task { @MainActor in
                                            try? await Task.sleep(for: .milliseconds(500))
                                            guard !Task.isCancelled else { return }
                                            showTooltip = true
                                        }
                                    } else {
                                        NSCursor.pop()
                                        hoverTask?.cancel()
                                        showTooltip = false
                                    }
                                }
                        }
                    }

                    extension View {
                        func glassTooltip(_ text: String) -> some View {
                            modifier(GlassTooltip(text: text))
                        }
                    }

                    // MARK: - Popover Menu Components
                    //
                    // Reusable header and menu-item views used by the suggestions, browser,
                    // and screenshot popovers. Items highlight on hover and show a pointer cursor.

                    struct PopoverHeader: View {
                        let icon: String
                        let title: String

                        var body: some View {
                            HStack(spacing: 6) {
                                Image(systemName: icon)
                                    .font(.system(size: 10, weight: .semibold))
                                    .foregroundStyle(.white.opacity(0.45))
                                Text(title)
                                    .font(.system(size: 11, weight: .semibold))
                                    .foregroundStyle(.white.opacity(0.45))
                            }
                            .padding(.horizontal, 10)
                            .padding(.top, 2)
                            .padding(.bottom, 4)
                        }
                    }

                    struct PopoverMenuItem: View {
                        let icon: String
                        let label: String
                        let action: () -> Void
                        @State private var isHovered = false

                        var body: some View {
                            Button(action: action) {
                                HStack(spacing: 8) {
                                    Image(systemName: icon)
                                        .font(.system(size: 11, weight: .medium))
                                        .foregroundStyle(isHovered ? .white.opacity(0.8) : .white.opacity(0.5))
                                        .frame(width: 18)
                                    Text(label)
                                        .font(.system(size: 12, weight: .regular))
                                        .foregroundStyle(isHovered ? .white : .white.opacity(0.85))
                                        .lineLimit(1)
                                }
                                .frame(maxWidth: .infinity, alignment: .leading)
                                .padding(.horizontal, 10)
                                .padding(.vertical, 7)
                                .background(
                                    RoundedRectangle(cornerRadius: 6, style: .continuous)
                                        .fill(Color.white.opacity(isHovered ? 0.10 : 0.0))
                                )
                                .contentShape(RoundedRectangle(cornerRadius: 6, style: .continuous))
                            }
                            .buttonStyle(.plain)
                            .onHover { inside in
                                withAnimation(.easeInOut(duration: 0.12)) { isHovered = inside }
                                if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() }
                            }
                        }
                    }

                    // MARK: - Animated Loading Dots

                    private struct InputBarLoadingDots: View {
                        @State private var phase = 0
                        private let timer = Timer.publish(every: 0.38, on: .main, in: .common).autoconnect()
                        private let gradientColors: [Color] = [
                            Color(red: 0.00, green: 0.90, blue: 1.00),
                            Color(red: 0.66, green: 0.00, blue: 1.00),
                        ]

                        var body: some View {
                            HStack(spacing: 5) {
                                ForEach(0..<3, id: \.self) { i in
                                    Circle()
                                        .fill(LinearGradient(
                                            colors: gradientColors,
                                            startPoint: .topLeading,
                                            endPoint: .bottomTrailing))
                                        .frame(width: 6, height: 6)
                                        .opacity(phase == i ? 1.0 : 0.25)
                                        .scaleEffect(phase == i ? 1.3 : 0.85)
                                        .animation(.easeInOut(duration: 0.3), value: phase)
                                }
                            }
                            .onReceive(timer) { _ in phase = (phase + 1) % 3 }
                        }
                    }

