                       247→                    Image(systemName: voiceService.phase == .speaking ? "hand.raised.fill" : "stop.fill")
                       248→                        .font(.system(size: 12, weight: .bold))
                       249→                        .foregroundStyle(.red)
                       250→                }
                       251→            }
                       252→            .buttonStyle(.plain)
                       253→            .opacity(voiceService.voiceModeActive ? 1 : 0)
                       254→            .allowsHitTesting(voiceService.voiceModeActive)
                       255→
                       256→            // Loading dots
