            newString: |-
                import SwiftUI
                #if !XCODE_BUILD
                import OrchestraShared
                #endif

                /// Write debug log to /tmp/orchestra-app.log for diagnosis.
                private func debugLog(_ msg: String) {
                    let line = "\(ISO8601DateFormatter().string(from: Date())) \(msg)\n"
                    if let data = line.data(using: .utf8) {
