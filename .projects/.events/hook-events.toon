                  const inputBg = isDark ? 'rgba(255,255,255,0.04)' : '#fafafa'

                  const filtered = members.filter(m => {
                    const q = search.toLowerCase()
                    return !q || m.name.toLowerCase().includes(q) || m.email.toLowerCase().includes(q)
