        tool_response:
            file:
                content: |4-
                         1→#if os(macOS)
                         2→import SwiftUI
                         3→#if !XCODE_BUILD
                         4→import OrchestraKit
                         5→#endif
                         6→
                         7→// MARK: - InputBarContent
                         8→//
                         9→// Unified inner content for the macOS input bar, used by both:
                        10→//   - DockedInputBar (in-window, isFloating = false)
                        11→//   - SmartFloatingContent expanded card (NSPanel, isFloating = true)
                        12→//
                        13→// This component owns the text field, quick actions row, trigger autocomplete,
                        14→// file attachment chips, voice mode indicator, and send/stop button. It does NOT
                        15→// own the outer glass card background or panel chrome — callers wrap it.
                        16→
                        17→struct InputBarContent: View {
                        18→    let chatPlugin: ChatPlugin?
                        19→    let sessionId: UUID?
                        20→    let isFloating: Bool
                        21→    var onDock: (() -> Void)? = nil
                        22→    var onDetach: (() -> Void)? = nil
                        23→    var onHeightChange: (() -> Void)? = nil
                        24→
                        25→    @ObservedObject private var state = SmartInputState.shared
                        26→    @FocusState private var inputFocused: Bool
                        27→    @ObservedObject private var voiceService = VoiceService.shared
                        28→    @ObservedObject private var screenshotService = ScreenshotService.shared
                        29→    @ObservedObject private var browserService = BrowserContextService.shared
                        30→    @State private var chevronRotation: Double = 0
                        31→    @State private var voiceModeMessageCount: Int = 0
                        32→    @State private var showSuggestionsPopover = false
                        33→    @State private var showBrowserPopover = false
                        34→    @State private var showScreenshotPopover = false
                        35→
                        36→    // MARK: - Body
                        37→
                        38→    var body: some View {
                        39→        contentVStack
                        40→            .onChange(of: state.text) { _, _ in
                        41→                state.processTextChange()
                        42→                if let trigger = state.activeTrigger {
                        43→                    Task {
                        44→                        let results = await TriggerService.shared.search(trigger: trigger, query: state.triggerQuery)
                        45→                        state.triggerResults = results
                        46→                    }
                        47→                }
                        48→            }
                        49→            .onChange(of: inputFocused) { _, focused in
                        50→                state.isFocused = focused
                        51→                state.processTextChange()
                        52→            }
                        53→            .background {
                        54→                // Hidden keyboard shortcuts for trigger navigation and paste
                        55→                Button("") { navigateTriggerUp() }
                        56→                    .keyboardShortcut(.upArrow, modifiers: [])
                        57→                    .opacity(0)
                        58→                Button("") { navigateTriggerDown() }
                        59→                    .keyboardShortcut(.downArrow, modifiers: [])
                        60→                    .opacity(0)
                        61→                Button("") { applySelectedTrigger() }
                        62→                    .keyboardShortcut(.tab, modifiers: [])
                        63→                    .opacity(0)
                        64→                Button("") { pasteFilesFromPasteboard() }
                        65→                    .keyboardShortcut("v", modifiers: .command)
                        66→                    .opacity(0)
                        67→            }
                        68→            .onAppear {
                        69→                DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) { inputFocused = true }
                        70→                browserService.startPolling()
                        71→                setupVoiceCallbacks()
                        72→            }
                        73→            .onReceive(NotificationCenter.default.publisher(for: .orchestraActivateSmartInput)) { _ in
                        74→                DispatchQueue.main.asyncAfter(deadline: .now() + 0.05) { inputFocused = true }
                        75→            }
                        76→            .onReceive(NotificationCenter.default.publisher(for: .orchestraTriggerAutoSend)) { _ in
                        77→                sendMessage()
                        78→            }
                        79→            // Auto-speak agent response when voice mode is active.
                        80→            // Uses a stable Timer publisher to poll instead of objectWillChange,
                        81→            // which causes re-render cascades and crashes in the floating panel.
                        82→            .onReceive(Timer.publish(every: 1.0, on: .main, in: .common).autoconnect()) { _ in
                        83→                guard voiceService.voiceModeActive else { return }
                        84→                guard let plugin = chatPlugin, !plugin.isSending else { return }
                        85→                guard let sid = resolvedSessionId,
                        86→                      let session = plugin.sessions.first(where: { $0.id == sid }),
                        87→                      let lastAssistant = session.messages.last(where: { $0.role == .assistant }) else { return }
                        88→                let msgCount = session.messages.count
                        89→                if msgCount > voiceModeMessageCount {
                        90→                    voiceModeMessageCount = msgCount
                        91→                    voiceService.speakAgentResponse(lastAssistant.content)
                        92→                }
                        93→            }
                        94→    }
                        95→
                        96→    // MARK: - Content Stack
                        97→
                        98→    private var contentVStack: some View {
                        99→        VStack(spacing: 0) {
                       100→            // File attachment chips
                       101→            if !state.attachedFiles.isEmpty {
                       102→                fileAttachmentChips
                       103→            }
                       104→
                       105→            inputRow
                       106→                .padding(.horizontal, 20)
                       107→                .padding(.vertical, isFloating ? 14 : 12)
                       108→
                       109→            if state.showQuickActions {
                       110→                Divider()
                       111→                    .background(Color.white.opacity(0.08))
                       112→                    .padding(.horizontal, 16)
                       113→                quickActionsRow
                       114→            }
                       115→
                       116→            if state.activeTrigger != nil {
                       117→                InputToolbar()
                       118→            }
                       119→        }
                       120→    }
                       121→
                       122→    // MARK: - Input Row
                       123→
                       124→    private var inputRow: some View {
                       125→        HStack(spacing: 10) {
                       126→            Image("OrchestraLogo")
                       127→                .resizable()
                       128→                .scaledToFit()
                       129→                .colorMultiply(.white)
                       130→                .brightness(1)
                       131→                .frame(width: isFloating ? 26 : 24, height: isFloating ? 26 : 24)
                       132→
                       133→            if !SmartInputWindowManager.isTrayMode {
                       134→                dockDetachButton
                       135→            }
                       136→
                       137→            // Voice mode: overlay indicator on top of text field using ZStack + opacity.
                       138→            // Avoids swapping the view tree which crashes NSHostingView in floating panel.
                       139→            ZStack {
                       140→                TextField(
                       141→                    state.isChatMode ? "Message..." : "Ask anything...",
                       142→                    text: $state.text
                       143→                )
                       144→                .textFieldStyle(.plain)
                       145→                .font(.system(size: 15, weight: .regular))
                       146→                .foregroundStyle(.white)
                       147→                .focused($inputFocused)
                       148→                .opacity(voiceService.voiceModeActive ? 0 : 1)
                       149→                .background {
                       150→                    Button("") {
                       151→                        if state.activeTrigger != nil, state.triggerSelectedIndex < state.triggerResults.count {
                       152→                            let shouldSend = state.applyTriggerResult(state.triggerResults[state.triggerSelectedIndex])
                       153→                            if shouldSend { sendMessage() }
                       154→                        } else {
                       155→                            sendMessage()
                       156→                        }
                       157→                    }
                       158→                    .keyboardShortcut(.return, modifiers: [])
                       159→                    .opacity(0)
                       160→                    Button("") { sendMessage() }
                       161→                        .keyboardShortcut(.return, modifiers: .command)
                       162→                        .opacity(0)
                       163→                    if isFloating {
                       164→                        Button("") {
                       165→                            NotificationCenter.default.post(name: .orchestraCollapseSmartInput, object: nil)
                       166→                            DispatchQueue.main.asyncAfter(deadline: .now() + 0.25) {
                       167→                                SmartInputWindowManager.shared.collapse()
                       168→                            }
                       169→                        }
                       170→                        .keyboardShortcut(.escape, modifiers: [])
                       171→                        .opacity(0)
                       172→                    }
                       173→                }
                       174→
                       175→                if voiceService.voiceModeActive {
                       176→                    voiceInlineIndicator
                       177→                }
                       178→            }
                       179→
                       180→            Spacer(minLength: 0)
                       181→            quickActionToggle
                       182→        }
                       183→    }
                       184→
                       185→    // MARK: - Voice Inline Indicator
                       186→
                       187→    private var voiceInlineIndicator: some View {
                       188→        HStack(spacing: 8) {
                       189→            // Animated phase dot
                       190→            Circle()
                       191→                .fill(voicePhaseColor)
                       192→                .frame(width: 10, height: 10)
                       193→                .scaleEffect(voiceService.phase == .listening ? CGFloat(1.0 + Double(voiceService.audioLevel) * 0.5) : 1.0)
                       194→
                       195→            // Phase label
                       196→            Text(voicePhaseLabelShort)
                       197→                .font(.system(size: 13, weight: .medium))
                       198→                .foregroundStyle(.white.opacity(0.6))
                       199→
                       200→            // Transcribed text (truncated)
                filePath: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/4c8aa7b3-279a-4e53-9880-b7605c240237/tool-results/toolu_0136ysYjcfD8ne3hRRn58aWn.txt
                numLines: 200
                startLine: 1
                totalLines: 1097
            type: text
