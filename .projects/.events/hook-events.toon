    - event_type: PostToolUse
      session_id: 1acff5d2-1b1a-4ff6-aa21-c57537674eaf
      tool_name: Edit
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: acceptEdits
        session_id: 1acff5d2-1b1a-4ff6-aa21-c57537674eaf
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/scripts/add-plugin-release-workflow.sh
            new_string: |4-
