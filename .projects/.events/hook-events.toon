                      1407→// MARK: - Docked Input Bar (macOS only)
                      1408→// Same visual style as the floating SmartFloatingContent expandedCard:
                      1409→// single-row capsule with glass background, logo, text field, send button.
                      1410→
                      1411→#if os(macOS)
                      1412→struct DockedInputBar: View {
                      1413→    let chatPlugin: ChatPlugin?
                      1414→    let sessionId: UUID
                      1415→    @ObservedObject private var state = SmartInputState.shared
                      1416→
                      1417→    var body: some View {
                      1418→        InputBarContent(
                      1419→            chatPlugin: chatPlugin,
                      1420→            sessionId: sessionId,
                      1421→            isFloating: false,
                      1422→            onDetach: {
                      1423→                withAnimation(.spring(response: 0.32, dampingFraction: 0.8)) {
                      1424→                    state.isDetached = true
                      1425→                }
                      1426→                SmartInputWindowManager.shared.openPanel(
                      1427→                    chatPlugin: state.activeChatPlugin ?? chatPlugin
                      1428→                )
                      1429→            }
                      1430→        )
                      1431→        .animation(.spring(response: 0.35, dampingFraction: 0.78), value: state.showQuickActions)
                      1432→        .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: 18, style: .continuous))
                      1433→        .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).fill(Color.white.opacity(0.10)).allowsHitTesting(false))
                      1434→        .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).strokeBorder(Color.white.opacity(0.25), lineWidth: 0.75).allowsHitTesting(false))
                      1435→        .shadow(color: .black.opacity(0.15), radius: 6, x: 0, y: 3)
                      1436→        #if os(macOS)
                      1437→        .onDrop(of: [.fileURL], isTargeted: nil) { providers in
                      1438→            for provider in providers {
                      1439→                provider.loadItem(forTypeIdentifier: UTType.fileURL.identifier, options: nil) { item, _ in
                      1440→                    if let data = item as? Data,
                      1441→                       let urlString = String(data: data, encoding: .utf8),
                      1442→                       let url = URL(string: urlString) {
                      1443→                        Task { @MainActor in
                      1444→                            state.attachFile(url)
                      1445→                        }
                      1446→                    }
                      1447→                }
                      1448→            }
                      1449→            return true
                      1450→        }
                      1451→        #endif
                      1452→    }
                      1453→}
                      1454→
                      1455→#endif
