                    struct ChatContentView: View {
                        @ObservedObject var plugin: ChatPlugin

                        var body: some View {
                            if let session = plugin.selectedSession {
                                ChatDetailView(plugin: plugin, session: session)
                            } else {
                                OrchestraEmptyState(
                                    contextMessage: "Start a new chat or select one from the panel.",
                                    actionLabel: "New Chat",
                                    onAction: { plugin.newSession() }
                                )
                            }
                        }
                    }

                    // MARK: - Session Status Bar

                    struct SessionStatusBar: View {
                        let metadata: SessionMetadata

                        var body: some View {
                            HStack(spacing: 12) {
                                if !metadata.model.isEmpty {
                                    metaItem(icon: "cpu", text: metadata.model)
                                }
                                if metadata.tokenCount > 0 {
                                    metaItem(icon: "number", text: "\(metadata.tokenCount) tokens")
                                }
                                if !metadata.duration.isEmpty {
                                    metaItem(icon: "clock", text: metadata.duration)
                                }
                                if !metadata.cost.isEmpty {
                                    metaItem(icon: "dollarsign.circle", text: metadata.cost)
                                }
                                Spacer()
                            }
                            .padding(.horizontal, 16)
                            .padding(.vertical, 5)
                        }

                        private func metaItem(icon: String, text: String) -> some View {
                            HStack(spacing: 4) {
                                Image(systemName: icon)
                                    .font(.system(size: 9, weight: .medium))
                                Text(text)
                                    .font(.system(size: 11))
                            }
                            .foregroundStyle(.secondary)
                            .padding(.horizontal, 7)
                            .padding(.vertical, 3)
                            .background(Color.secondary.opacity(0.10), in: Capsule())
                        }
                    }


                    // MARK: - Detail View

                    struct ChatDetailView: View {
                        @ObservedObject var plugin: ChatPlugin
                        let session: ChatSession
                        @ObservedObject private var inputState = SmartInputState.shared

                        var body: some View {
                            ZStack {
                                VStack(spacing: 0) {
                                    HStack(spacing: 10) {
                                        ZStack {
                                            Circle()
                                                .fill(session.resolvedColor.opacity(0.15))
                                                .frame(width: 28, height: 28)
                                            Image(systemName: session.resolvedIcon)
                                                .font(.system(size: 13))
                                                .foregroundStyle(session.resolvedColor)
                                        }
                                        Text(session.title)
                                            .font(.headline)
                                        Spacer()
                                        Text(session.modelLabel)
                                            .font(.system(size: 11))
                                            .foregroundStyle(.secondary)
                                            .padding(.horizontal, 8)
                                            .padding(.vertical, 3)
                                            .background(Color.secondary.opacity(0.12), in: Capsule())
                                        Text(session.provider)
                                            .font(.caption)
                                            .foregroundStyle(.secondary)
                                            .padding(.horizontal, 8)
                                            .padding(.vertical, 3)
                                            .background(Color.secondary.opacity(0.12), in: Capsule())
                                    }
                                    .padding(.horizontal, 16)
                                    .padding(.vertical, 10)

                                    Divider()

                                    MessageList(session: session, isSending: plugin.isSending, loadingWord: plugin.loadingWord) { messageId, answer in
                                        plugin.sendQuestionAnswer(messageId: messageId, answer: answer)
                                    }

                                    // Permission request banner — shown above input bar
                                    if let permission = plugin.pendingPermission {
                                        PermissionRequestView(request: permission)
                                            .padding(.horizontal, 14)
                                            .padding(.vertical, 6)
                                            .transition(.move(edge: .bottom).combined(with: .opacity))
                                    }

                                    // Docked input bar — only on macOS, only when not detached
                                    #if os(macOS)
                                    if !inputState.isDetached {
                                        DockedInputBar(chatPlugin: plugin, sessionId: session.id)
                                            .environment(\.colorScheme, .dark)
                                            .padding(.horizontal, 14)
                                            .padding(.vertical, 10)
                                            .transition(.move(edge: .bottom).combined(with: .opacity))
                                    }
                                    #endif

                                    // Session metadata status bar
                                    if let metadata = plugin.sessionMetadata, metadata.hasData {
                                        SessionStatusBar(metadata: metadata)
                                    }
                                }

                            }
                            .animation(.spring(response: 0.35, dampingFraction: 0.82), value: inputState.isDetached)
                            .onAppear {
                                SmartInputState.shared.activeChatPlugin = plugin
                            }
                            .onDisappear {
                                SmartInputState.shared.activeChatPlugin = nil
                            }
                        }
                    }


                    // MARK: - Message List

                    struct MessageList: View {
                        let session: ChatSession
                        var isSending: Bool = false
                        var loadingWord: String = "Thinking"
                        var onQuestionAnswer: ((UUID, String) -> Void)? = nil

                        var body: some View {
                            ScrollViewReader { proxy in
                                ScrollView {
                                    LazyVStack(alignment: .leading, spacing: 8) {
                                        ForEach(session.messages) { message in
                                            ChatBubble(message: message, onQuestionAnswer: onQuestionAnswer)
                                                .id(message.id)
                                        }
                                        if isSending {
                                            TypingIndicator(loadingWord: loadingWord)
                                                .id("typing-indicator")
                                        }
                                    }
                                    .padding()
                                }
                                .onChange(of: session.messages.count) { _, _ in
                                    if let last = session.messages.last {
                                        withAnimation(.easeOut(duration: 0.2)) {
                                            proxy.scrollTo(last.id, anchor: .bottom)
                                        }
                                    }
                                }
                                .onChange(of: isSending) { _, sending in
                                    if sending {
                                        withAnimation(.easeOut(duration: 0.2)) {
                                            proxy.scrollTo("typing-indicator", anchor: .bottom)
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // MARK: - Typing Indicator

                    private struct TypingIndicator: View {
                        var loadingWord: String = "Thinking"
                        @State private var dotPhase = 0
                        @State private var pulseScale: CGFloat = 1.0
                        private let timer = Timer.publish(every: 0.5, on: .main, in: .common).autoconnect()

                        private let gradientColors: [Color] = [
                            Color(red: 0.00, green: 0.90, blue: 1.00),
                            Color(red: 0.66, green: 0.00, blue: 1.00),
                        ]

                        var body: some View {
                            HStack(alignment: .bottom, spacing: 0) {
                                HStack(spacing: 4) {
                                    Text(loadingWord + String(repeating: ".", count: dotPhase + 1))
                                        .font(.system(size: 13, weight: .medium))
                                        .foregroundStyle(
                                            LinearGradient(
                                                colors: gradientColors,
                                                startPoint: .leading,
                                                endPoint: .trailing
                                            )
                                        )
                                        .scaleEffect(pulseScale)
                                        .animation(.easeInOut(duration: 1.0).repeatForever(autoreverses: true), value: pulseScale)
                                }
                                .padding(.horizontal, 14)
                                .padding(.vertical, 10)
                                .background(Color.secondary.opacity(0.15))
                                .clipShape(RoundedRectangle(cornerRadius: 16, style: .continuous))
                                Spacer(minLength: 48)
                            }
                            .onReceive(timer) { _ in dotPhase = (dotPhase + 1) % 3 }
                            .onAppear { pulseScale = 1.03 }
                        }
                    }

                    // MARK: - Docked Input Bar (macOS only)
                    // Same visual style as the floating SmartFloatingContent expandedCard:
                    // single-row capsule with glass background, logo, text field, send button.

                    #if os(macOS)
                    struct DockedInputBar: View {
                        let chatPlugin: ChatPlugin?
                        let sessionId: UUID
                        @ObservedObject private var state = SmartInputState.shared

                        var body: some View {
                            InputBarContent(
                                chatPlugin: chatPlugin,
                                sessionId: sessionId,
                                isFloating: false,
                                onDetach: {
                                    withAnimation(.spring(response: 0.32, dampingFraction: 0.8)) {
                                        state.isDetached = true
                                    }
                                    SmartInputWindowManager.shared.openPanel(
                                        chatPlugin: state.activeChatPlugin ?? chatPlugin
                                    )
                                }
                            )
                            .animation(.spring(response: 0.35, dampingFraction: 0.78), value: state.showQuickActions)
                            .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: 18, style: .continuous))
                            .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).fill(Color.white.opacity(0.10)).allowsHitTesting(false))
                            .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).strokeBorder(Color.white.opacity(0.25), lineWidth: 0.75).allowsHitTesting(false))
                            .shadow(color: .black.opacity(0.15), radius: 6, x: 0, y: 3)
                            #if os(macOS)
                            .onDrop(of: [.fileURL], isTargeted: nil) { providers in
                                for provider in providers {
                                    provider.loadItem(forTypeIdentifier: UTType.fileURL.identifier, options: nil) { item, _ in
                                        if let data = item as? Data,
                                           let urlString = String(data: data, encoding: .utf8),
                                           let url = URL(string: urlString) {
                                            Task { @MainActor in
                                                state.attachFile(url)
                                            }
                                        }
                                    }
                                }
                                return true
                            }
                            #endif
                        }
                    }

                    #endif

                    // MARK: - Input Bar

                    struct ChatInputBar: View {
                        @Binding var text: String
                        let isLoading: Bool
                        let onSend: () -> Void

                        private var canSend: Bool {
                            !text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && !isLoading
                        }

                        var body: some View {
                            HStack(alignment: .bottom, spacing: 8) {
                                TextField("Message…", text: $text, axis: .vertical)
                                    .textFieldStyle(.roundedBorder)
                                    .lineLimit(1...6)
                                    .onSubmit { onSend() }

                                if isLoading {
                                    ProgressView()
                                        .controlSize(.small)
                                        .frame(width: 32, height: 32)
                                } else {
                                    Button(action: onSend) {
                                        Image(systemName: "arrow.up.circle.fill")
                                            .font(.title2)
                                            .foregroundStyle(canSend ? Color.accentColor : Color.secondary)
                                    }
                                    .buttonStyle(.plain)
                                    .disabled(!canSend)
                                    .keyboardShortcut(.return, modifiers: [])
                                }
                            }
                            .padding(.horizontal, 12)
                            .padding(.vertical, 10)
                        }
                    }

                    // MARK: - Tool Call Card

                    struct ToolCallCardView: View {
                        let toolCall: ToolCall
                        @State private var isExpanded = false

                        var body: some View {
                            VStack(alignment: .leading, spacing: 0) {
                                // Header row — always visible
                                Button {
                                    withAnimation(.spring(response: 0.28, dampingFraction: 0.8)) {
                                        isExpanded.toggle()
                                    }
                                } label: {
                                    HStack(spacing: 8) {
                                        Image(systemName: isExpanded ? "chevron.down" : "chevron.right")
                                            .font(.system(size: 9, weight: .bold))
                                            .foregroundStyle(.tertiary)
                                            .frame(width: 12)

                                        Image(systemName: toolCall.iconName)
                                            .font(.system(size: 12, weight: .medium))
                                            .foregroundStyle(iconColor)
                                            .frame(width: 18)

                                        Text(toolCall.toolName)
                                            .font(.system(size: 12, weight: .semibold, design: .monospaced))
                                            .foregroundStyle(.primary)

                                        statusBadge

                                        Spacer(minLength: 4)

                                        if !toolCall.arguments.isEmpty && !isExpanded {
                                            Text(toolCall.arguments)
                                                .font(.system(size: 11))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(1)
                                                .truncationMode(.middle)
                                        }
                                    }
                                    .padding(.horizontal, 10)
                                    .padding(.vertical, 7)
                                }
                                .buttonStyle(.plain)

                                // Expanded detail
                                if isExpanded {
                                    Divider().padding(.leading, 38)

                                    VStack(alignment: .leading, spacing: 6) {
                                        if !toolCall.arguments.isEmpty {
                                            Text("Arguments")
                                                .font(.system(size: 10, weight: .semibold))
                                                .foregroundStyle(.tertiary)
                                                .textCase(.uppercase)
                                            Text(toolCall.arguments)
                                                .font(.system(size: 11, design: .monospaced))
                                                .foregroundStyle(.secondary)
                                                .textSelection(.enabled)
                                        }
                                        if !toolCall.result.isEmpty {
                                            Text("Result")
                                                .font(.system(size: 10, weight: .semibold))
                                                .foregroundStyle(.tertiary)
                                                .textCase(.uppercase)
                                            Text(toolCall.result)
                                                .font(.system(size: 11, design: .monospaced))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(20)
                                                .textSelection(.enabled)
                                        }
                                    }
