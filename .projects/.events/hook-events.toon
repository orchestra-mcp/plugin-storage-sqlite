                    private let maxRetryDelay: TimeInterval = 30.0

                    private var savedHost: String = "127.0.0.1"
                    private var savedPort: UInt16 = 50101   // TCP server port
                    private var probeConnection: NWConnection?

                    public init() {}

                    // MARK: - Public API

                    public func connect(to host: String = "127.0.0.1", port: UInt16 = 50101) {
                        self.savedHost = host
                        self.savedPort = port
                        print("[TCPConnection] connect() → \(host):\(port)")
                        startProbe(host: host, port: port)
                    }

                    public func disconnect() {
                        probeConnection?.cancel()
                        probeConnection = nil
                        DispatchQueue.main.async { self.state = .disconnected }
                    }

                    public func sendAndReceive(_ data: Data) async throws -> Data {
                        print("[TCPConnection] sendAndReceive called, state=\(state), data=\(data.count) bytes")
                        // Wait up to 10 seconds for the probe to connect before giving up.
                        if state != .connected {
                            print("[TCPConnection] waiting for probe to connect...")
                            for i in 0..<20 {
                                if state == .connected { break }
                                try? await Task.sleep(nanoseconds: 500_000_000)
                                if i % 4 == 3 { print("[TCPConnection] still waiting... state=\(state) (\(i+1)/20)") }
                            }
                            guard state == .connected else {
                                print("[TCPConnection] TIMEOUT — state=\(state) after 10s")
                                throw TransportError.notConnected
                            }
                        }
                        print("[TCPConnection] connected, calling openAndCall")
                        return try await openAndCall(data: data)
                    }

                    // MARK: - Probe Connection (reachability monitor)

                    private func startProbe(host: String, port: UInt16) {
                        probeConnection?.cancel()

                        let endpoint = NWEndpoint.hostPort(
                            host: NWEndpoint.Host(host),
                            port: NWEndpoint.Port(rawValue: port)!
                        )
                        let conn = NWConnection(to: endpoint, using: .tcp)

                        conn.stateUpdateHandler = { [weak self] newState in
                            guard let self else { return }
                            DispatchQueue.main.async {
                                switch newState {
                                case .ready:
                                    self.state = .connected
                                    self.retryDelay = 1.0
                                    conn.cancel() // probe done — close it
                                case .waiting:
                                    self.state = .reconnecting
                                    self.scheduleRetry(host: host, port: port)
                                case .failed(let err):
                                    self.state = .failed(err)
                                    self.scheduleRetry(host: host, port: port)
                                case .preparing:
                                    self.state = .connecting
                                case .cancelled:
                                    if self.state != .connected {
                                        self.state = .disconnected
                                    }
                                default:
                                    break
                                }
                            }
                        }

                        conn.start(queue: queue)
                        probeConnection = conn
                        DispatchQueue.main.async { self.state = .connecting }
                    }

                    private func scheduleRetry(host: String, port: UInt16) {
                        let delay = retryDelay
                        retryDelay = min(retryDelay * 2, maxRetryDelay)
                        DispatchQueue.main.asyncAfter(deadline: .now() + delay) { [weak self] in
                            guard let self, self.state != .connected else { return }
                            self.startProbe(host: host, port: port)
                        }
                    }

                    // MARK: - Per-Request Connection

                    private func openAndCall(data: Data) async throws -> Data {
                        let endpoint = NWEndpoint.hostPort(
                            host: NWEndpoint.Host(savedHost),
                            port: NWEndpoint.Port(rawValue: savedPort)!
                        )
                        let conn = NWConnection(to: endpoint, using: .tcp)

                        try await withCheckedThrowingContinuation { (cont: CheckedContinuation<Void, Error>) in
                            conn.stateUpdateHandler = { newState in
                                switch newState {
                                case .ready:
                                    cont.resume()
                                case .failed(let err):
                                    cont.resume(throwing: err)
                                case .waiting(let err):
                                    conn.cancel()
                                    cont.resume(throwing: err)
                                default:
                                    break
                                }
                            }
                            conn.start(queue: queue)
                        }

                        defer { conn.cancel() }

                        try await StreamFramer.write(data, to: conn)
                        return try await StreamFramer.read(from: conn)
                    }
                }

                // MARK: - Errors

                enum MTLSConfigError: Error { case setup }

                /// Errors from the transport layer.
                public enum TransportError: Error, LocalizedError {
                    case notConnected
                    case messageTooLarge(UInt32)
                    case invalidFrameLength
                    case receiveError(String)

                    public var errorDescription: String? {
                        switch self {
                        case .notConnected: return "Not connected to orchestrator"
                        case .messageTooLarge(let size): return "Message too large: \(size) bytes"
                        case .invalidFrameLength: return "Invalid frame length"
                        case .receiveError(let msg): return "Receive error: \(msg)"
                        }
                    }
                }
