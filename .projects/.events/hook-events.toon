                              go build -ldflags "${LDFLAGS}" -o dist/orchestra ./libs/cli/
                              go build -o dist/orchestrator ./libs/orchestrator/cmd/
                              go build -o dist/storage-markdown ./libs/plugin-storage-markdown/cmd/
                              go build -o dist/tools-features ./libs/plugin-tools-features/cmd/
