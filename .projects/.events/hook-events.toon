                         1→import SwiftUI
                         2→import UniformTypeIdentifiers
                         3→#if os(macOS)
                         4→import AppKit
                         5→#endif
                         6→#if !XCODE_BUILD
                         7→import OrchestraKit
                         8→#endif
                         9→
                        10→// MARK: - Plugin
                        11→
                        12→/// Chat plugin — wraps an AI conversation UI and session state.
                        13→/// Maps to the Go `bridge.claude` plugin; calls the `ai_prompt` tool
                        14→/// via ToolService which routes through the TCP/Protobuf transport.
                        15→///
                        16→/// Layout contract (macOS 3-column shell):
                        17→///   Column 2 (panel)   ← makePanelView() → ChatSessionListView
                        18→///   Column 3 (content) ← makeView()      → ChatContentView
                        19→@MainActor
                        20→public final class ChatPlugin: ObservableObject, OrchestraPlugin {
                        21→
                        22→    // MARK: OrchestraPlugin identity
                        23→
                        24→    public let id = "chat"
                        25→    public let name = "Chat"
                        26→    public let icon = "bubble.left.and.bubble.right"
                        27→    public let section: AppSection = .sidebar
                        28→    public let order = 1
                        29→    public let supportedPlatforms: Set<Platform> = [.macOS, .iOS, .iPadOS, .watchOS, .tvOS, .visionOS]
                        30→
                        31→    // MARK: State
                        32→
                        33→    @Published public var sessions: [ChatSession] = [] {
                        34→        didSet { persistSessions() }
                        35→    }
                        36→    @Published public var selectedSession: ChatSession? {
                        37→        didSet {
                        38→            selectedSessionId = selectedSession?.id.uuidString ?? ""
                        39→            if let session = selectedSession {
                        40→                let msgs = session.messages.suffix(10).map { "\($0.role.rawValue): \($0.content)" }.joined(separator: "\n")
                        41→                AppContext.shared.update(plugin: "Chat", label: session.title, body: msgs)
                        42→            } else {
                        43→                AppContext.shared.clear()
                        44→            }
                        45→        }
                        46→    }
                        47→    @Published public var isSending: Bool = false {
                        48→        didSet {
                        49→            if isSending {
                        50→                startLoadingWordTimer()
                        51→            } else {
                        52→                stopLoadingWordTimer()
                        53→            }
                        54→        }
