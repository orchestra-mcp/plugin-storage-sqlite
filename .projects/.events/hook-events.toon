                    import SwiftUI
                    import UniformTypeIdentifiers
                    #if os(macOS)
                    import AppKit
                    #endif
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - Plugin

                    /// Chat plugin — wraps an AI conversation UI and session state.
                    /// Maps to the Go `bridge.claude` plugin; calls the `ai_prompt` tool
                    /// via ToolService which routes through the TCP/Protobuf transport.
                    ///
                    /// Layout contract (macOS 3-column shell):
                    ///   Column 2 (panel)   ← makePanelView() → ChatSessionListView
                    ///   Column 3 (content) ← makeView()      → ChatContentView
                    @MainActor
                    public final class ChatPlugin: ObservableObject, OrchestraPlugin {

                        // MARK: OrchestraPlugin identity

                        public let id = "chat"
                        public let name = "Chat"
                        public let icon = "bubble.left.and.bubble.right"
                        public let section: AppSection = .sidebar
                        public let order = 1
                        public let supportedPlatforms: Set<Platform> = [.macOS, .iOS, .iPadOS, .watchOS, .tvOS, .visionOS]

                        // MARK: State

                        @Published public var sessions: [ChatSession] = [] {
                            didSet { persistSessions() }
                        }
                        @Published public var selectedSession: ChatSession? {
                            didSet {
                                selectedSessionId = selectedSession?.id.uuidString ?? ""
                                if let session = selectedSession {
                                    let msgs = session.messages.suffix(10).map { "\($0.role.rawValue): \($0.content)" }.joined(separator: "\n")
                                    AppContext.shared.update(plugin: "Chat", label: session.title, body: msgs)
                                } else {
                                    AppContext.shared.clear()
                                }
                            }
                        }
                        @Published public var isSending: Bool = false {
                            didSet {
                                if isSending {
                                    startLoadingWordTimer()
                                } else {
                                    stopLoadingWordTimer()
                                }
                            }
                        }
                        @Published public var loadingWord: String = "Thinking"
                        @Published public var selectedIds: Set<UUID> = []
                        @Published public var isSelecting: Bool = false
                        @Published public var sessionMetadata: SessionMetadata?
                        @Published public var pendingPermission: PermissionRequest?

                        /// A tool call that requires user approval before execution.
                        public struct PermissionRequest: Identifiable {
                            public let id = UUID()
                            public let toolName: String
                            public let arguments: String
                            public let onAccept: () -> Void
                            public let onAcceptAll: () -> Void
                            public let onReject: () -> Void
                        }

                        // Persists the selected session ID across launches via UserDefaults
                        @AppStorage("chat.selectedSessionId") private var selectedSessionId: String = ""

                        // MARK: Persistence

                        private static var sessionsURL: URL {
                            let appSupport = FileManager.default.urls(for: .applicationSupportDirectory, in: .userDomainMask)[0]
                            let dir = appSupport.appendingPathComponent("Orchestra", isDirectory: true)
                            try? FileManager.default.createDirectory(at: dir, withIntermediateDirectories: true)
                            return dir.appendingPathComponent("chat-sessions.json")
                        }

                        private func persistSessions() {
                            let url = Self.sessionsURL
                            Task.detached(priority: .background) { [sessions] in
                                guard let data = try? JSONEncoder().encode(sessions) else { return }
                                try? data.write(to: url, options: .atomic)
                            }
                        }

                        private static func loadSessions() -> [ChatSession] {
                            guard let data = try? Data(contentsOf: sessionsURL),
                                  let decoded = try? JSONDecoder().decode([ChatSession].self, from: data)
                            else { return [] }
                            return decoded
                        }

                        public init() {
                            let saved = Self.loadSessions()
                            // Bypass didSet on init to avoid a redundant write-back on first load
                            _sessions = Published(initialValue: saved)
                            // Restore the previously selected session; fall back to first
                            let lastId = UserDefaults.standard.string(forKey: "chat.selectedSessionId") ?? ""
                            let restored = saved.first { $0.id.uuidString == lastId } ?? saved.first
                            _selectedSession = Published(initialValue: restored)
                        }

                        // MARK: OrchestraPlugin views

                        public var itemCount: Int { sessions.count }

                        public func makeView() -> AnyView {
                            AnyView(ChatContentView(plugin: self))
                        }

                        public func makePanelView(searchText: String = "") -> AnyView {
                            AnyView(ChatSessionListView(plugin: self, searchText: searchText))
                        }

                        // MARK: OrchestraPlugin lifecycle

                        public func onActivate() {}
                        public func onDeactivate() {}

                        // MARK: Session management

                        public func newSession(title: String = "New Chat", provider: String = "claude") {
                            let session = ChatSession(title: title, provider: provider)
                            // Pinned sessions stay at top; new sessions go after pinned block
                            let insertIdx = sessions.firstIndex { !$0.isPinned } ?? sessions.endIndex
                            sessions.insert(session, at: insertIdx)
                            selectedSession = session
                        }

                        public func deleteSession(_ session: ChatSession) {
                            sessions.removeAll { $0.id == session.id }
                            selectedIds.remove(session.id)
                            if selectedSession?.id == session.id {
                                selectedSession = sessions.first
                            }
                        }

                        public func deleteSelected() {
                            sessions.removeAll { selectedIds.contains($0.id) }
                            if let sel = selectedSession, selectedIds.contains(sel.id) {
                                selectedSession = sessions.first
                            }
                            clearSelection()
                        }

                        public func togglePin(_ session: ChatSession) {
                            guard let idx = sessions.firstIndex(where: { $0.id == session.id }) else { return }
                            sessions[idx].isPinned.toggle()
                            // Re-sort: pinned first, then by date
                            sessions.sort {
                                if $0.isPinned != $1.isPinned { return $0.isPinned }
                                return $0.createdAt > $1.createdAt
                            }
                            // Keep selectedSession in sync
                            if let sel = selectedSession, sel.id == session.id {
                                selectedSession = sessions[sessions.firstIndex { $0.id == session.id }!]
                            }
                        }

                        public func updateSession(_ id: UUID, colorName: String? = nil, iconName: String? = nil, title: String? = nil) {
                            guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                            if let c = colorName  { sessions[idx].colorName = c }
                            if let i = iconName   { sessions[idx].iconName  = i }
                            if let t = title      { sessions[idx].title     = t }
                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        public func toggleSelectMode() {
                            isSelecting.toggle()
                            if !isSelecting { clearSelection() }
                        }

                        public func toggleSelect(_ id: UUID) {
                            if selectedIds.contains(id) { selectedIds.remove(id) }
                            else { selectedIds.insert(id) }
                        }

                        public func clearSelection() {
                            selectedIds.removeAll()
                            isSelecting = false
                        }

                        // MARK: Session model mutation

                        public func updateSessionModel(_ id: UUID, model: String) {
                            guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                            sessions[idx].model = model
                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        public func updateSessionMode(_ id: UUID, mode: String) {
                            guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                            sessions[idx].mode = mode
                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        public func updateSessionThinking(_ id: UUID, enabled: Bool) {
                            guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                            sessions[idx].thinkingEnabled = enabled
                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        // MARK: Messaging

                        public func sendMessage(_ text: String) async {
                            guard var session = selectedSession else { return }

                            let userMsg = ChatMessage(sessionId: session.id, role: .user, content: text)
                            append(userMsg, to: &session)

                            isSending = true
                            defer { isSending = false }

                            do {
                                // Ensure we have a bridge session ID (create on first message)
                                if session.bridgeSessionId == nil {
                                    let bridgeId = try await createBridgeSession(for: session)
                                    session.bridgeSessionId = bridgeId
                                    // Persist the bridge ID
                                    if let idx = sessions.firstIndex(where: { $0.id == session.id }) {
                                        sessions[idx].bridgeSessionId = bridgeId
                                    }
                                    selectedSession = session
                                }

                                guard let bridgeId = session.bridgeSessionId else {
                                    throw ChatError.noBridgeSession
                                }

                                // Prepend thinking instruction when enabled
                                var messageText = text
                                if session.thinkingEnabled {
                                    messageText = "Think step by step before answering.\n\n\(messageText)"
                                }

                                let result = try await ToolService.shared.call(
                                    tool: "send_message",
                                    arguments: ["session_id": bridgeId, "message": messageText]
                                )

                                // Extract metadata from response tail (if present)
                                let (cleanContent, metadata) = Self.extractMetadata(from: result)
                                if metadata.hasData {
                                    sessionMetadata = metadata
                                }

                                // Parse tool calls and user questions from the response content
                                let toolCalls = Self.parseToolCalls(from: cleanContent)
                                let pendingQuestion = Self.parseUserQuestion(from: cleanContent)

                                let assistantMsg = ChatMessage(
                                    sessionId: session.id,
                                    role: .assistant,
                                    content: cleanContent,
                                    toolCalls: toolCalls,
                                    pendingQuestion: pendingQuestion
                                )
                                append(assistantMsg, to: &session)
                            } catch {
                                let errMsg = ChatMessage(
                                    sessionId: session.id, role: .assistant,
                                    content: "Error: \(error.localizedDescription)"
                                )
                                append(errMsg, to: &session)
                            }
                        }

                        // MARK: Bridge session lifecycle

                        private func createBridgeSession(for session: ChatSession) async throws -> String {
                            let result = try await ToolService.shared.call(
                                tool: "create_session",
                                arguments: [
                                    "account_id": "default",
                                    "name": session.title,
                                    "model": session.model,
                                    "permission_mode": session.mode
                                ]
                            )
                            // Parse session ID from response. The response is typically JSON or
                            // plain text containing an ID like "s-XXXXXX".
                            if let id = Self.parseBridgeSessionId(from: result) {
                                return id
                            }
                            throw ChatError.sessionIdNotFound(result)
                        }

                        /// Extract a bridge session ID (format: s-XXXXXX) from JSON or plain text.
                        static func parseBridgeSessionId(from text: String) -> String? {
                            // Try JSON first: look for {"id": "s-...", ...} or {"session_id": "s-..."}
                            if let data = text.data(using: .utf8),
                               let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any] {
                                if let sid = json["id"] as? String, sid.hasPrefix("s-") { return sid }
                                if let sid = json["session_id"] as? String, sid.hasPrefix("s-") { return sid }
                            }
                            // Fallback: regex scan for s- followed by alphanumeric characters
                            let pattern = #"s-[A-Za-z0-9]{4,}"#
                            if let range = text.range(of: pattern, options: .regularExpression) {
                                return String(text[range])
                            }
                            return nil
                        }

                        // MARK: Metadata extraction

                        /// Parses trailing metadata lines from a response and returns (cleanContent, metadata).
                        /// Recognized patterns: Session: ..., Model: ..., Tokens: ..., Duration: ..., Cost: ...
                        static func extractMetadata(from text: String) -> (String, SessionMetadata) {
                            var meta = SessionMetadata()
                            var lines = text.components(separatedBy: "\n")

                            // Scan from the bottom for metadata lines (at most last 10 lines)
                            var metaLineCount = 0
                            let scanLimit = min(10, lines.count)
                            for i in stride(from: lines.count - 1, through: max(0, lines.count - scanLimit), by: -1) {
                                let line = lines[i].trimmingCharacters(in: .whitespaces)
                                if line.isEmpty { metaLineCount += 1; continue }

                                if let val = Self.matchMetaLine(line, prefix: "Model:") {
                                    meta.model = val; metaLineCount += 1
                                } else if let val = Self.matchMetaLine(line, prefix: "Tokens:") {
                                    meta.tokenCount = Int(val.replacingOccurrences(of: ",", with: "")) ?? 0; metaLineCount += 1
                                } else if let val = Self.matchMetaLine(line, prefix: "Duration:") {
                                    meta.duration = val; metaLineCount += 1
                                } else if let val = Self.matchMetaLine(line, prefix: "Cost:") {
                                    meta.cost = val; metaLineCount += 1
                                } else if let val = Self.matchMetaLine(line, prefix: "Session:") {
                                    // Skip session line from displayed content but don't store it
                                    _ = val; metaLineCount += 1
                                } else {
                                    break // Stop scanning when we hit a non-metadata line
                                }
                            }

                            if metaLineCount > 0 && meta.hasData {
                                lines.removeLast(metaLineCount)
                                // Trim trailing empty lines
                                while lines.last?.trimmingCharacters(in: .whitespaces).isEmpty == true {
                                    lines.removeLast()
                                }
                            }

                            return (lines.joined(separator: "\n"), meta)
                        }

                        private static func matchMetaLine(_ line: String, prefix: String) -> String? {
                            guard line.hasPrefix(prefix) else { return nil }
                            return line.dropFirst(prefix.count).trimmingCharacters(in: .whitespaces)
                        }

                        // MARK: AskUserQuestion parsing

                        /// Parses a UserQuestion from assistant response content.
                        /// Recognizes interactive prompt patterns:
                        ///   ? Question text
                        ///     > Option 1
                        ///     Option 2
                        /// Or JSON blocks with question/options structure.
                        static func parseUserQuestion(from text: String) -> UserQuestion? {
                            // Try JSON pattern: {"question": "...", "options": [...]}
                            if let data = text.data(using: .utf8),
                               let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any],
                               let questionText = json["question"] as? String {
                                var opts: [UserQuestion.QuestionOption] = []
                                if let optArr = json["options"] as? [String] {
                                    opts = optArr.map { UserQuestion.QuestionOption(label: $0) }
                                } else if let optArr = json["options"] as? [[String: Any]] {
                                    opts = optArr.compactMap { item in
                                        guard let label = item["label"] as? String else { return nil }
                                        let desc = item["description"] as? String ?? ""
                                        return UserQuestion.QuestionOption(label: label, description: desc)
                                    }
                                }
                                if !opts.isEmpty {
                                    return UserQuestion(question: questionText, options: opts)
                                }
                            }

                            // Try interactive prompt pattern
                            let lines = text.components(separatedBy: "\n")
                            var questionText: String?
                            var options: [UserQuestion.QuestionOption] = []

                            for line in lines {
                                let trimmed = line.trimmingCharacters(in: .whitespaces)
                                // Question line: starts with "?" or contains "AskUserQuestion"
                                if trimmed.hasPrefix("? ") {
                                    questionText = String(trimmed.dropFirst(2)).trimmingCharacters(in: .whitespaces)
                                    continue
                                }
                                // Option lines: start with unicode arrow or bullet
                                if questionText != nil {
                                    let optionPrefixes = ["\u{276F} ", "\u{25B6} ", "- ", "* ", "> "]
                                    for prefix in optionPrefixes {
                                        if trimmed.hasPrefix(prefix) {
                                            let label = String(trimmed.dropFirst(prefix.count)).trimmingCharacters(in: .whitespaces)
                                            if !label.isEmpty {
                                                options.append(UserQuestion.QuestionOption(label: label))
                                            }
                                            break
                                        }
                                    }
                                    // Plain indented option (after question was found)
                                    if options.isEmpty == false || trimmed.isEmpty { continue }
                                    // Check for a line that looks like a plain option (indented text after ?)
                                    if line.hasPrefix("  ") || line.hasPrefix("\t") {
                                        let label = trimmed
                                        if !label.isEmpty && !label.hasPrefix("?") {
                                            options.append(UserQuestion.QuestionOption(label: label))
                                        }
                                    }
                                }
                            }

                            if let question = questionText, !options.isEmpty {
                                return UserQuestion(question: question, options: options)
                            }
                            return nil
                        }

                        // MARK: Tool call parsing

                        /// Parses tool call indicators from assistant response text.
                        static func parseToolCalls(from text: String) -> [ToolCall] {
                            var calls: [ToolCall] = []
                            let lines = text.components(separatedBy: "\n")

                            for line in lines {
                                let trimmed = line.trimmingCharacters(in: .whitespaces)

                                // Pattern: checkmark-prefixed lines like "Read file.swift" or "Edit file.swift"
                                // Also handles Unicode checkmark variants
                                let checkPrefixes = ["\u{2713} ", "\u{2714} ", "\u{2705} "]
                                for prefix in checkPrefixes {
                                    if trimmed.hasPrefix(prefix) {
                                        let rest = String(trimmed.dropFirst(prefix.count))
                                        if let call = Self.parseToolLine(rest, status: .completed) {
                                            calls.append(call)
                                        }
                                    }
                                }

                                // Pattern: "X toolname args" for errors
                                let errorPrefixes = ["\u{2717} ", "\u{2718} ", "\u{274C} "]
                                for prefix in errorPrefixes {
                                    if trimmed.hasPrefix(prefix) {
                                        let rest = String(trimmed.dropFirst(prefix.count))
                                        if let call = Self.parseToolLine(rest, status: .error) {
                                            calls.append(call)
                                        }
                                    }
                                }
                            }

                            return calls
                        }

                        private static func parseToolLine(_ text: String, status: ToolCall.ToolCallStatus) -> ToolCall? {
                            let knownTools = ["Read", "Edit", "Write", "Bash", "Glob", "Grep",
                                              "WebFetch", "WebSearch", "TodoWrite", "AskUserQuestion", "Task"]
                            let parts = text.components(separatedBy: " ")
                            guard let first = parts.first else { return nil }

                            // Check for "Bash: command" pattern
                            let toolName: String
                            let args: String
                            if first.hasSuffix(":") {
                                let candidate = String(first.dropLast())
                                if knownTools.contains(where: { $0.caseInsensitiveCompare(candidate) == .orderedSame }) {
                                    toolName = candidate
                                    args = parts.dropFirst().joined(separator: " ")
                                } else {
                                    return nil
                                }
                            } else if knownTools.contains(where: { $0.caseInsensitiveCompare(first) == .orderedSame }) {
                                toolName = first
                                args = parts.dropFirst().joined(separator: " ")
                            } else {
                                return nil
                            }

                            return ToolCall(
                                toolName: toolName,
                                status: status,
                                arguments: args.trimmingCharacters(in: .whitespaces)
                            )
                        }

                        // MARK: Question answering

                        /// Sends the user's answer to a pending question back via the bridge session.
                        public func sendQuestionAnswer(messageId: UUID, answer: String) {
                            guard var session = selectedSession else { return }

                            // Mark the question as answered in the message
                            if let idx = session.messages.firstIndex(where: { $0.id == messageId }) {
                                session.messages[idx].pendingQuestion?.selectedAnswer = answer
                                if let sessionIdx = sessions.firstIndex(where: { $0.id == session.id }) {
                                    sessions[sessionIdx] = session
                                }
                                selectedSession = session
                            }

                            // Send the answer as a new user message
                            Task { await sendMessage(answer) }
                        }

                        // MARK: Helpers

                        private func append(_ message: ChatMessage, to session: inout ChatSession) {
                            session.messages.append(message)
                            if let idx = sessions.firstIndex(where: { $0.id == session.id }) {
                                sessions[idx] = session
                            }
                            selectedSession = session
                        }

                        enum ChatError: Error, LocalizedError {
                            case noBridgeSession
                            case sessionIdNotFound(String)

                            var errorDescription: String? {
                                switch self {
                                case .noBridgeSession:
                                    return "No bridge session established."
                                case .sessionIdNotFound(let response):
                                    return "Could not parse session ID from response: \(response.prefix(200))"
                                }
                            }
                        }

                        // MARK: - Loading Words

                        public static let loadingWords: [String] = [
                            "Thinking", "Pondering", "Brewing", "Conjuring", "Weaving",
                            "Crafting", "Dreaming", "Exploring", "Imagining", "Composing",
                            "Analyzing", "Processing", "Computing", "Decoding", "Synthesizing"
                        ]

                        private var loadingWordTimer: Timer?
                        private var loadingWordIndex: Int = 0

                        private func startLoadingWordTimer() {
                            loadingWordIndex = 0
                            loadingWord = Self.loadingWords[0]
                            loadingWordTimer = Timer.scheduledTimer(withTimeInterval: 2.0, repeats: true) { [weak self] _ in
                                Task { @MainActor [weak self] in
                                    guard let self = self else { return }
                                    self.loadingWordIndex = (self.loadingWordIndex + 1) % Self.loadingWords.count
                                    self.loadingWord = Self.loadingWords[self.loadingWordIndex]
                                }
                            }
                        }

                        private func stopLoadingWordTimer() {
                            loadingWordTimer?.invalidate()
                            loadingWordTimer = nil
                            loadingWord = "Thinking"
                        }
                    }

                    // MARK: - Color / Icon palette helpers

                    extension ChatSession {
                        static let colorOptions: [(name: String, color: Color)] = [
                            ("",         .accentColor),
                            ("red",      .red),
                            ("orange",   .orange),
                            ("yellow",   .yellow),
                            ("green",    .green),
                            ("teal",     .teal),
                            ("blue",     .blue),
                            ("indigo",   .indigo),
                            ("purple",   .purple),
                            ("pink",     .pink),
                            ("gray",     .gray),
                        ]

                        static let iconOptions: [String] = [
                            "bubble.left", "star", "bolt", "flame", "heart",
                            "brain", "wand.and.stars", "sparkles", "cpu",
                            "doc.text", "terminal", "code", "pencil", "paintbrush",
                        ]

                        var resolvedColor: Color {
                            ChatSession.colorOptions.first { $0.name == colorName }?.color ?? .accentColor
                        }

                        var resolvedIcon: String {
                            iconName.isEmpty ? "bubble.left" : iconName
                        }
                    }

                    // MARK: - Column 2: Session List
                    // searchText is passed from the shared sidebar filter bar (SidebarFilterBar).
                    // The + button in that bar posts .orchestraNewItem which is handled here.

                    struct ChatSessionListView: View {
                        @ObservedObject var plugin: ChatPlugin
                        let searchText: String
                        @State private var editingSession: ChatSession? = nil
                        @State private var renamingSession: ChatSession? = nil
                        @State private var renameText: String = ""
                        @State private var deletingSession: ChatSession? = nil   // single-delete confirmation
                        @State private var confirmDeleteSelected = false          // bulk-delete confirmation
                        @Namespace private var selectionNamespace

                        private var filtered: [ChatSession] {
                            guard !searchText.isEmpty else { return plugin.sessions }
                            let q = searchText.lowercased()
                            return plugin.sessions.filter { $0.title.lowercased().contains(q) }
                        }

                        var body: some View {
                            VStack(spacing: 0) {
                                // ── Select mode header ────────────────────────────────
                                if plugin.isSelecting {
                                    HStack(spacing: 6) {
                                        Button("Cancel") { plugin.clearSelection() }
                                            .buttonStyle(.plain)
                                            .font(.system(size: 12))
                                            .foregroundStyle(.secondary)
                                        Spacer()
                                        if !plugin.selectedIds.isEmpty {
                                            Button(role: .destructive) {
                                                confirmDeleteSelected = true
                                            } label: {
                                                Image(systemName: "trash")
                                                    .font(.system(size: 12))
                                            }
                                            .buttonStyle(.plain)
                                            .foregroundStyle(.red)
                                        }
                                    }
                                    .padding(.horizontal, 12)
                                    .padding(.vertical, 7)
                                    Divider()
                                }

                                // ── List ──────────────────────────────────────────────
                                if plugin.sessions.isEmpty {
                                    Spacer()
                                    VStack(spacing: 8) {
                                        Image(systemName: "bubble.left")
                                            .font(.system(size: 28))
                                            .foregroundStyle(.tertiary)
                                        Text("No chats yet")
                                            .font(.caption)
                                            .foregroundStyle(.secondary)
                                        Button("New Chat") { plugin.newSession() }
                                            .buttonStyle(.bordered)
                                            .controlSize(.small)
                                    }
                                    Spacer()
                                } else if filtered.isEmpty {
                                    Spacer()
                                    VStack(spacing: 6) {
                                        Image(systemName: "magnifyingglass")
                                            .font(.system(size: 24))
                                            .foregroundStyle(.tertiary)
                                        Text("No results")
                                            .font(.caption)
                                            .foregroundStyle(.secondary)
                                    }
                                    Spacer()
                                } else {
                                    ScrollView {
                                        LazyVStack(spacing: 4) {
                                            ForEach(filtered, id: \.id) { session in
                                                let isSelected = plugin.selectedSession?.id == session.id
                                                SessionRow(
                                                    session: session,
                                                    isSelected: isSelected,
                                                    isChecked: plugin.selectedIds.contains(session.id),
                                                    isSelecting: plugin.isSelecting,
                                                    selectionNamespace: selectionNamespace,
                                                    onPin: { plugin.togglePin(session) },
                                                    onDelete: { deletingSession = session },
                                                    onTap: {
                                                        if plugin.isSelecting {
                                                            plugin.toggleSelect(session.id)
                                                        } else {
                                                            withAnimation(.spring(response: 0.32, dampingFraction: 0.78)) {
                                                                plugin.selectedSession = session
                                                            }
                                                            NotificationCenter.default.post(name: .orchestraPluginActivated, object: plugin.id)
                                                        }
                                                    },
                                                    onLongPress: {
                                                        withAnimation(.spring(response: 0.3, dampingFraction: 0.75)) {
                                                            if !plugin.isSelecting { plugin.isSelecting = true }
                                                            plugin.toggleSelect(session.id)
                                                        }
                                                    }
                                                )
                                                .padding(.horizontal, 10)
                                                // ── Context menu ──────────────────────
                                                .contextMenu {
                                                    Button {
                                                        renameText = session.title
                                                        renamingSession = session
                                                    } label: {
                                                        Label("Rename", systemImage: "pencil")
                                                    }

                                                    Button {
                                                        plugin.togglePin(session)
                                                    } label: {
                                                        Label(session.isPinned ? "Unpin" : "Pin",
                                                              systemImage: session.isPinned ? "pin.slash" : "pin")
                                                    }

                                                    Button { editingSession = session } label: {
                                                        Label("Color & Icon", systemImage: "paintpalette")
                                                    }

                                                    Divider()

                                                    Button {
                                                        if !plugin.isSelecting { plugin.isSelecting = true }
                                                        plugin.toggleSelect(session.id)
                                                    } label: {
                                                        Label("Select", systemImage: "checkmark.circle")
                                                    }

                                                    Divider()

                                                    Button(role: .destructive) {
                                                        deletingSession = session
                                                    } label: {
                                                        Label("Delete", systemImage: "trash")
                                                    }
                                                }
                                            }
                                        }
                                        .padding(.top, 12)
                                    }
                                    .scrollIndicators(.never)
                                }
                            }
                            .frame(maxWidth: .infinity, maxHeight: .infinity)
                            // ── Keyboard shortcuts ────────────────────────────────────
                            .onKeyPress(.escape) {
                                if plugin.isSelecting {
                                    plugin.clearSelection()
                                    return .handled
                                }
                                return .ignored
                            }
                            .background {
                                Group {
                                    // CMD+A — select all only when already in selection mode
                                    Button("") {
                                        guard plugin.isSelecting, !filtered.isEmpty else { return }
                                        withAnimation(.spring(response: 0.3, dampingFraction: 0.75)) {
                                            plugin.selectedIds = Set(filtered.map(\.id))
                                        }
                                    }
                                    .keyboardShortcut("a", modifiers: .command)
                                    .opacity(0)
                                    // CMD+F — trigger search
                                    Button("") {
                                        NotificationCenter.default.post(name: .orchestraShowSearch, object: nil)
                                    }
                                    .keyboardShortcut("f", modifiers: .command)
                                    .opacity(0)
                                }
                            }
                            .onKeyPress(.delete) {
                                if plugin.isSelecting && !plugin.selectedIds.isEmpty {
                                    confirmDeleteSelected = true
                                    return .handled
                                }
                                return .ignored
                            }
                            // ── New chat from sidebar + button ────────────────────────
                            .onReceive(NotificationCenter.default.publisher(for: .orchestraNewItem)) { note in
                                if note.object as? String == "chat" || note.object == nil {
                                    plugin.newSession()
                                }
                            }
                            // ── Appearance sheet ──────────────────────────────────────
                            .sheet(item: $editingSession) { session in
                                SessionAppearanceSheet(session: session) { colorName, iconName in
                                    plugin.updateSession(session.id, colorName: colorName, iconName: iconName)
                                }
                            }
                            // ── Rename alert ──────────────────────────────────────────
                            .alert("Rename Chat", isPresented: Binding(
                                get: { renamingSession != nil },
                                set: { if !$0 { renamingSession = nil } }
                            )) {
                                TextField("Chat name", text: $renameText)
                                Button("Rename") {
                                    if let session = renamingSession {
                                        let trimmed = renameText.trimmingCharacters(in: .whitespacesAndNewlines)
                                        if !trimmed.isEmpty {
                                            plugin.updateSession(session.id, title: trimmed)
                                        }
                                    }
                                    renamingSession = nil
                                }
                                .keyboardShortcut(.defaultAction)
                                Button("Cancel", role: .cancel) { renamingSession = nil }
                            } message: {
                                if let session = renamingSession {
                                    Text("Enter a new name for \"\(session.title)\"")
                                }
                            }
                            // ── Single delete confirmation ────────────────────────────
                            .alert("Delete Chat", isPresented: Binding(
                                get: { deletingSession != nil },
                                set: { if !$0 { deletingSession = nil } }
                            )) {
                                Button("Delete", role: .destructive) {
                                    if let session = deletingSession {
                                        plugin.deleteSession(session)
                                    }
                                    deletingSession = nil
                                }
                                Button("Cancel", role: .cancel) { deletingSession = nil }
                            } message: {
                                if let session = deletingSession {
                                    Text("Delete \"\(session.title)\"? This cannot be undone.")
                                }
                            }
                            // ── Bulk delete confirmation ──────────────────────────────
                            .alert("Delete \(plugin.selectedIds.count) Chats", isPresented: $confirmDeleteSelected) {
                                Button("Delete All", role: .destructive) {
                                    plugin.deleteSelected()
                                }
                                Button("Cancel", role: .cancel) {}
                            } message: {
                                Text("This will permanently delete \(plugin.selectedIds.count) chat\(plugin.selectedIds.count == 1 ? "" : "s"). This cannot be undone.")
                            }
                        }
                    }


                    // MARK: - Session Row

                    struct SessionRow: View {
                        let session: ChatSession
                        let isSelected: Bool
                        let isChecked: Bool
                        let isSelecting: Bool
                        var selectionNamespace: Namespace.ID
                        var onPin: (() -> Void)? = nil
                        var onDelete: (() -> Void)? = nil
                        var onTap: (() -> Void)? = nil
                        var onLongPress: (() -> Void)? = nil

                        @State private var isHovered = false
                        @State private var swipeOffset: CGFloat = 0
                        @State private var isSwipingLeft = false   // trailing (delete)
                        @State private var isSwipingRight = false  // leading (pin)

                        // How far to drag before revealing the action button
                        private let revealThreshold: CGFloat = 64
                        // Full-swipe distance to auto-trigger
                        private let fullSwipeThreshold: CGFloat = 160

                        var body: some View {
                            ZStack(alignment: .trailing) {
                                // ── Right action (Delete) ──────────────────────────
                                if isSwipingLeft {
                                    HStack {
                                        Spacer()
                                        Button(action: { onDelete?() }) {
                                            VStack(spacing: 3) {
                                                Image(systemName: "trash.fill")
                                                    .font(.system(size: 14, weight: .semibold))
                                                Text("Delete")
                                                    .font(.system(size: 10, weight: .medium))
                                            }
                                            .foregroundStyle(.white)
                                            .frame(width: max(0, -swipeOffset))
                                            .frame(maxHeight: .infinity)
                                            .background(Color.red.opacity(min(1, (-swipeOffset) / revealThreshold)))
                                            .clipShape(RoundedRectangle(cornerRadius: 13, style: .continuous))
                                        }
                                        .buttonStyle(.plain)
                                    }
                                }

                                // ── Left action (Pin) ──────────────────────────────
                                if isSwipingRight {
                                    HStack {
                                        Button(action: { onPin?() }) {
                                            VStack(spacing: 3) {
                                                Image(systemName: session.isPinned ? "pin.slash.fill" : "pin.fill")
                                                    .font(.system(size: 14, weight: .semibold))
                                                Text(session.isPinned ? "Unpin" : "Pin")
                                                    .font(.system(size: 10, weight: .medium))
                                            }
                                            .foregroundStyle(.white)
                                            .frame(width: max(0, swipeOffset))
                                            .frame(maxHeight: .infinity)
                                            .background(Color.orange.opacity(min(1, swipeOffset / revealThreshold)))
                                            .clipShape(RoundedRectangle(cornerRadius: 13, style: .continuous))
                                        }
                                        .buttonStyle(.plain)
                                        Spacer()
                                    }
                                }

                                // ── Row content ────────────────────────────────────
                                rowContent
                                    .offset(x: swipeOffset)
                                    .gesture(
                                        DragGesture(minimumDistance: 10)
                                            .onChanged { value in
                                                let dx = value.translation.width
                                                // Only allow horizontal drag
                                                guard abs(dx) > abs(value.translation.height) else { return }
                                                withAnimation(.interactiveSpring()) {
                                                    swipeOffset = dx
                                                    isSwipingLeft  = dx < 0
                                                    isSwipingRight = dx > 0
                                                }
                                            }
                                            .onEnded { value in
                                                let dx = value.translation.width
                                                withAnimation(.spring(response: 0.35, dampingFraction: 0.75)) {
                                                    if dx < -fullSwipeThreshold {
                                                        // Full swipe left → immediate delete
                                                        onDelete?()
                                                        swipeOffset = 0
                                                    } else if dx < -revealThreshold {
                                                        // Partial — snap to reveal delete button
                                                        swipeOffset = -revealThreshold
                                                    } else if dx > fullSwipeThreshold {
                                                        // Full swipe right → immediate pin toggle
                                                        onPin?()
                                                        swipeOffset = 0
                                                    } else if dx > revealThreshold {
                                                        // Partial — snap to reveal pin button
                                                        swipeOffset = revealThreshold
                                                    } else {
                                                        swipeOffset = 0
                                                    }
                                                    isSwipingLeft  = swipeOffset < 0
                                                    isSwipingRight = swipeOffset > 0
                                                }
                                            }
                                    )
                            }
                            .clipped()
                            // simultaneousGesture lets tap fire even when DragGesture is attached
                            .simultaneousGesture(
                                TapGesture().onEnded {
                                    if swipeOffset != 0 {
                                        withAnimation(.spring(response: 0.3, dampingFraction: 0.8)) {
                                            swipeOffset = 0
                                            isSwipingLeft  = false
                                            isSwipingRight = false
                                        }
                                    } else {
                                        onTap?()
                                    }
                                }
                            )
                            .simultaneousGesture(
                                LongPressGesture(minimumDuration: 0.4).onEnded { _ in
                                    if swipeOffset == 0 { onLongPress?() }
                                }
                            )
                            .animation(.easeInOut(duration: 0.15), value: isSelected)
                            .onHover { isHovered = $0 }
                        }

                        // ── The actual row HStack ──────────────────────────────────
                        private var rowContent: some View {
                            HStack(spacing: 8) {
                                if isSelecting {
                                    Image(systemName: isChecked ? "checkmark.circle.fill" : "circle")
                                        .font(.system(size: 16))
                                        .foregroundStyle(isChecked ? Color.accentColor : Color.secondary)
                                        .frame(width: 20)
                                } else {
                                    ZStack {
                                        Circle()
                                            .fill(session.resolvedColor.opacity(0.18))
                                            .frame(width: 30, height: 30)
                                        Image(systemName: session.resolvedIcon)
                                            .font(.system(size: 13, weight: .medium))
                                            .foregroundStyle(session.resolvedColor)
                                    }
                                }

                                VStack(alignment: .leading, spacing: 2) {
                                    HStack(spacing: 4) {
                                        if session.isPinned {
                                            Image(systemName: "pin.fill")
                                                .font(.system(size: 9))
                                                .foregroundStyle(.orange)
                                        }
                                        Text(session.title)
                                            .font(.system(size: 13, weight: .medium))
                                            .foregroundStyle(.primary)
                                            .lineLimit(1)
                                    }
                                    Text(session.provider)
                                        .font(.system(size: 11))
                                        .foregroundStyle(.secondary)
                                }

                                Spacer()

                                if !session.messages.isEmpty {
                                    Text("\(session.messages.count)")
                                        .font(.system(size: 10, weight: .medium))
                                        .foregroundStyle(.secondary)
                                        .padding(.horizontal, 5)
                                        .padding(.vertical, 2)
                                        .background(Capsule().fill(Color.secondary.opacity(0.15)))
                                }
                            }
                            .padding(.horizontal, 10)
                            .padding(.vertical, 9)
                            .background {
                                if isSelected {
                                    RoundedRectangle(cornerRadius: 13, style: .continuous)
                                        .fill(.ultraThinMaterial)
                                        .matchedGeometryEffect(id: "session-selection", in: selectionNamespace)
                                        .overlay(
                                            RoundedRectangle(cornerRadius: 13, style: .continuous)
                                                .strokeBorder(
                                                    LinearGradient(
                                                        colors: [Color.white.opacity(0.28), Color.white.opacity(0.06)],
                                                        startPoint: .top, endPoint: .bottom
                                                    ),
                                                    lineWidth: 0.75
                                                )
                                        )
                                        .shadow(color: .black.opacity(0.20), radius: 6, x: 0, y: 3)
                                } else if isHovered {
                                    RoundedRectangle(cornerRadius: 13, style: .continuous)
                                        .fill(Color.white.opacity(0.06))
                                        .overlay(
                                            RoundedRectangle(cornerRadius: 13, style: .continuous)
                                                .strokeBorder(Color.white.opacity(0.08), lineWidth: 0.75)
                                        )
                                }
                            }
                            .animation(.easeInOut(duration: 0.12), value: isHovered)
                        }
                    }

                    // MARK: - Appearance Sheet

                    struct SessionAppearanceSheet: View {
                        let session: ChatSession
                        let onSave: (String, String) -> Void

                        @State private var selectedColor: String
                        @State private var selectedIcon: String
                        @Environment(\.dismiss) private var dismiss

                        init(session: ChatSession, onSave: @escaping (String, String) -> Void) {
                            self.session = session
                            self.onSave = onSave
                            _selectedColor = State(initialValue: session.colorName)
                            _selectedIcon = State(initialValue: session.iconName)
                        }

                        var body: some View {
                            VStack(spacing: 0) {
                                // Title bar
                                HStack {
                                    Text("Chat Appearance")
                                        .font(.headline)
                                    Spacer()
                                    Button("Done") {
                                        onSave(selectedColor, selectedIcon)
                                        dismiss()
                                    }
                                    .buttonStyle(.borderedProminent)
                                    .controlSize(.small)
                                }
                                .padding(16)

                                Divider()

                                ScrollView {
                                    VStack(alignment: .leading, spacing: 20) {
                                        // Preview
                                        HStack(spacing: 10) {
                                            ZStack {
                                                Circle()
                                                    .fill(previewColor.opacity(0.15))
                                                    .frame(width: 44, height: 44)
                                                Image(systemName: previewIcon)
                                                    .font(.system(size: 20))
                                                    .foregroundStyle(previewColor)
                                            }
                                            VStack(alignment: .leading, spacing: 2) {
                                                Text(session.title)
                                                    .font(.system(size: 14, weight: .semibold))
                                                Text(session.provider)
                                                    .font(.caption)
                                                    .foregroundStyle(.secondary)
                                            }
                                            Spacer()
                                        }
                                        .padding(12)
                                        .background(Color.secondary.opacity(0.08), in: RoundedRectangle(cornerRadius: 10))

                                        // Color picker
                                        VStack(alignment: .leading, spacing: 8) {
                                            Text("Color")
                                                .font(.system(size: 12, weight: .semibold))
                                                .foregroundStyle(.secondary)
                                                .textCase(.uppercase)
                                            LazyVGrid(columns: Array(repeating: GridItem(.flexible()), count: 6), spacing: 10) {
                                                ForEach(ChatSession.colorOptions, id: \.name) { option in
                                                    Circle()
                                                        .fill(option.color)
                                                        .frame(width: 32, height: 32)
                                                        .overlay(
                                                            Circle()
                                                                .strokeBorder(
                                                                    selectedColor == option.name ? Color.primary : Color.clear,
                                                                    lineWidth: 2
                                                                )
                                                                .padding(-3)
                                                        )
                                                        .onTapGesture { selectedColor = option.name }
                                                }
                                            }
                                        }

                                        // Icon picker
                                        VStack(alignment: .leading, spacing: 8) {
                                            Text("Icon")
                                                .font(.system(size: 12, weight: .semibold))
                                                .foregroundStyle(.secondary)
                                                .textCase(.uppercase)
                                            LazyVGrid(columns: Array(repeating: GridItem(.flexible()), count: 6), spacing: 10) {
                                                ForEach(ChatSession.iconOptions, id: \.self) { sym in
                                                    ZStack {
                                                        RoundedRectangle(cornerRadius: 8)
                                                            .fill(selectedIcon == sym
                                                                  ? previewColor.opacity(0.2)
                                                                  : Color.secondary.opacity(0.1))
                                                            .frame(width: 40, height: 40)
                                                        Image(systemName: sym)
                                                            .font(.system(size: 16))
                                                            .foregroundStyle(selectedIcon == sym ? previewColor : .secondary)
                                                    }
                                                    .overlay(
                                                        RoundedRectangle(cornerRadius: 8)
                                                            .strokeBorder(
                                                                selectedIcon == sym ? previewColor : Color.clear,
                                                                lineWidth: 1.5
                                                            )
                                                    )
                                                    .onTapGesture {
                                                        selectedIcon = sym == "bubble.left" && session.iconName.isEmpty ? "" : sym
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    .padding(16)
                                }
                            }
                            #if os(macOS)
                            .frame(width: 360, height: 480)
                            #endif
                        }

                        private var previewColor: Color {
                            ChatSession.colorOptions.first { $0.name == selectedColor }?.color ?? .accentColor
                        }

                        private var previewIcon: String {
                            selectedIcon.isEmpty ? "bubble.left" : selectedIcon
                        }
                    }

                    // MARK: - Column 3: Chat Content

                    struct ChatContentView: View {
                        @ObservedObject var plugin: ChatPlugin

                        var body: some View {
                            if let session = plugin.selectedSession {
                                ChatDetailView(plugin: plugin, session: session)
                            } else {
                                OrchestraEmptyState(
                                    contextMessage: "Start a new chat or select one from the panel.",
                                    actionLabel: "New Chat",
                                    onAction: { plugin.newSession() }
                                )
                            }
                        }
                    }

                    // MARK: - Session Status Bar

                    struct SessionStatusBar: View {
                        let metadata: SessionMetadata

                        var body: some View {
                            HStack(spacing: 12) {
                                if !metadata.model.isEmpty {
                                    metaItem(icon: "cpu", text: metadata.model)
                                }
                                if metadata.tokenCount > 0 {
                                    metaItem(icon: "number", text: "\(metadata.tokenCount) tokens")
                                }
                                if !metadata.duration.isEmpty {
                                    metaItem(icon: "clock", text: metadata.duration)
                                }
                                if !metadata.cost.isEmpty {
                                    metaItem(icon: "dollarsign.circle", text: metadata.cost)
                                }
                                Spacer()
                            }
                            .padding(.horizontal, 16)
                            .padding(.vertical, 5)
                        }

                        private func metaItem(icon: String, text: String) -> some View {
                            HStack(spacing: 4) {
                                Image(systemName: icon)
                                    .font(.system(size: 9, weight: .medium))
                                Text(text)
                                    .font(.system(size: 11))
                            }
                            .foregroundStyle(.secondary)
                            .padding(.horizontal, 7)
                            .padding(.vertical, 3)
                            .background(Color.secondary.opacity(0.10), in: Capsule())
                        }
                    }


                    // MARK: - Detail View

                    struct ChatDetailView: View {
                        @ObservedObject var plugin: ChatPlugin
                        let session: ChatSession
                        @ObservedObject private var inputState = SmartInputState.shared

                        var body: some View {
                            ZStack {
                                VStack(spacing: 0) {
                                    HStack(spacing: 10) {
                                        ZStack {
                                            Circle()
                                                .fill(session.resolvedColor.opacity(0.15))
                                                .frame(width: 28, height: 28)
                                            Image(systemName: session.resolvedIcon)
                                                .font(.system(size: 13))
                                                .foregroundStyle(session.resolvedColor)
                                        }
                                        Text(session.title)
                                            .font(.headline)
                                        Spacer()
                                        Text(session.modelLabel)
                                            .font(.system(size: 11))
                                            .foregroundStyle(.secondary)
                                            .padding(.horizontal, 8)
                                            .padding(.vertical, 3)
                                            .background(Color.secondary.opacity(0.12), in: Capsule())
                                        Text(session.provider)
                                            .font(.caption)
                                            .foregroundStyle(.secondary)
                                            .padding(.horizontal, 8)
                                            .padding(.vertical, 3)
                                            .background(Color.secondary.opacity(0.12), in: Capsule())
                                    }
                                    .padding(.horizontal, 16)
                                    .padding(.vertical, 10)

                                    Divider()

                                    MessageList(session: session, isSending: plugin.isSending, loadingWord: plugin.loadingWord) { messageId, answer in
                                        plugin.sendQuestionAnswer(messageId: messageId, answer: answer)
                                    }

                                    // Permission request banner — shown above input bar
                                    if let permission = plugin.pendingPermission {
                                        PermissionRequestView(request: permission)
                                            .padding(.horizontal, 14)
                                            .padding(.vertical, 6)
                                            .transition(.move(edge: .bottom).combined(with: .opacity))
                                    }

                                    // Docked input bar — only on macOS, only when not detached
                                    #if os(macOS)
                                    if !inputState.isDetached {
                                        DockedInputBar(chatPlugin: plugin, sessionId: session.id)
                                            .environment(\.colorScheme, .dark)
                                            .padding(.horizontal, 14)
                                            .padding(.vertical, 10)
                                            .transition(.move(edge: .bottom).combined(with: .opacity))
                                    }
                                    #endif

                                    // Session metadata status bar
                                    if let metadata = plugin.sessionMetadata, metadata.hasData {
                                        SessionStatusBar(metadata: metadata)
                                    }
                                }

                            }
                            .animation(.spring(response: 0.35, dampingFraction: 0.82), value: inputState.isDetached)
                            .onAppear {
                                SmartInputState.shared.activeChatPlugin = plugin
                            }
                            .onDisappear {
                                SmartInputState.shared.activeChatPlugin = nil
                            }
                        }
                    }


                    // MARK: - Message List

                    struct MessageList: View {
                        let session: ChatSession
                        var isSending: Bool = false
                        var loadingWord: String = "Thinking"
                        var onQuestionAnswer: ((UUID, String) -> Void)? = nil

                        var body: some View {
                            ScrollViewReader { proxy in
                                ScrollView {
                                    LazyVStack(alignment: .leading, spacing: 8) {
                                        ForEach(session.messages) { message in
                                            ChatBubble(message: message, onQuestionAnswer: onQuestionAnswer)
                                                .id(message.id)
                                        }
                                        if isSending {
                                            TypingIndicator(loadingWord: loadingWord)
                                                .id("typing-indicator")
                                        }
                                    }
                                    .padding()
                                }
                                .onChange(of: session.messages.count) { _, _ in
                                    if let last = session.messages.last {
                                        withAnimation(.easeOut(duration: 0.2)) {
                                            proxy.scrollTo(last.id, anchor: .bottom)
                                        }
                                    }
                                }
                                .onChange(of: isSending) { _, sending in
                                    if sending {
                                        withAnimation(.easeOut(duration: 0.2)) {
                                            proxy.scrollTo("typing-indicator", anchor: .bottom)
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // MARK: - Typing Indicator

                    private struct TypingIndicator: View {
                        var loadingWord: String = "Thinking"
                        @State private var dotPhase = 0
                        @State private var pulseScale: CGFloat = 1.0
                        private let timer = Timer.publish(every: 0.5, on: .main, in: .common).autoconnect()

                        private let gradientColors: [Color] = [
                            Color(red: 0.00, green: 0.90, blue: 1.00),
                            Color(red: 0.66, green: 0.00, blue: 1.00),
                        ]

                        var body: some View {
                            HStack(alignment: .bottom, spacing: 0) {
                                HStack(spacing: 4) {
                                    Text(loadingWord + String(repeating: ".", count: dotPhase + 1))
                                        .font(.system(size: 13, weight: .medium))
                                        .foregroundStyle(
                                            LinearGradient(
                                                colors: gradientColors,
                                                startPoint: .leading,
                                                endPoint: .trailing
                                            )
                                        )
                                        .scaleEffect(pulseScale)
                                        .animation(.easeInOut(duration: 1.0).repeatForever(autoreverses: true), value: pulseScale)
                                }
                                .padding(.horizontal, 14)
                                .padding(.vertical, 10)
                                .background(Color.secondary.opacity(0.15))
                                .clipShape(RoundedRectangle(cornerRadius: 16, style: .continuous))
                                Spacer(minLength: 48)
                            }
                            .onReceive(timer) { _ in dotPhase = (dotPhase + 1) % 3 }
                            .onAppear { pulseScale = 1.03 }
                        }
                    }

                    // MARK: - Docked Input Bar (macOS only)
                    // Same visual style as the floating SmartFloatingContent expandedCard:
                    // single-row capsule with glass background, logo, text field, send button.

                    #if os(macOS)
                    struct DockedInputBar: View {
                        let chatPlugin: ChatPlugin?
                        let sessionId: UUID
                        @ObservedObject private var state = SmartInputState.shared

                        var body: some View {
                            InputBarContent(
                                chatPlugin: chatPlugin,
                                sessionId: sessionId,
                                isFloating: false,
                                onDetach: {
                                    withAnimation(.spring(response: 0.32, dampingFraction: 0.8)) {
                                        state.isDetached = true
                                    }
                                    SmartInputWindowManager.shared.openPanel(
                                        chatPlugin: state.activeChatPlugin ?? chatPlugin
                                    )
                                }
                            )
                            .animation(.spring(response: 0.35, dampingFraction: 0.78), value: state.showQuickActions)
                            .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: 18, style: .continuous))
                            .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).fill(Color.white.opacity(0.10)).allowsHitTesting(false))
                            .overlay(RoundedRectangle(cornerRadius: 18, style: .continuous).strokeBorder(Color.white.opacity(0.25), lineWidth: 0.75).allowsHitTesting(false))
                            .shadow(color: .black.opacity(0.15), radius: 6, x: 0, y: 3)
                            #if os(macOS)
                            .onDrop(of: [.fileURL], isTargeted: nil) { providers in
                                for provider in providers {
                                    provider.loadItem(forTypeIdentifier: UTType.fileURL.identifier, options: nil) { item, _ in
                                        if let data = item as? Data,
                                           let urlString = String(data: data, encoding: .utf8),
                                           let url = URL(string: urlString) {
                                            Task { @MainActor in
                                                state.attachFile(url)
                                            }
                                        }
                                    }
                                }
                                return true
                            }
                            #endif
                        }
                    }

                    #endif

                    // MARK: - Input Bar

                    struct ChatInputBar: View {
                        @Binding var text: String
                        let isLoading: Bool
                        let onSend: () -> Void

                        private var canSend: Bool {
                            !text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && !isLoading
                        }

                        var body: some View {
                            HStack(alignment: .bottom, spacing: 8) {
                                TextField("Message…", text: $text, axis: .vertical)
                                    .textFieldStyle(.roundedBorder)
                                    .lineLimit(1...6)
                                    .onSubmit { onSend() }

                                if isLoading {
                                    ProgressView()
                                        .controlSize(.small)
                                        .frame(width: 32, height: 32)
                                } else {
                                    Button(action: onSend) {
                                        Image(systemName: "arrow.up.circle.fill")
                                            .font(.title2)
                                            .foregroundStyle(canSend ? Color.accentColor : Color.secondary)
                                    }
                                    .buttonStyle(.plain)
                                    .disabled(!canSend)
                                    .keyboardShortcut(.return, modifiers: [])
                                }
                            }
                            .padding(.horizontal, 12)
                            .padding(.vertical, 10)
                        }
                    }

                    // MARK: - Tool Call Card

                    struct ToolCallCardView: View {
                        let toolCall: ToolCall
                        @State private var isExpanded = false

                        var body: some View {
                            VStack(alignment: .leading, spacing: 0) {
                                // Header row — always visible
                                Button {
                                    withAnimation(.spring(response: 0.28, dampingFraction: 0.8)) {
                                        isExpanded.toggle()
                                    }
                                } label: {
                                    HStack(spacing: 8) {
                                        Image(systemName: isExpanded ? "chevron.down" : "chevron.right")
                                            .font(.system(size: 9, weight: .bold))
                                            .foregroundStyle(.tertiary)
                                            .frame(width: 12)

                                        Image(systemName: toolCall.iconName)
                                            .font(.system(size: 12, weight: .medium))
                                            .foregroundStyle(iconColor)
                                            .frame(width: 18)

                                        Text(toolCall.toolName)
                                            .font(.system(size: 12, weight: .semibold, design: .monospaced))
                                            .foregroundStyle(.primary)

                                        statusBadge

                                        Spacer(minLength: 4)

                                        if !toolCall.arguments.isEmpty && !isExpanded {
                                            Text(toolCall.arguments)
                                                .font(.system(size: 11))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(1)
                                                .truncationMode(.middle)
                                        }
                                    }
                                    .padding(.horizontal, 10)
                                    .padding(.vertical, 7)
                                }
                                .buttonStyle(.plain)

                                // Expanded detail
                                if isExpanded {
                                    Divider().padding(.leading, 38)

                                    VStack(alignment: .leading, spacing: 6) {
                                        if !toolCall.arguments.isEmpty {
                                            Text("Arguments")
                                                .font(.system(size: 10, weight: .semibold))
                                                .foregroundStyle(.tertiary)
                                                .textCase(.uppercase)
                                            Text(toolCall.arguments)
                                                .font(.system(size: 11, design: .monospaced))
                                                .foregroundStyle(.secondary)
                                                .textSelection(.enabled)
                                        }
                                        if !toolCall.result.isEmpty {
                                            Text("Result")
                                                .font(.system(size: 10, weight: .semibold))
                                                .foregroundStyle(.tertiary)
                                                .textCase(.uppercase)
                                            Text(toolCall.result)
                                                .font(.system(size: 11, design: .monospaced))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(20)
                                                .textSelection(.enabled)
                                        }
                                    }
                                    .padding(.horizontal, 10)
                                    .padding(.leading, 28)
                                    .padding(.vertical, 6)
                                }
                            }
                            .background(
                                RoundedRectangle(cornerRadius: 8, style: .continuous)
                                    .fill(Color.secondary.opacity(0.08))
                            )
                            .overlay(
                                RoundedRectangle(cornerRadius: 8, style: .continuous)
                                    .strokeBorder(Color.secondary.opacity(0.12), lineWidth: 0.5)
                            )
                        }

                        private var iconColor: Color {
                            switch toolCall.status {
                            case .completed: return .green
                            case .error:     return .red
                            case .running:   return .orange
                            }
                        }

                        @ViewBuilder
                        private var statusBadge: some View {
                            switch toolCall.status {
                            case .completed:
                                Image(systemName: "checkmark.circle.fill")
                                    .font(.system(size: 11))
                                    .foregroundStyle(.green)
                            case .error:
                                Image(systemName: "xmark.circle.fill")
                                    .font(.system(size: 11))
                                    .foregroundStyle(.red)
                            case .running:
                                ProgressView()
                                    .controlSize(.mini)
                            }
                        }
                    }

                    // MARK: - Permission Request View

                    struct PermissionRequestView: View {
                        let request: ChatPlugin.PermissionRequest

                        var body: some View {
                            VStack(alignment: .leading, spacing: 10) {
                                HStack(spacing: 8) {
                                    Image(systemName: "lock.shield.fill")
                                        .font(.system(size: 14, weight: .medium))
                                        .foregroundStyle(.orange)
                                    Text("Permission Required")
                                        .font(.system(size: 13, weight: .semibold))
                                        .foregroundStyle(.primary)
                                }

                                HStack(spacing: 8) {
                                    Image(systemName: toolIcon(for: request.toolName))
                                        .font(.system(size: 12))
                                        .foregroundStyle(.secondary)
                                        .frame(width: 18)
                                    VStack(alignment: .leading, spacing: 2) {
                                        Text(request.toolName)
                                            .font(.system(size: 12, weight: .semibold, design: .monospaced))
                                        if !request.arguments.isEmpty {
                                            Text(request.arguments)
                                                .font(.system(size: 11, design: .monospaced))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(3)
                                        }
                                    }
                                }
                                .padding(8)
                                .frame(maxWidth: .infinity, alignment: .leading)
                                .background(
                                    RoundedRectangle(cornerRadius: 8, style: .continuous)
                                        .fill(Color.secondary.opacity(0.08))
                                )

                                HStack(spacing: 8) {
                                    Button {
                                        request.onAccept()
                                    } label: {
                                        HStack(spacing: 4) {
                                            Image(systemName: "checkmark")
                                                .font(.system(size: 10, weight: .bold))
                                            Text("Accept")
                                                .font(.system(size: 12, weight: .medium))
                                        }
                                        .padding(.horizontal, 12)
                                        .padding(.vertical, 6)
                                        .background(Color.green.opacity(0.15), in: Capsule())
                                        .foregroundStyle(.green)
                                    }
                                    .buttonStyle(.plain)

                                    Button {
                                        request.onAcceptAll()
                                    } label: {
                                        HStack(spacing: 4) {
                                            Image(systemName: "checkmark.circle")
                                                .font(.system(size: 10, weight: .bold))
                                            Text("Accept All")
                                                .font(.system(size: 12, weight: .medium))
                                        }
                                        .padding(.horizontal, 12)
                                        .padding(.vertical, 6)
                                        .background(Color.blue.opacity(0.15), in: Capsule())
                                        .foregroundStyle(.blue)
                                    }
                                    .buttonStyle(.plain)

                                    Button {
                                        request.onReject()
                                    } label: {
                                        HStack(spacing: 4) {
                                            Image(systemName: "xmark")
                                                .font(.system(size: 10, weight: .bold))
                                            Text("Reject")
                                                .font(.system(size: 12, weight: .medium))
                                        }
                                        .padding(.horizontal, 12)
                                        .padding(.vertical, 6)
                                        .background(Color.red.opacity(0.15), in: Capsule())
                                        .foregroundStyle(.red)
                                    }
                                    .buttonStyle(.plain)

                                    Spacer()
                                }
                            }
                            .padding(12)
                            .background(
                                RoundedRectangle(cornerRadius: 12, style: .continuous)
                                    .fill(Color.orange.opacity(0.06))
                            )
                            .overlay(
                                RoundedRectangle(cornerRadius: 12, style: .continuous)
                                    .strokeBorder(Color.orange.opacity(0.20), lineWidth: 0.75)
                            )
                        }

                        private func toolIcon(for name: String) -> String {
                            switch name.lowercased() {
                            case "read":              return "doc.text"
                            case "edit":              return "pencil"
                            case "write":             return "square.and.pencil"
                            case "bash":              return "terminal"
                            case "glob":              return "folder.badge.gearshape"
                            case "grep":              return "magnifyingglass"
                            case "webfetch":          return "globe"
                            case "websearch":         return "globe.magnifyingglass"
                            case "todowrite":         return "checklist"
                            case "askuserquestion":   return "questionmark.bubble"
                            case "task":              return "person.3"
                            default:                  return "wrench"
                            }
                        }
                    }

                    // MARK: - User Question Card

                    struct UserQuestionCardView: View {
                        let question: UserQuestion
                        let onAnswer: (String) -> Void
                        @State private var customText: String = ""
                        @State private var showCustomField: Bool = false

                        private var isAnswered: Bool { question.selectedAnswer != nil }

                        var body: some View {
                            VStack(alignment: .leading, spacing: 10) {
                                questionHeader
                                optionsList
                                if !isAnswered { customInputSection }
                            }
                            .padding(12)
                            .background(
                                RoundedRectangle(cornerRadius: 12, style: .continuous)
                                    .fill(Color.purple.opacity(0.06))
                            )
                            .overlay(
                                RoundedRectangle(cornerRadius: 12, style: .continuous)
                                    .strokeBorder(Color.purple.opacity(0.15), lineWidth: 0.75)
                            )
                        }

                        private var questionHeader: some View {
                            HStack(spacing: 8) {
                                Image(systemName: "questionmark.bubble.fill")
                                    .font(.system(size: 14, weight: .medium))
                                    .foregroundStyle(.purple)
                                Text(question.question)
                                    .font(.system(size: 13, weight: .semibold))
                                    .foregroundStyle(.primary)
                            }
                        }

                        private var optionsList: some View {
                            VStack(spacing: 6) {
                                ForEach(question.options) { option in
                                    optionButton(for: option)
                                }
                            }
                        }

                        private func optionButton(for option: UserQuestion.QuestionOption) -> some View {
                            let isSelected = question.selectedAnswer == option.label
                            let bgColor: Color = isSelected ? .purple : Color.secondary.opacity(0.10)
                            let borderColor: Color = isSelected ? Color.purple.opacity(0.5) : Color.secondary.opacity(0.15)
                            let rowOpacity: Double = (isAnswered && !isSelected) ? 0.5 : 1.0

                            return Button {
                                if !isAnswered { onAnswer(option.label) }
                            } label: {
                                HStack(spacing: 8) {
                                    Image(systemName: isSelected ? "checkmark.circle.fill" : "circle")
                                        .font(.system(size: 13))
                                        .foregroundStyle(isSelected ? .white : .secondary)
                                    VStack(alignment: .leading, spacing: 1) {
                                        Text(option.label)
                                            .font(.system(size: 12, weight: .medium))
                                            .foregroundStyle(isSelected ? .white : .primary)
                                        if !option.description.isEmpty {
                                            Text(option.description)
                                                .font(.system(size: 10))
                                                .foregroundStyle(isSelected ? Color.white.opacity(0.7) : .secondary)
                                        }
                                    }
                                    Spacer()
                                }
                                .padding(.horizontal, 12)
                                .padding(.vertical, 8)
                                .background(RoundedRectangle(cornerRadius: 10, style: .continuous).fill(bgColor))
                                .overlay(RoundedRectangle(cornerRadius: 10, style: .continuous).strokeBorder(borderColor, lineWidth: 0.75))
                            }
                            .buttonStyle(.plain)
                            .disabled(isAnswered)
                            .opacity(rowOpacity)
                        }

                        @ViewBuilder
                        private var customInputSection: some View {
                            if showCustomField {
                                HStack(spacing: 8) {
                                    TextField("Type your answer...", text: $customText)
                                        .textFieldStyle(.roundedBorder)
                                        .font(.system(size: 12))
                                    Button("Send") {
                                        let answer = customText.trimmingCharacters(in: .whitespacesAndNewlines)
                                        if !answer.isEmpty { onAnswer(answer) }
                                    }
                                    .buttonStyle(.borderedProminent)
                                    .controlSize(.small)
                                    .tint(.purple)
                                    .disabled(customText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
                                }
                            } else {
                                Button {
                                    showCustomField = true
                                } label: {
                                    HStack(spacing: 6) {
                                        Image(systemName: "pencil")
                                            .font(.system(size: 11))
                                        Text("Other...")
                                            .font(.system(size: 12))
                                    }
                                    .foregroundStyle(.secondary)
                                }
                                .buttonStyle(.plain)
                            }
                        }
                    }

                    // MARK: - Chat Bubble

                    struct ChatBubble: View {
                        let message: ChatMessage
                        var onQuestionAnswer: ((UUID, String) -> Void)? = nil
                        private var isUser: Bool { message.role == .user }
                        #if os(macOS)
                        @ObservedObject private var voiceService = VoiceService.shared
                        #endif

                        var body: some View {
                            HStack(alignment: .top, spacing: 0) {
                                if isUser { Spacer(minLength: 48) }
                                VStack(alignment: isUser ? .trailing : .leading, spacing: 0) {
                                    if isUser {
                                        Text(message.content)
                                            .font(.system(size: 13.5))
                                            .padding(.horizontal, 12)
                                            .padding(.vertical, 8)
                                            .background(Color.accentColor)
                                            .foregroundStyle(Color.white)
                                            .clipShape(RoundedRectangle(cornerRadius: 16, style: .continuous))
                                            .textSelection(.enabled)
                                    } else {
                                        VStack(alignment: .leading, spacing: 6) {
                                            // Tool call cards (above the markdown content)
                                            if !message.toolCalls.isEmpty {
                                                VStack(spacing: 4) {
                                                    ForEach(message.toolCalls) { toolCall in
                                                        ToolCallCardView(toolCall: toolCall)
                                                    }
                                                }
                                            }

                                            MarkdownContentView(markdown: message.content)

                                            // AskUserQuestion interactive card
                                            if let question = message.pendingQuestion {
                                                UserQuestionCardView(question: question) { answer in
                                                    onQuestionAnswer?(message.id, answer)
                                                }
                                            }

                                            // TTS speaker button for assistant messages
                                            #if os(macOS)
                                            HStack {
                                                Spacer()
                                                Button {
                                                    if voiceService.isSpeaking {
                                                        voiceService.stopSpeaking()
                                                    } else {
                                                        voiceService.speak(message.content)
                                                    }
                                                } label: {
                                                    Image(systemName: voiceService.isSpeaking ? "stop.circle.fill" : "speaker.wave.2")
                                                        .font(.system(size: 11, weight: .medium))
                                                        .foregroundStyle(.secondary)
                                                        .padding(4)
                                                }
                                                .buttonStyle(.plain)
                                                .help(voiceService.isSpeaking ? "Stop speaking" : "Read aloud")
                                            }
                                            #endif
                                        }
                                        .padding(EdgeInsets(top: 8, leading: 12, bottom: 8, trailing: 12))
                                        .background(Color.secondary.opacity(0.15))
                                        .clipShape(RoundedRectangle(cornerRadius: 16, style: .continuous))
                                        .contextMenu {
                                            Button {
                                                #if os(macOS)
                                                NSPasteboard.general.clearContents()
                                                NSPasteboard.general.setString(message.content, forType: .string)
                                                #else
                                                UIPasteboard.general.string = message.content
                                                #endif
                                            } label: {
                                                Label("Copy Message", systemImage: "doc.on.doc")
                                            }
                                        }
                                    }
                                }
                                if !isUser { Spacer(minLength: 48) }
                            }
                        }
                    }

                    // MARK: - Browser Context Popover

                    #if os(macOS)
                    struct BrowserContextPopover: View {
                        @ObservedObject private var browserService = BrowserContextService.shared

                        var body: some View {
                            VStack(alignment: .leading, spacing: 0) {
                                // Header
                                HStack {
                                    Image(systemName: "globe")
                                        .font(.system(size: 13, weight: .medium))
                                        .foregroundStyle(.cyan)
                                    Text("Browser Context")
                                        .font(.system(size: 13, weight: .semibold))
                                    Spacer()
                                    Toggle("", isOn: $browserService.includeBrowserContext)
                                        .toggleStyle(.switch)
                                        .controlSize(.mini)
                                        .labelsHidden()
                                }
                                .padding(.horizontal, 12)
                                .padding(.vertical, 10)

                                Divider()

                                if browserService.tabs.isEmpty {
                                    VStack(spacing: 8) {
                                        Image(systemName: "globe.badge.chevron.backward")
                                            .font(.system(size: 24))
                                            .foregroundStyle(.tertiary)
                                        Text("No browser tabs detected")
                                            .font(.system(size: 12))
                                            .foregroundStyle(.secondary)
                                        Text("Launch Chrome with --remote-debugging-port=9222")
                                            .font(.system(size: 10))
                                            .foregroundStyle(.tertiary)
                                    }
                                    .frame(maxWidth: .infinity)
                                    .padding(.vertical, 16)
                                } else {
                                    ScrollView {
                                        VStack(spacing: 0) {
                                            ForEach(browserService.tabs) { tab in
                                                HStack(spacing: 8) {
                                                    Image(systemName: "doc.text")
                                                        .font(.system(size: 10))
                                                        .foregroundStyle(.secondary)
                                                        .frame(width: 16)
                                                    VStack(alignment: .leading, spacing: 1) {
                                                        Text(tab.title)
                                                            .font(.system(size: 12, weight: .medium))
                                                            .lineLimit(1)
                                                        Text(tab.url)
                                                            .font(.system(size: 10))
                                                            .foregroundStyle(.tertiary)
                                                            .lineLimit(1)
                                                    }
                                                    Spacer()
                                                }
                                                .padding(.horizontal, 12)
                                                .padding(.vertical, 6)
                                            }
                                        }
                                    }
                                    .frame(maxHeight: 200)
                                }

                                Divider()

                                // Footer with refresh button
                                HStack {
                                    Text(browserService.includeBrowserContext ? "Included in prompts" : "Excluded from prompts")
                                        .font(.system(size: 10))
                                        .foregroundStyle(.tertiary)
                                    Spacer()
                                    Button {
                                        browserService.refreshTabs()
                                    } label: {
                                        Image(systemName: "arrow.clockwise")
                                            .font(.system(size: 11))
                                    }
                                    .buttonStyle(.plain)
                                    .disabled(browserService.isRefreshing)
                                }
                                .padding(.horizontal, 12)
                                .padding(.vertical, 8)
                            }
                            .frame(width: 280)
                        }
                    }
                    #endif

                    // MARK: - Previews

                    #if DEBUG
                    #Preview("Session List") {
                        let plugin = ChatPlugin()
                        plugin.newSession(title: "Swift tips")
                        plugin.newSession(title: "Architecture review")
                        plugin.newSession(title: "Bug fix help")
                        plugin.sessions[0].colorName = "blue"
                        plugin.sessions[0].iconName  = "star"
                        plugin.sessions[1].isPinned  = true
                        return plugin.makePanelView(searchText: "")
                            .frame(width: 260, height: 500)
                    }

                    #Preview("Chat — with messages") {
                        let plugin = ChatPlugin()
