        tool_name: Edit
        tool_response:
            filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Apps/macOS/OrchestraApp.swift
            newString: debugLog("[connectAndFetchTools]
            oldString: print("[connectAndFetchTools]
            originalFile: |
                // macOS App Entry Point — Tray-Only Mode
                // The app runs as a menu bar (tray) icon with a floating bubble/card panel.
                // No dock icon. No main window. Everything flows through SmartInputWindowManager.
                //
                // Required capabilities (Signing & Capabilities):
                //   - App Sandbox: ON
                //   - Network Client: ON (TCP to orchestrator)
                //   - Keychain Access Groups (for mTLS certs)

                import SwiftUI
                #if !XCODE_BUILD
                import OrchestraShared
                #endif

                // MARK: - Shared App State

                /// Shared registry accessible from both AppDelegate and TrayMenuView.
                @MainActor
                let sharedRegistry: PluginRegistry = makeDefaultRegistry()

                @main
                struct OrchestraApp: App {
                    @NSApplicationDelegateAdaptor(AppDelegate.self) private var appDelegate
                    @ObservedObject private var workspaceState = WorkspaceState.shared

                    /// Pre-built 18x18pt template NSImage for the menu bar icon.
                    private static let trayIcon: NSImage = {
                        let size = NSSize(width: 18, height: 18)
                        guard let original = NSImage(named: "OrchestraLogo") else {
                            // Fallback: use an SF Symbol if the asset is missing
                            return NSImage(systemSymbolName: "music.quarternote.3", accessibilityDescription: "Orchestra")!
                        }
                        let resized = NSImage(size: size, flipped: false) { rect in
                            original.draw(in: rect)
                            return true
                        }
                        resized.isTemplate = true
                        return resized
                    }()

                    var body: some Scene {
                        MenuBarExtra {
                            TrayMenuView(workspaceState: workspaceState)
                        } label: {
                            // MenuBarExtra ignores SwiftUI .resizable()/.frame() modifiers.
                            // Use NSImage resized at init time via a helper.
                            Image(nsImage: Self.trayIcon)
                        }
                        .menuBarExtraStyle(.menu)
                    }
                }

                // MARK: - AppDelegate
                // Handles app lifecycle: boots orchestrator, shows floating bubble, registers hotkey.

                @MainActor
                final class AppDelegate: NSObject, NSApplicationDelegate {
                    nonisolated func applicationDidFinishLaunching(_ notification: Notification) {
                        // Prevent multiple instances — kill this one if another is already running.
                        let myPID = ProcessInfo.processInfo.processIdentifier
                        let running = NSRunningApplication.runningApplications(withBundleIdentifier: Bundle.main.bundleIdentifier ?? "")
                        if running.contains(where: { $0.processIdentifier != myPID }) {
                            NSApp.terminate(nil)
                            return
                        }

                        Task { @MainActor in
                            boot()
                        }
                    }

                    nonisolated func applicationWillTerminate(_ notification: Notification) {
                        Task { @MainActor in
                            SmartInputWindowManager.shared.removeGlobalHotkey()
                        }
                    }

                    private func boot() {
                        // Hide dock icon programmatically (backup for LSUIElement in Info.plist)
                        NSApp.setActivationPolicy(.accessory)

                        SmartInputWindowManager.isTrayMode = true

                        // Launch orchestrator
                        OrchestratorLauncher.shared.start()

                        // Set up floating panel with chat plugin
                        let chat = sharedRegistry.plugin(for: "chat") as? ChatPlugin
                        SmartInputWindowManager.shared.setup(chatPlugin: chat)

                        // Show the floating bubble on launch
                        SmartInputWindowManager.shared.showOnLaunch()

                        // Register global Cmd+K hotkey
                        SmartInputWindowManager.shared.registerGlobalHotkey()

                        // Connect to orchestrator, fetch tools, index workspace
                        Task {
                            await WorkspaceState.shared.refresh()
                            await connectAndFetchTools()
                        }

                        // Listen for workspace switches
                        NotificationCenter.default.addObserver(
                            forName: .orchestraWorkspaceSwitch,
                            object: nil,
                            queue: .main
                        ) { note in
                            guard let primaryFolder = note.object as? String else { return }
                            OrchestraClient.shared.disconnect()
                            OrchestratorLauncher.shared.restart(workspace: primaryFolder)
                            Task { @MainActor in
                                try? await Task.sleep(nanoseconds: 1_500_000_000)
                                await connectAndFetchTools()
                            }
                        }

                        // Activate all plugins
                        sharedRegistry.activateAll()
                    }
                }

                // MARK: - TrayMenuView

                struct TrayMenuView: View {
                    @ObservedObject var workspaceState: WorkspaceState

                    var body: some View {
                        // Show / Hide Orchestra
                        Button {
                            SmartInputWindowManager.shared.togglePanel()
                        } label: {
                            Label(
                                SmartInputWindowManager.shared.isPanelVisible ? "Hide Orchestra" : "Show Orchestra",
                                systemImage: SmartInputWindowManager.shared.isPanelVisible ? "eye.slash" : "eye"
                            )
                        }
                        .keyboardShortcut("k", modifiers: .command)

                        Button {
                            NotificationCenter.default.post(name: .orchestraNewChat, object: nil)
                        } label: {
                            Label("New Chat", systemImage: "plus.bubble")
                        }
                        .keyboardShortcut("n", modifiers: [.command, .shift])

                        Divider()

                        // Workspace submenu
                        Menu {
                            ForEach(workspaceState.workspaces) { ws in
                                Button {
                                    Task { await workspaceState.switchWorkspace(ws.id) }
                                } label: {
                                    Label(
                                        ws.id == workspaceState.activeWorkspaceID ? "\(ws.name) (active)" : ws.name,
                                        systemImage: ws.id == workspaceState.activeWorkspaceID ? "checkmark.circle.fill" : "folder"
                                    )
                                }
                            }

                            if !workspaceState.workspaces.isEmpty {
                                Divider()
                            }

                            Button {
                                openFolder()
                            } label: {
                                Label("Open Folder...", systemImage: "folder.badge.plus")
                            }

                            Button {
                                openWorkspace()
                            } label: {
                                Label("Open Workspace...", systemImage: "square.grid.2x2")
                            }
                        } label: {
                            Label("Workspace", systemImage: "folder")
                        }

                        Divider()

                        Button {
                            openSettings()
                        } label: {
                            Label("Settings...", systemImage: "gearshape")
                        }
                        .keyboardShortcut(",", modifiers: .command)

                        Divider()

                        Button {
                            NSApp.terminate(nil)
                        } label: {
                            Label("Quit Orchestra", systemImage: "power")
                        }
                        .keyboardShortcut("q", modifiers: .command)
                    }

                    // MARK: - Actions

                    private func openFolder() {
                        NSApp.activate(ignoringOtherApps: true)
                        let panel = NSOpenPanel()
                        panel.title = "Open Folder"
                        panel.canChooseFiles = false
                        panel.canChooseDirectories = true
                        panel.allowsMultipleSelection = false
                        panel.prompt = "Open"

                        guard panel.runModal() == .OK, let url = panel.url else { return }
                        let folderName = url.lastPathComponent

                        Task {
                            if let ws = await workspaceState.createWorkspace(name: folderName, folders: [url.path]) {
                                await workspaceState.switchWorkspace(ws.id)
                            }
                        }
                    }

                    private func openWorkspace() {
                        NSApp.activate(ignoringOtherApps: true)
                        let panel = NSOpenPanel()
                        panel.title = "Open Workspace"
                        panel.canChooseFiles = false
                        panel.canChooseDirectories = true
                        panel.allowsMultipleSelection = true
                        panel.prompt = "Open"

                        guard panel.runModal() == .OK, !panel.urls.isEmpty else { return }
                        let folders = panel.urls.map(\.path)

                        let alert = NSAlert()
                        alert.messageText = "New Workspace"
                        alert.informativeText = "Enter a name for this workspace:"
                        alert.addButton(withTitle: "Create")
                        alert.addButton(withTitle: "Cancel")

                        let input = NSTextField(frame: NSRect(x: 0, y: 0, width: 260, height: 24))
                        input.stringValue = panel.urls.first?.lastPathComponent ?? "My Workspace"
                        alert.accessoryView = input

                        guard alert.runModal() == .alertFirstButtonReturn else { return }
                        let name = input.stringValue.isEmpty ? "Untitled" : input.stringValue

                        Task {
                            if let ws = await workspaceState.createWorkspace(name: name, folders: folders) {
                                await workspaceState.switchWorkspace(ws.id)
                            }
                        }
                    }

                    private func openSettings() {
                        NSApp.activate(ignoringOtherApps: true)
                        let settingsView = SettingsPlugin().makeView()
                            .frame(minWidth: 680, idealWidth: 780, minHeight: 480, idealHeight: 600)
                        let hosting = NSHostingView(rootView: settingsView)
                        let settingsWindow = NSPanel(
                            contentRect: NSRect(x: 0, y: 0, width: 780, height: 600),
                            styleMask: [.titled, .closable, .resizable],
                            backing: .buffered,
                            defer: false
                        )
                        settingsWindow.title = "Orchestra Settings"
                        settingsWindow.contentView = hosting
                        settingsWindow.center()
                        settingsWindow.makeKeyAndOrderFront(nil)
                    }
                }

                // MARK: - Connect & Fetch Tools

                @MainActor
                private func connectAndFetchTools() async {
                    let host = UserDefaults.standard.string(forKey: "orchestrator_host") ?? "127.0.0.1"
                    let port = UserDefaults.standard.integer(forKey: "orchestrator_port")
                    let resolvedPort = port > 0 ? UInt16(port) : 50101
                    print("[connectAndFetchTools] connecting to \(host):\(resolvedPort)")
                    await OrchestraClient.shared.connect(host: host, port: resolvedPort)

                    // Wait for the probe connection to succeed (up to 15 seconds).
                    // orchestra serve may take a few seconds to start listening.
                    for i in 0..<30 {
                        if OrchestraClient.shared.connectionState == .connected { break }
                        try? await Task.sleep(nanoseconds: 500_000_000) // 0.5s
                        if i % 4 == 3 { print("[connectAndFetchTools] waiting... state=\(OrchestraClient.shared.connectionState) (\(i+1)/30)") }
                    }
                    print("[connectAndFetchTools] final state=\(OrchestraClient.shared.connectionState)")

                    do {
                        let tools = try await OrchestraClient.shared.listTools()
                        print("[connectAndFetchTools] fetched \(tools.count) tools")
                        AppState.shared.setTools(tools)
                        TriggerService.shared.invalidateToolCache()
                    } catch {
                        print("[connectAndFetchTools] FAILED: \(error)")
                    }

                    if let workspace = OrchestratorLauncher.workspacePath {
                        Task.detached {
                            _ = try? await ToolService.shared.call(
                                tool: "index_directory",
                                arguments: ["path": workspace]
                            )
                        }
                    }
                }

                // MARK: - WorkspaceState Helpers

                extension WorkspaceState {
                    /// Convenience: the currently active workspace.
                    public var activeWorkspace: WorkspaceInfo? {
                        guard let id = activeWorkspaceID else { return nil }
                        return workspaces.first { $0.id == id }
                    }
                }

                extension Notification.Name {
                    static let orchestraNewChat = Notification.Name("orchestra.newChat")
                }
            replaceAll: true
