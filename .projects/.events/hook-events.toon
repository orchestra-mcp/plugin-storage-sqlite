                {
                    "name": "${ORG}/plugin-${NAME}",
                    "description": "${NAME} ${TYPE} plugin for Orchestra MCP.",
                    "type": "${TYPE}",
                    "license": "MIT",
                    "homepage": "https://orchestra-mcp.dev",
                    "support": {
                        "issues": "https://github.com/${ORG}/plugin-${NAME}/issues",
