                          - name: Package tarball
                            run: |
                              cd dist
                              tar -czf orchestra-${{ matrix.goos }}-${{ matrix.goarch }}.tar.gz \
                                orchestra orchestrator storage-markdown tools-features transport-stdio

                          - name: Upload artifact
