        tool_name: Read
        tool_response:
            file:
                content: |
                    import Foundation
                    import Network

                    /// Length-delimited Protobuf framing over TCP connections.
                    /// Matches the Go SDK's framing format:
                    ///   [4 bytes big-endian uint32 length][N bytes protobuf payload]
                    public enum StreamFramer {
                        /// Maximum message size: 16 MB (matches Go SDK).
                        public static let maxMessageSize: UInt32 = 16 * 1024 * 1024

                        /// Write a length-delimited message to a TCP connection.
                        public static func write(_ data: Data, to connection: NWConnection) async throws {
                            let length = UInt32(data.count)
                            guard length <= maxMessageSize else {
                                throw TransportError.messageTooLarge(length)
                            }

                            // 4-byte big-endian length header
                            var bigEndianLength = length.bigEndian
                            let header = Data(bytes: &bigEndianLength, count: 4)

                            // Send header + payload
                            let frame = header + data
                            try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<Void, Error>) in
                                connection.send(content: frame, completion: .contentProcessed { error in
                                    if let error {
                                        continuation.resume(throwing: error)
                                    } else {
                                        continuation.resume()
                                    }
                                })
                            }
                        }

                        /// Read a length-delimited message from a TCP connection.
                        public static func read(from connection: NWConnection) async throws -> Data {
                            // Read 4-byte length header
                            let header = try await receive(from: connection, length: 4)
                            let length = header.withUnsafeBytes { $0.load(as: UInt32.self).bigEndian }

                            guard length > 0 else {
                                return Data()
                            }
                            guard length <= maxMessageSize else {
                                throw TransportError.messageTooLarge(length)
                            }

                            // Read payload
                            return try await receive(from: connection, length: Int(length))
                        }

                        /// Receive exactly `length` bytes from a connection.
                        private static func receive(from connection: NWConnection, length: Int) async throws -> Data {
                            try await withCheckedThrowingContinuation { continuation in
                                connection.receive(minimumIncompleteLength: length, maximumLength: length) { data, _, _, error in
                                    if let error {
                                        continuation.resume(throwing: error)
                                    } else if let data, data.count == length {
                                        continuation.resume(returning: data)
                                    } else {
                                        continuation.resume(throwing: TransportError.receiveError(
                                            "Expected \(length) bytes, got \(data?.count ?? 0)"
                                        ))
                                    }
                                }
                            }
                        }
                    }
