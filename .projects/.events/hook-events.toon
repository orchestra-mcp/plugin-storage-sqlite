                      } else {
                        const created = await apiFetch<Project>('/api/projects', {
                          method: 'POST',
                          body: JSON.stringify({ name: newName.trim(), description: newDesc.trim() }),
                        })
                        setProjects(p => [created, ...p])
                      }
