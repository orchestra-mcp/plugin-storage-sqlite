        tool_response:
            file:
                content: |
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    /// A compact dot-and-label indicator showing the current TCP connection state.
                    ///
                    /// Usage:
                    /// ```swift
                    /// ConnectionIndicator(state: transport.connectionState)
                    /// ```
                    public struct ConnectionIndicator: View {

                        private let state: ConnectionState

                        public init(state: ConnectionState) {
                            self.state = state
                        }

                        // MARK: - Helpers

                        private var dotColor: Color {
                            switch state {
                            case .connected:
                                return .green
                            case .connecting, .reconnecting:
                                return .orange
                            case .disconnected, .failed:
                                return .red
                            }
                        }

                        // MARK: - Body

                        public var body: some View {
                            HStack(spacing: 4) {
                                Circle()
                                    .frame(width: 8, height: 8)
                                    .foregroundStyle(dotColor)

                                Text(state.label)
                                    .font(.caption2)
                                    .foregroundStyle(.secondary)
                            }
                        }
                    }

                    // MARK: - Preview

                    #if DEBUG
                    #Preview {
                        VStack(alignment: .leading, spacing: 8) {
                            ConnectionIndicator(state: .connected)
                            ConnectionIndicator(state: .connecting)
                            ConnectionIndicator(state: .reconnecting)
                            ConnectionIndicator(state: .disconnected)
                            ConnectionIndicator(state: .failed(URLError(.notConnectedToInternet)))
                        }
                        .padding()
                    }
                    #endif
                filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/ConnectionIndicator.swift
                numLines: 62
                startLine: 1
                totalLines: 62
            type: text
        tool_use_id: toolu_012j86CTVXS5fRe1ifQPHBx2
        transcript_path: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/4c8aa7b3-279a-4e53-9880-b7605c240237.jsonl
      timestamp: "2026-03-02T10:44:49Z"
    - event_type: PostToolUse
      session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
      tool_name: Read
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: plan
        session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/InputBarContent.swift
            limit: 250
            offset: 1
        tool_name: Read
        tool_response:
            file:
                content: |-
                    #if os(macOS)
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - InputBarContent
                    //
                    // Unified inner content for the macOS input bar, used by both:
                    //   - DockedInputBar (in-window, isFloating = false)
                    //   - SmartFloatingContent expanded card (NSPanel, isFloating = true)
                    //
                    // This component owns the text field, quick actions row, trigger autocomplete,
                    // file attachment chips, voice mode indicator, and send/stop button. It does NOT
                    // own the outer glass card background or panel chrome — callers wrap it.

                    struct InputBarContent: View {
                        let chatPlugin: ChatPlugin?
                        let sessionId: UUID?
                        let isFloating: Bool
                        var onDock: (() -> Void)? = nil
                        var onDetach: (() -> Void)? = nil
                        var onHeightChange: (() -> Void)? = nil

                        @ObservedObject private var state = SmartInputState.shared
                        @FocusState private var inputFocused: Bool
                        @ObservedObject private var voiceService = VoiceService.shared
                        @ObservedObject private var screenshotService = ScreenshotService.shared
                        @ObservedObject private var browserService = BrowserContextService.shared
                        @State private var chevronRotation: Double = 0
                        @State private var voiceModeMessageCount: Int = 0
                        @State private var showSuggestionsPopover = false
                        @State private var showBrowserPopover = false
                        @State private var showScreenshotPopover = false

                        // MARK: - Body

                        var body: some View {
                            contentVStack
                                .onChange(of: state.text) { _, _ in
                                    state.processTextChange()
                                    if let trigger = state.activeTrigger {
                                        Task {
                                            let results = await TriggerService.shared.search(trigger: trigger, query: state.triggerQuery)
                                            state.triggerResults = results
                                        }
                                    }
                                }
                                .onChange(of: inputFocused) { _, focused in
                                    state.isFocused = focused
                                    state.processTextChange()
                                }
                                .background {
                                    // Hidden keyboard shortcuts for trigger navigation and paste
                                    Button("") { navigateTriggerUp() }
                                        .keyboardShortcut(.upArrow, modifiers: [])
                                        .opacity(0)
                                    Button("") { navigateTriggerDown() }
                                        .keyboardShortcut(.downArrow, modifiers: [])
                                        .opacity(0)
                                    Button("") { applySelectedTrigger() }
                                        .keyboardShortcut(.tab, modifiers: [])
                                        .opacity(0)
                                    Button("") { pasteFilesFromPasteboard() }
                                        .keyboardShortcut("v", modifiers: .command)
                                        .opacity(0)
                                }
                                .onAppear {
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) { inputFocused = true }
                                    browserService.startPolling()
                                    setupVoiceCallbacks()
                                }
                                .onReceive(NotificationCenter.default.publisher(for: .orchestraActivateSmartInput)) { _ in
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 0.05) { inputFocused = true }
                                }
                                .onReceive(NotificationCenter.default.publisher(for: .orchestraTriggerAutoSend)) { _ in
                                    sendMessage()
                                }
                                // Auto-speak agent response when voice mode is active.
                                // Uses a stable Timer publisher to poll instead of objectWillChange,
                                // which causes re-render cascades and crashes in the floating panel.
                                .onReceive(Timer.publish(every: 1.0, on: .main, in: .common).autoconnect()) { _ in
                                    guard voiceService.voiceModeActive else { return }
                                    guard let plugin = chatPlugin, !plugin.isSending else { return }
                                    guard let sid = resolvedSessionId,
                                          let session = plugin.sessions.first(where: { $0.id == sid }),
                                          let lastAssistant = session.messages.last(where: { $0.role == .assistant }) else { return }
                                    let msgCount = session.messages.count
                                    if msgCount > voiceModeMessageCount {
                                        voiceModeMessageCount = msgCount
                                        voiceService.speakAgentResponse(lastAssistant.content)
                                    }
                                }
                        }

                        // MARK: - Content Stack

                        private var contentVStack: some View {
                            VStack(spacing: 0) {
                                // File attachment chips
                                if !state.attachedFiles.isEmpty {
                                    fileAttachmentChips
                                }

                                inputRow
                                    .padding(.horizontal, 20)
                                    .padding(.vertical, isFloating ? 14 : 12)

                                if state.showQuickActions {
                                    Divider()
                                        .background(Color.white.opacity(0.08))
                                        .padding(.horizontal, 16)
                                    quickActionsRow
                                }

                                if state.activeTrigger != nil {
                                    InputToolbar()
                                }
                            }
                        }

                        // MARK: - Input Row

                        private var inputRow: some View {
                            HStack(spacing: 10) {
                                Image("OrchestraLogo")
                                    .resizable()
                                    .scaledToFit()
                                    .colorMultiply(.white)
                                    .brightness(1)
                                    .frame(width: isFloating ? 26 : 24, height: isFloating ? 26 : 24)

                                if !SmartInputWindowManager.isTrayMode {
                                    dockDetachButton
                                }

                                // Voice mode: overlay indicator on top of text field using ZStack + opacity.
                                // Avoids swapping the view tree which crashes NSHostingView in floating panel.
                                ZStack {
                                    TextField(
                                        state.isChatMode ? "Message..." : "Ask anything...",
                                        text: $state.text
                                    )
                                    .textFieldStyle(.plain)
                                    .font(.system(size: 15, weight: .regular))
                                    .foregroundStyle(.white)
                                    .focused($inputFocused)
                                    .opacity(voiceService.voiceModeActive ? 0 : 1)
                                    .background {
                                        Button("") {
                                            if state.activeTrigger != nil, state.triggerSelectedIndex < state.triggerResults.count {
                                                let shouldSend = state.applyTriggerResult(state.triggerResults[state.triggerSelectedIndex])
                                                if shouldSend { sendMessage() }
                                            } else {
                                                sendMessage()
                                            }
                                        }
                                        .keyboardShortcut(.return, modifiers: [])
                                        .opacity(0)
                                        Button("") { sendMessage() }
                                            .keyboardShortcut(.return, modifiers: .command)
                                            .opacity(0)
                                        if isFloating {
                                            Button("") {
                                                NotificationCenter.default.post(name: .orchestraCollapseSmartInput, object: nil)
                                                DispatchQueue.main.asyncAfter(deadline: .now() + 0.25) {
                                                    SmartInputWindowManager.shared.collapse()
                                                }
                                            }
                                            .keyboardShortcut(.escape, modifiers: [])
                                            .opacity(0)
                                        }
                                    }

                                    if voiceService.voiceModeActive {
                                        voiceInlineIndicator
                                    }
                                }

                                Spacer(minLength: 0)
                                quickActionToggle
                            }
                        }

                        // MARK: - Voice Inline Indicator

                        private var voiceInlineIndicator: some View {
                            HStack(spacing: 8) {
                                // Animated phase dot
                                Circle()
                                    .fill(voicePhaseColor)
                                    .frame(width: 10, height: 10)
                                    .scaleEffect(voiceService.phase == .listening ? CGFloat(1.0 + Double(voiceService.audioLevel) * 0.5) : 1.0)

                                // Phase label
                                Text(voicePhaseLabelShort)
                                    .font(.system(size: 13, weight: .medium))
                                    .foregroundStyle(.white.opacity(0.6))

                                // Transcribed text (truncated)
                                if voiceService.phase == .listening && !voiceService.transcribedText.isEmpty {
                                    Text(voiceService.transcribedText)
                                        .font(.system(size: 14, weight: .regular))
                                        .foregroundStyle(.white)
                                        .lineLimit(1)
                                        .truncationMode(.tail)
                                }
                            }
                            .frame(maxWidth: .infinity, alignment: .leading)
                        }

                        private var voicePhaseLabelShort: String {
                            switch voiceService.phase {
                            case .idle:       return "Voice"
                            case .listening:  return "Listening..."
                            case .processing: return "Thinking..."
                            case .speaking:   return "Speaking..."
                            }
                        }

                        private var voicePhaseColor: Color {
                            switch voiceService.phase {
                            case .idle, .listening:  return .blue
                            case .processing:        return .purple
                            case .speaking:          return .green
                            }
                        }

                        // MARK: - Send or Stop Button
                        //
                        // Uses ZStack + opacity to keep the view tree stable.
                        // Swapping views via if/else crashes NSHostingView in the floating panel.

                        private var sendOrStopButton: some View {
                            ZStack {
                                // Voice stop button
                                Button {
                                    if voiceService.phase == .speaking {
                                        voiceService.interrupt()
                                    } else {
                                        voiceService.stopVoiceMode()
                                    }
                                } label: {
                                    ZStack {
                                        Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                                        Circle().fill(Color.red.opacity(0.25)).frame(width: 30, height: 30)
                                        Image(systemName: voiceService.phase == .speaking ? "hand.raised.fill" : "stop.fill")
                                            .font(.system(size: 12, weight: .bold))
                                            .foregroundStyle(.red)
                                    }
                filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/InputBarContent.swift
