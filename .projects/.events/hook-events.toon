                                    .font(.system(size: 11, weight: .medium))
                                    .foregroundStyle(isDefault ? .white.opacity(0.35) : .white)
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(isDefault ? 0.0 : 0.07)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        isDefault
                                            ? LinearGradient(colors: [Color.white.opacity(0.12)],
                                                             startPoint: .leading, endPoint: .trailing)
                                            : LinearGradient(colors: [Color.green.opacity(0.40), Color.teal.opacity(0.30)],
                                                             startPoint: .topLeading, endPoint: .bottomTrailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
