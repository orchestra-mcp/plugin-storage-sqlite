      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: plan
        session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/SmartInputBar.swift
            limit: 150
        tool_name: Read
        tool_response:
            file:
                content: |-
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    // MARK: - Notification

                    extension Notification.Name {
                        public static let orchestraActivateSmartInput = Notification.Name("orchestra.activateSmartInput")
                        public static let orchestraCollapseSmartInput = Notification.Name("orchestra.collapseSmartInput")
                        /// Posted when a trigger result (e.g. quick action `!`) should auto-send the message.
                        public static let orchestraTriggerAutoSend    = Notification.Name("orchestra.triggerAutoSend")
                    }

                    // MARK: - Smart Input Bar
                    //
                    // On macOS: returns EmptyView — the floating NSPanel (SmartInputWindowManager) is used instead.
                    // On iOS/iPadOS: renders the full two-row glass card.

                    public struct SmartInputBar: View {
                        let chatPlugin: ChatPlugin?

                        public init(chatPlugin: ChatPlugin? = nil) {
                            self.chatPlugin = chatPlugin
                        }

                        public var body: some View {
                            #if os(macOS)
                            EmptyView()  // macOS uses DockedInputBar (in ChatDetailView) or floating SmartFloatingContent
                            #else
                            SmartInputContent(chatPlugin: chatPlugin)
                            #endif
                        }
                    }

                    // MARK: - SmartInputContent (iOS / non-macOS full implementation)
                    //
                    // Visual system — identical tokens to the nav pill and session rows:
                    //   background : .ultraThinMaterial
                    //   fill tint  : Color.white.opacity(0.10)
                    //   border     : Color.white.opacity(0.12), lineWidth: 0.75  (rest)
                    //              : gradient cyan→purple, lineWidth: 1.2         (focused / loading)
                    //   shadow     : .black.opacity(0.18), radius: 8, y: 4
                    //
                    // Layout (matches Zap-style two-row card):
                    //   ┌─────────────────────────────────────────────────┐
                    //   │  Ask anything… / Message…                       │  row 1 — text field
                    //   ├╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┤  inner divider
                    //   │  [chip] [chip] [chip] …            [icon]  [↑]  │  row 2 — actions
                    //   └─────────────────────────────────────────────────┘
                    //
                    //   cornerRadius: 18  (rounded rect, not capsule)
                    //   Enter = send · Shift+Enter = newline

                    private struct SmartInputContent: View {
                        @ObservedObject private var state   = SmartInputState.shared
                        @ObservedObject private var context = AppContext.shared

                        let chatPlugin: ChatPlugin?

                        @FocusState private var inputFocused: Bool
                        @State private var useContext  = true
                        @State private var hoverDetach = false

                        // Exact same gradient as every other accent in the app
                        private let gradientColors: [Color] = [
                            Color(red: 0.00, green: 0.90, blue: 1.00),  // #00e5ff cyan
                            Color(red: 0.66, green: 0.00, blue: 1.00),  // #a900ff purple
                        ]
                        private let radius: CGFloat = 18

                        // MARK: - Body

                        var body: some View {
                            VStack(spacing: 10) {

                                // Smart response card — floats above bar in non-chat mode
                                if !state.isChatMode, state.showingResponse, let response = state.lastResponse {
                                    SmartResponseCard(
                                        response: response,
                                        gradientColors: gradientColors,
                                        onDismiss: {
                                            withAnimation(.spring(response: 0.35, dampingFraction: 0.8)) {
                                                state.showingResponse = false
                                                state.lastResponse    = nil
                                            }
                                        },
                                        onOpenInChat: { openInChat(response: response) }
                                    )
                                    .transition(.asymmetric(
                                        insertion: .opacity.combined(with: .move(edge: .bottom)),
                                        removal:   .opacity.combined(with: .move(edge: .bottom))
                                    ))
                                }

                                // ── Two-row card ───────────────────────────────────────────
                                VStack(spacing: 0) {

                                    // Row 1 — text field
                                    textFieldRow

                                    // Inner hairline divider (same as Zap screenshot)
                                    Rectangle()
                                        .fill(Color.white.opacity(0.08))
                                        .frame(height: 0.5)
                                        .padding(.horizontal, 14)

                                    // Row 2 — action chips + send
                                    actionsRow
                                }
                                .background {
                                    RoundedRectangle(cornerRadius: radius, style: .continuous)
                                        // ① Base material — identical to nav pill
                                        .fill(.ultraThinMaterial)
                                        // ② Tint fill — identical to NavigatorIcon selected bubble
                                        .overlay(
                                            RoundedRectangle(cornerRadius: radius, style: .continuous)
                                                .fill(Color.white.opacity(0.10))
                                        )
                                        // ③ Plain white border — rest & focused (no colour ever)
                                        .overlay(
                                            RoundedRectangle(cornerRadius: radius, style: .continuous)
                                                .strokeBorder(borderColor, lineWidth: borderWidth)
                                        )
                                        // ④ Gradient border — ONLY while chat is loading, drawn on top
                                        .overlay(
                                            Group {
                                                if state.isChatMode && state.isLoading {
                                                    RoundedRectangle(cornerRadius: radius, style: .continuous)
                                                        .strokeBorder(
                                                            LinearGradient(
                                                                colors: [gradientColors[0].opacity(0.80),
                                                                         gradientColors[1].opacity(0.70)],
                                                                startPoint: .topLeading,
                                                                endPoint: .bottomTrailing),
                                                            lineWidth: 1.3)
                                                        .transition(.opacity)
                                                }
                                            }
                                        )
                                        // ⑤ Shadow — system default weight
                                        .shadow(color: .black.opacity(0.18), radius: 8, x: 0, y: 4)
                                        // ⑥ Ambient glow — only while chat is loading
                                        .shadow(color: loadingGlow, radius: 22, x: 0, y: 0)
                                }
                                .animation(.easeInOut(duration: 0.2),  value: inputFocused)
                                .animation(.easeInOut(duration: 0.45), value: state.isLoading)
                            }
                            .padding(.horizontal, 14)
                            .padding(.bottom, 14)
                filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Components/SmartInputBar.swift
                numLines: 150
                startLine: 1
                totalLines: 525
