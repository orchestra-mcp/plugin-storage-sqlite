                      1457→// MARK: - Input Bar
                      1458→
                      1459→struct ChatInputBar: View {
                      1460→    @Binding var text: String
                      1461→    let isLoading: Bool
                      1462→    let onSend: () -> Void
                      1463→
                      1464→    private var canSend: Bool {
                      1465→        !text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && !isLoading
                      1466→    }
                      1467→
                      1468→    var body: some View {
                      1469→        HStack(alignment: .bottom, spacing: 8) {
                      1470→            TextField("Message…", text: $text, axis: .vertical)
                      1471→                .textFieldStyle(.roundedBorder)
                      1472→                .lineLimit(1...6)
                      1473→                .onSubmit { onSend() }
                      1474→
                      1475→            if isLoading {
                      1476→                ProgressView()
                      1477→                    .controlSize(.small)
                      1478→                    .frame(width: 32, height: 32)
                      1479→            } else {
                      1480→                Button(action: onSend) {
                      1481→                    Image(systemName: "arrow.up.circle.fill")
                      1482→                        .font(.title2)
                      1483→                        .foregroundStyle(canSend ? Color.accentColor : Color.secondary)
                      1484→                }
                      1485→                .buttonStyle(.plain)
                      1486→                .disabled(!canSend)
                      1487→                .keyboardShortcut(.return, modifiers: [])
                      1488→            }
                      1489→        }
                      1490→        .padding(.horizontal, 12)
                      1491→        .padding(.vertical, 10)
                      1492→    }
                      1493→}
                      1494→
                      1495→// MARK: - Tool Call Card
                      1496→
                      1497→struct ToolCallCardView: View {
                      1498→    let toolCall: ToolCall
                      1499→    @State private var isExpanded = false
                      1500→
                      1501→    var body: some View {
                      1502→        VStack(alignment: .leading, spacing: 0) {
                      1503→            // Header row — always visible
                      1504→            Button {
                      1505→                withAnimation(.spring(response: 0.28, dampingFraction: 0.8)) {
                      1506→                    isExpanded.toggle()
                      1507→                }
                      1508→            } label: {
                      1509→                HStack(spacing: 8) {
                      1510→                    Image(systemName: isExpanded ? "chevron.down" : "chevron.right")
                      1511→                        .font(.system(size: 9, weight: .bold))
                      1512→                        .foregroundStyle(.tertiary)
                      1513→                        .frame(width: 12)
                      1514→
                      1515→                    Image(systemName: toolCall.iconName)
                      1516→                        .font(.system(size: 12, weight: .medium))
                      1517→                        .foregroundStyle(iconColor)
                      1518→                        .frame(width: 18)
                      1519→
                      1520→                    Text(toolCall.toolName)
                      1521→                        .font(.system(size: 12, weight: .semibold, design: .monospaced))
                      1522→                        .foregroundStyle(.primary)
                      1523→
                      1524→                    statusBadge
                      1525→
                      1526→                    Spacer(minLength: 4)
                      1527→
                      1528→                    if !toolCall.arguments.isEmpty && !isExpanded {
                      1529→                        Text(toolCall.arguments)
                      1530→                            .font(.system(size: 11))
                      1531→                            .foregroundStyle(.secondary)
                      1532→                            .lineLimit(1)
                      1533→                            .truncationMode(.middle)
                      1534→                    }
                      1535→                }
                      1536→                .padding(.horizontal, 10)
                      1537→                .padding(.vertical, 7)
                      1538→            }
                      1539→            .buttonStyle(.plain)
                      1540→
                      1541→            // Expanded detail
                      1542→            if isExpanded {
                      1543→                Divider().padding(.leading, 38)
                      1544→
                      1545→                VStack(alignment: .leading, spacing: 6) {
                      1546→                    if !toolCall.arguments.isEmpty {
                      1547→                        Text("Arguments")
                      1548→                            .font(.system(size: 10, weight: .semibold))
                      1549→                            .foregroundStyle(.tertiary)
                      1550→                            .textCase(.uppercase)
                      1551→                        Text(toolCall.arguments)
                      1552→                            .font(.system(size: 11, design: .monospaced))
                      1553→                            .foregroundStyle(.secondary)
                      1554→                            .textSelection(.enabled)
                      1555→                    }
                      1556→                    if !toolCall.result.isEmpty {
                      1557→                        Text("Result")
                      1558→                            .font(.system(size: 10, weight: .semibold))
                      1559→                            .foregroundStyle(.tertiary)
                      1560→                            .textCase(.uppercase)
                      1561→                        Text(toolCall.result)
                      1562→                            .font(.system(size: 11, design: .monospaced))
                      1563→                            .foregroundStyle(.secondary)
                      1564→                            .lineLimit(20)
                      1565→                            .textSelection(.enabled)
                      1566→                    }
                      1567→                }
                      1568→                .padding(.horizontal, 10)
                      1569→                .padding(.leading, 28)
                      1570→                .padding(.vertical, 6)
                      1571→            }
                      1572→        }
                      1573→        .background(
                      1574→            RoundedRectangle(cornerRadius: 8, style: .continuous)
                      1575→                .fill(Color.secondary.opacity(0.08))
                      1576→        )
                      1577→        .overlay(
                      1578→            RoundedRectangle(cornerRadius: 8, style: .continuous)
                      1579→                .strokeBorder(Color.secondary.opacity(0.12), lineWidth: 0.5)
                      1580→        )
                      1581→    }
                      1582→
                      1583→    private var iconColor: Color {
                      1584→        switch toolCall.status {
                      1585→        case .completed: return .green
                      1586→        case .error:     return .red
                      1587→        case .running:   return .orange
                      1588→        }
                      1589→    }
                      1590→
                      1591→    @ViewBuilder
                      1592→    private var statusBadge: some View {
                      1593→        switch toolCall.status {
                      1594→        case .completed:
                      1595→            Image(systemName: "checkmark.circle.fill")
                      1596→                .font(.system(size: 11))
                      1597→                .foregroundStyle(.green)
                      1598→        case .error:
                      1599→            Image(systemName: "xmark.circle.fill")
                      1600→                .font(.system(size: 11))
                      1601→                .foregroundStyle(.red)
                      1602→        case .running:
                      1603→            ProgressView()
                      1604→                .controlSize(.mini)
                      1605→        }
                      1606→    }
                      1607→}
                      1608→
                      1609→// MARK: - Permission Request View
                      1610→
                      1611→struct PermissionRequestView: View {
                      1612→    let request: ChatPlugin.PermissionRequest
                      1613→
                      1614→    var body: some View {
                      1615→        VStack(alignment: .leading, spacing: 10) {
                      1616→            HStack(spacing: 8) {
                      1617→                Image(systemName: "lock.shield.fill")
