                python3 -c "
                import json

                # Revert orchestra.json
                with open('orchestra.json') as f:
                    m = json.load(f)
                m['require'].pop('orchestra-mcp/plugin-test-example', None)
                m['extra']['install-order'] = [x for x in m['extra']['install-order'] if x != 'plugin-test-example']
                with open('orchestra.json', 'w') as f:
                    json.dump(m, f, indent=4)
                    f.write('\n')

                # Revert orchestra.lock
                with open('orchestra.lock') as f:
                    lock = json.load(f)
                lock['packages'] = [p for p in lock['packages'] if p['name'] != 'orchestra-mcp/plugin-test-example']
                with open('orchestra.lock', 'w') as f:
                    json.dump(lock, f, indent=4)
                    f.write('\n')
                "

                echo "Cleanup done"
            description: Clean up test plugin and revert files
