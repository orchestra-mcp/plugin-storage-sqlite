        tool_name: Read
        tool_response:
            file:
                content: |
                    import SwiftUI
                    import UniformTypeIdentifiers

                    // MARK: - Attached File

                    public struct AttachedFile: Identifiable {
                        public let id: UUID
                        public let url: URL
                        public var name: String { url.lastPathComponent }

                        public init(id: UUID = UUID(), url: URL) {
                            self.id = id
                            self.url = url
                        }
                    }

                    // MARK: - Trigger Types

                    public enum TriggerKind: Character, CaseIterable {
                        case slash = "/"   // Agent/slash commands
                        case at    = "@"   // File references
                        case hash  = "#"   // Memory search
                        case bang  = "!"   // Quick actions

                        public var icon: String {
                            switch self {
                            case .slash: return "command"
                            case .at:    return "doc.text"
                            case .hash:  return "brain.head.profile"
                            case .bang:  return "bolt.fill"
                            }
                        }

                        public var label: String {
                            switch self {
                            case .slash: return "Commands"
                            case .at:    return "Files"
                            case .hash:  return "Memory"
                            case .bang:  return "Actions"
                            }
                        }
                    }

                    public struct TriggerResult: Identifiable {
                        public let id: String
                        public let title: String
                        public let subtitle: String
                        public let icon: String
                        public let insertText: String

                        public init(id: String, title: String, subtitle: String, icon: String, insertText: String) {
                            self.id = id
                            self.title = title
                            self.subtitle = subtitle
                            self.icon = icon
                            self.insertText = insertText
                        }
                    }

                    public struct SuggestedPrompt: Identifiable {
                        public let id: String
                        public let text: String
                        public let icon: String
                    }

                    // MARK: - SmartInputState

                    @MainActor
                    public final class SmartInputState: ObservableObject {
                        public static let shared = SmartInputState()
                        private init() {
                            _isDetached = Published(initialValue: UserDefaults.standard.bool(forKey: "smartInput.isDetached"))
                            _isToolbarVisible = Published(initialValue: UserDefaults.standard.object(forKey: "smartInput.toolbarVisible") as? Bool ?? true)
                        }

                        @Published public var text: String = ""
                        @Published public var isVisible: Bool = true
                        @Published public var isFocused: Bool = false
                        @Published public var isLoading: Bool = false
                        @Published public var isDetached: Bool = false {
                            didSet { UserDefaults.standard.set(isDetached, forKey: "smartInput.isDetached") }
                        }

                        // Last AI response shown inline (cleared when new message sent)
                        @Published public var lastResponse: String? = nil
                        @Published public var showingResponse: Bool = false

                        // When a ChatDetailView is visible, it registers itself here.
                        // SmartInputBar switches to chat mode and sends messages directly.
                        @Published public var activeChatPlugin: ChatPlugin? = nil

                        /// True when the input bar is acting as the chat input (not smart context input)
                        public var isChatMode: Bool { activeChatPlugin != nil }

                        // MARK: - Trigger / Autocomplete

                        @Published public var activeTrigger: TriggerKind? = nil
                        @Published public var triggerQuery: String = ""
                        @Published public var triggerResults: [TriggerResult] = []
                        @Published public var triggerSelectedIndex: Int = 0

                        // MARK: - Toolbar

                        @Published public var isToolbarVisible: Bool = true {
                            didSet { UserDefaults.standard.set(isToolbarVisible, forKey: "smartInput.toolbarVisible") }
                        }
                        @Published public var useContext: Bool = true
                        @Published public var showSuggestions: Bool = false
                        @Published public var showQuickActions: Bool = false

                        // MARK: - File Attachments

                        @Published public var attachedFiles: [AttachedFile] = []

                        /// Attach a file URL, deduplicating by path.
                        public func attachFile(_ url: URL) {
                            guard !attachedFiles.contains(where: { $0.url.path == url.path }) else { return }
                            attachedFiles.append(AttachedFile(url: url))
                        }

                        /// Remove a single attached file by ID.
                        public func removeFile(_ id: UUID) {
                            attachedFiles.removeAll { $0.id == id }
                        }

                        /// Remove all attached files.
                        public func clearFiles() {
                            attachedFiles.removeAll()
                        }

                        // MARK: - Trigger Detection

                        public func processTextChange() {
                            if let found = findActiveTrigger(in: text) {
                                activeTrigger = found.kind
                                triggerQuery = found.query
                                triggerSelectedIndex = 0
                            } else {
                                clearTrigger()
                            }
                            showSuggestions = text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty && isFocused
                        }

                        public func clearTrigger() {
                            activeTrigger = nil
                            triggerQuery = ""
                            triggerResults = []
                            triggerSelectedIndex = 0
                        }

                        /// Apply a trigger result. Returns `true` if the result should auto-send
                        /// (quick actions `!` and startup prompts auto-send, everything else just inserts).
                        @discardableResult
                        public func applyTriggerResult(_ result: TriggerResult) -> Bool {
                            let shouldSend = activeTrigger == .bang
                            guard let trigger = activeTrigger else { return false }
                            let search = String(trigger.rawValue) + triggerQuery
                            if let range = text.range(of: search, options: .backwards) {
                                text.replaceSubrange(range, with: result.insertText + " ")
                            }
                            clearTrigger()
                            return shouldSend
                        }

                        private func findActiveTrigger(in text: String) -> (kind: TriggerKind, query: String)? {
                            guard !text.isEmpty else { return nil }
                            for kind in TriggerKind.allCases {
                                let char = String(kind.rawValue)
                                if let range = text.range(of: char, options: .backwards) {
                                    let afterTrigger = text[range.upperBound...]
                                    if !afterTrigger.contains(" ") {
                                        let beforeTrigger = text[..<range.lowerBound]
                                        if beforeTrigger.isEmpty || beforeTrigger.last?.isWhitespace == true {
                                            return (kind, String(afterTrigger))
                                        }
                                    }
                                }
                            }
                            return nil
                        }
                    }
                filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Services/SmartInputState.swift
                numLines: 182
                startLine: 1
                totalLines: 182
