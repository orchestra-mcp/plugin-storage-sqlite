        tool_response:
            file:
                content: |
                    name: CI

                    on:
                      push:
                        branches: [master, main]
                      pull_request:
                        branches: [master, main]

                    jobs:
                      test:
                        runs-on: ubuntu-latest
                        steps:
                          - uses: actions/checkout@v4
                          - uses: actions/setup-go@v5
                            with:
                              go-version: '1.23'

                          - name: Clone libs
                            run: |
                              org=$(python3 -c "import json; print(json.load(open('libs.json'))['org'])")
                              for name in $(python3 -c "import json; [print(l['name']) for l in json.load(open('libs.json'))['libs']]"); do
                                git clone --depth 1 --branch master "https://github.com/${org}/${name}.git" "libs/${name}"
                              done

                          - name: Build all binaries
                            run: make build

                          - name: Run unit tests
                            run: make test-unit

                          - name: Run E2E tests
                            run: make test-e2e

                      lint:
                        runs-on: ubuntu-latest
                        steps:
                          - uses: actions/checkout@v4
                          - uses: actions/setup-go@v5
                            with:
                              go-version: '1.23'

                          - name: Clone libs
                            run: |
                              org=$(python3 -c "import json; print(json.load(open('libs.json'))['org'])")
                              for name in $(python3 -c "import json; [print(l['name']) for l in json.load(open('libs.json'))['libs']]"); do
                                git clone --depth 1 --branch master "https://github.com/${org}/${name}.git" "libs/${name}"
                              done

                          - name: Vet
                            run: |
                              for path in $(python3 -c "import json; [print(l['path']) for l in json.load(open('libs.json'))['libs'] if l['type'] != 'proto']"); do
                                echo "go vet ./${path}/..."
                                go vet "./${path}/..."
                              done
                filePath: /Users/fadymondy/Sites/orchestra-agents/.github/workflows/ci.yml
                numLines: 55
                startLine: 1
                totalLines: 55
            type: text
