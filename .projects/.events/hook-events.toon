    - event_type: PostToolUse
      session_id: 42e039ef-ffda-42b3-aff0-9f3b4aec2a0e
      tool_name: Write
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: acceptEdits
        session_id: 42e039ef-ffda-42b3-aff0-9f3b4aec2a0e
        tool_input:
            content: |
                name: CI

                on:
                  push:
                    branches: [master, main]
                  pull_request:
                    branches: [master, main]

                jobs:
                  test:
                    runs-on: ubuntu-latest
                    steps:
                      - uses: actions/checkout@v4
                      - uses: actions/setup-go@v5
                        with:
                          go-version: '1.23'

                      - name: Install dependencies
                        run: |
                          python3 -c "
                          import json
                          lock = json.load(open('orchestra.lock'))
                          for pkg in lock['packages']:
                              url = pkg['source']['url']
                              path = pkg['path']
                              version = pkg['version']
                              print(f'git clone --depth 1 --branch {version} {url} {path}')
                          " | sh

                      - name: Build all binaries
                        run: make build

                      - name: Run unit tests
                        run: make test-unit

                      - name: Run E2E tests
                        run: make test-e2e

                  lint:
                    runs-on: ubuntu-latest
                    steps:
                      - uses: actions/checkout@v4
                      - uses: actions/setup-go@v5
                        with:
                          go-version: '1.23'

                      - name: Install dependencies
                        run: |
                          python3 -c "
                          import json
                          lock = json.load(open('orchestra.lock'))
                          for pkg in lock['packages']:
                              url = pkg['source']['url']
                              path = pkg['path']
                              version = pkg['version']
                              print(f'git clone --depth 1 --branch {version} {url} {path}')
                          " | sh

