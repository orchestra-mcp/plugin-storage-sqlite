                    // MARK: - Animated Loading Dots

                    private struct InputBarLoadingDots: View {
                        @State private var phase = 0
                        private let timer = Timer.publish(every: 0.38, on: .main, in: .common).autoconnect()
                        private let gradientColors: [Color] = [
                            Color(red: 0.00, green: 0.90, blue: 1.00),
                            Color(red: 0.66, green: 0.00, blue: 1.00),
                        ]

                        var body: some View {
                            HStack(spacing: 5) {
                                ForEach(0..<3, id: \.self) { i in
                                    Circle()
                                        .fill(LinearGradient(
                                            colors: gradientColors,
                                            startPoint: .topLeading,
                                            endPoint: .bottomTrailing))
                                        .frame(width: 6, height: 6)
                                        .opacity(phase == i ? 1.0 : 0.25)
                                        .scaleEffect(phase == i ? 1.3 : 0.85)
                                        .animation(.easeInOut(duration: 0.3), value: phase)
                                }
                            }
                            .onReceive(timer) { _ in phase = (phase + 1) % 3 }
                        }
                    }

                    #endif
