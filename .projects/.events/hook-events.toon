                       209→    // MARK: Messaging
                       210→
                       211→    public func sendMessage(_ text: String) async {
                       212→        guard var session = selectedSession else { return }
                       213→
                       214→        let userMsg = ChatMessage(sessionId: session.id, role: .user, content: text)
                       215→        append(userMsg, to: &session)
                       216→
                       217→        isSending = true
                       218→        defer { isSending = false }
                       219→
                       220→        do {
                       221→            // Ensure we have a bridge session ID (create on first message)
                       222→            if session.bridgeSessionId == nil {
                       223→                let bridgeId = try await createBridgeSession(for: session)
                       224→                session.bridgeSessionId = bridgeId
                       225→                // Persist the bridge ID
                       226→                if let idx = sessions.firstIndex(where: { $0.id == session.id }) {
                       227→                    sessions[idx].bridgeSessionId = bridgeId
                       228→                }
                       229→                selectedSession = session
                       230→            }
                       231→
                       232→            guard let bridgeId = session.bridgeSessionId else {
                       233→                throw ChatError.noBridgeSession
                       234→            }
                       235→
                       236→            // Prepend thinking instruction when enabled
                       237→            var messageText = text
                       238→            if session.thinkingEnabled {
                       239→                messageText = "Think step by step before answering.\n\n\(messageText)"
                       240→            }
                       241→
                       242→            let result = try await ToolService.shared.call(
                       243→                tool: "send_message",
                       244→                arguments: ["session_id": bridgeId, "message": messageText]
                       245→            )
                       246→
                       247→            // Extract metadata from response tail (if present)
                       248→            let (cleanContent, metadata) = Self.extractMetadata(from: result)
                       249→            if metadata.hasData {
                       250→                sessionMetadata = metadata
                       251→            }
                       252→
                       253→            // Parse tool calls and user questions from the response content
                       254→            let toolCalls = Self.parseToolCalls(from: cleanContent)
                       255→            let pendingQuestion = Self.parseUserQuestion(from: cleanContent)
                       256→
                       257→            let assistantMsg = ChatMessage(
                       258→                sessionId: session.id,
                       259→                role: .assistant,
                       260→                content: cleanContent,
                       261→                toolCalls: toolCalls,
                       262→                pendingQuestion: pendingQuestion
                       263→            )
                       264→            append(assistantMsg, to: &session)
                       265→        } catch {
                       266→            let errMsg = ChatMessage(
                       267→                sessionId: session.id, role: .assistant,
                       268→                content: "Error: \(error.localizedDescription)"
                       269→            )
                       270→            append(errMsg, to: &session)
                       271→        }
                       272→    }
                       273→
                       274→    // MARK: Bridge session lifecycle
                       275→
                       276→    private func createBridgeSession(for session: ChatSession) async throws -> String {
                       277→        let result = try await ToolService.shared.call(
                       278→            tool: "create_session",
                       279→            arguments: [
                       280→                "account_id": "default",
                       281→                "name": session.title,
                       282→                "model": session.model,
                       283→                "permission_mode": session.mode
                       284→            ]
                       285→        )
                       286→        // Parse session ID from response. The response is typically JSON or
                       287→        // plain text containing an ID like "s-XXXXXX".
                       288→        if let id = Self.parseBridgeSessionId(from: result) {
                       289→            return id
                       290→        }
                       291→        throw ChatError.sessionIdNotFound(result)
                       292→    }
                       293→
                       294→    /// Extract a bridge session ID (format: s-XXXXXX) from JSON or plain text.
                       295→    static func parseBridgeSessionId(from text: String) -> String? {
                       296→        // Try JSON first: look for {"id": "s-...", ...} or {"session_id": "s-..."}
                       297→        if let data = text.data(using: .utf8),
                       298→           let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any] {
                       299→            if let sid = json["id"] as? String, sid.hasPrefix("s-") { return sid }
                       300→            if let sid = json["session_id"] as? String, sid.hasPrefix("s-") { return sid }
                       301→        }
                       302→        // Fallback: regex scan for s- followed by alphanumeric characters
                       303→        let pattern = #"s-[A-Za-z0-9]{4,}"#
                       304→        if let range = text.range(of: pattern, options: .regularExpression) {
                       305→            return String(text[range])
                       306→        }
                       307→        return nil
                       308→    }
                       309→
                       310→    // MARK: Metadata extraction
                       311→
                       312→    /// Parses trailing metadata lines from a response and returns (cleanContent, metadata).
                       313→    /// Recognized patterns: Session: ..., Model: ..., Tokens: ..., Duration: ..., Cost: ...
                       314→    static func extractMetadata(from text: String) -> (String, SessionMetadata) {
                       315→        var meta = SessionMetadata()
                       316→        var lines = text.components(separatedBy: "\n")
                       317→
                       318→        // Scan from the bottom for metadata lines (at most last 10 lines)
                       319→        var metaLineCount = 0
                       320→        let scanLimit = min(10, lines.count)
                       321→        for i in stride(from: lines.count - 1, through: max(0, lines.count - scanLimit), by: -1) {
                       322→            let line = lines[i].trimmingCharacters(in: .whitespaces)
                       323→            if line.isEmpty { metaLineCount += 1; continue }
                       324→
                       325→            if let val = Self.matchMetaLine(line, prefix: "Model:") {
                       326→                meta.model = val; metaLineCount += 1
                       327→            } else if let val = Self.matchMetaLine(line, prefix: "Tokens:") {
                       328→                meta.tokenCount = Int(val.replacingOccurrences(of: ",", with: "")) ?? 0; metaLineCount += 1
                       329→            } else if let val = Self.matchMetaLine(line, prefix: "Duration:") {
                       330→                meta.duration = val; metaLineCount += 1
                       331→            } else if let val = Self.matchMetaLine(line, prefix: "Cost:") {
                       332→                meta.cost = val; metaLineCount += 1
                       333→            } else if let val = Self.matchMetaLine(line, prefix: "Session:") {
                       334→                // Skip session line from displayed content but don't store it
                       335→                _ = val; metaLineCount += 1
                       336→            } else {
                       337→                break // Stop scanning when we hit a non-metadata line
                       338→            }
                       339→        }
                       340→
                       341→        if metaLineCount > 0 && meta.hasData {
                       342→            lines.removeLast(metaLineCount)
                       343→            // Trim trailing empty lines
                       344→            while lines.last?.trimmingCharacters(in: .whitespaces).isEmpty == true {
                       345→                lines.removeLast()
                       346→            }
                       347→        }
                       348→
                       349→        return (lines.joined(separator: "\n"), meta)
                       350→    }
                       351→
                       352→    private static func matchMetaLine(_ line: String, prefix: String) -> String? {
                       353→        guard line.hasPrefix(prefix) else { return nil }
                       354→        return line.dropFirst(prefix.count).trimmingCharacters(in: .whitespaces)
                       355→    }
                       356→
                       357→    // MARK: AskUserQuestion parsing
                       358→
                       359→    /// Parses a UserQuestion from assistant response content.
                       360→    /// Recognizes interactive prompt patterns:
                       361→    ///   ? Question text
                       362→    ///     > Option 1
                       363→    ///     Option 2
                       364→    /// Or JSON blocks with question/options structure.
                       365→    static func parseUserQuestion(from text: String) -> UserQuestion? {
                       366→        // Try JSON pattern: {"question": "...", "options": [...]}
                       367→        if let data = text.data(using: .utf8),
                       368→           let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any],
                       369→           let questionText = json["question"] as? String {
                       370→            var opts: [UserQuestion.QuestionOption] = []
                       371→            if let optArr = json["options"] as? [String] {
                       372→                opts = optArr.map { UserQuestion.QuestionOption(label: $0) }
                       373→            } else if let optArr = json["options"] as? [[String: Any]] {
                       374→                opts = optArr.compactMap { item in
                       375→                    guard let label = item["label"] as? String else { return nil }
                       376→                    let desc = item["description"] as? String ?? ""
                       377→                    return UserQuestion.QuestionOption(label: label, description: desc)
                       378→                }
                       379→            }
                       380→            if !opts.isEmpty {
                       381→                return UserQuestion(question: questionText, options: opts)
                       382→            }
                       383→        }
                       384→
                       385→        // Try interactive prompt pattern
                       386→        let lines = text.components(separatedBy: "\n")
                       387→        var questionText: String?
                       388→        var options: [UserQuestion.QuestionOption] = []
                       389→
                       390→        for line in lines {
                       391→            let trimmed = line.trimmingCharacters(in: .whitespaces)
                       392→            // Question line: starts with "?" or contains "AskUserQuestion"
                       393→            if trimmed.hasPrefix("? ") {
                       394→                questionText = String(trimmed.dropFirst(2)).trimmingCharacters(in: .whitespaces)
                       395→                continue
                       396→            }
                       397→            // Option lines: start with unicode arrow or bullet
                       398→            if questionText != nil {
                       399→                let optionPrefixes = ["\u{276F} ", "\u{25B6} ", "- ", "* ", "> "]
                       400→                for prefix in optionPrefixes {
                       401→                    if trimmed.hasPrefix(prefix) {
                       402→                        let label = String(trimmed.dropFirst(prefix.count)).trimmingCharacters(in: .whitespaces)
                       403→                        if !label.isEmpty {
                       404→                            options.append(UserQuestion.QuestionOption(label: label))
                       405→                        }
                       406→                        break
                       407→                    }
                       408→                }
                       409→                // Plain indented option (after question was found)
                       410→                if options.isEmpty == false || trimmed.isEmpty { continue }
                       411→                // Check for a line that looks like a plain option (indented text after ?)
                       412→                if line.hasPrefix("  ") || line.hasPrefix("\t") {
                       413→                    let label = trimmed
                       414→                    if !label.isEmpty && !label.hasPrefix("?") {
                       415→                        options.append(UserQuestion.QuestionOption(label: label))
                       416→                    }
                       417→                }
                       418→            }
                       419→        }
                       420→
                       421→        if let question = questionText, !options.isEmpty {
                       422→            return UserQuestion(question: question, options: options)
                       423→        }
                       424→        return nil
                       425→    }
                       426→
                       427→    // MARK: Tool call parsing
                       428→
                       429→    /// Parses tool call indicators from assistant response text.
                       430→    static func parseToolCalls(from text: String) -> [ToolCall] {
                       431→        var calls: [ToolCall] = []
                       432→        let lines = text.components(separatedBy: "\n")
                       433→
                       434→        for line in lines {
                       435→            let trimmed = line.trimmingCharacters(in: .whitespaces)
                       436→
                       437→            // Pattern: checkmark-prefixed lines like "Read file.swift" or "Edit file.swift"
                       438→            // Also handles Unicode checkmark variants
                       439→            let checkPrefixes = ["\u{2713} ", "\u{2714} ", "\u{2705} "]
                       440→            for prefix in checkPrefixes {
                       441→                if trimmed.hasPrefix(prefix) {
                       442→                    let rest = String(trimmed.dropFirst(prefix.count))
                       443→                    if let call = Self.parseToolLine(rest, status: .completed) {
                       444→                        calls.append(call)
                       445→                    }
                       446→                }
                       447→            }
                       448→
                       449→            // Pattern: "X toolname args" for errors
                       450→            let errorPrefixes = ["\u{2717} ", "\u{2718} ", "\u{274C} "]
                       451→            for prefix in errorPrefixes {
                       452→                if trimmed.hasPrefix(prefix) {
                       453→                    let rest = String(trimmed.dropFirst(prefix.count))
                       454→                    if let call = Self.parseToolLine(rest, status: .error) {
                       455→                        calls.append(call)
                       456→                    }
                       457→                }
                       458→            }
                       459→        }
                       460→
                       461→        return calls
                       462→    }
                       463→
                       464→    private static func parseToolLine(_ text: String, status: ToolCall.ToolCallStatus) -> ToolCall? {
                       465→        let knownTools = ["Read", "Edit", "Write", "Bash", "Glob", "Grep",
                       466→                          "WebFetch", "WebSearch", "TodoWrite", "AskUserQuestion", "Task"]
                       467→        let parts = text.components(separatedBy: " ")
                       468→        guard let first = parts.first else { return nil }
                       469→
                       470→        // Check for "Bash: command" pattern
                       471→        let toolName: String
                       472→        let args: String
                       473→        if first.hasSuffix(":") {
                       474→            let candidate = String(first.dropLast())
                       475→            if knownTools.contains(where: { $0.caseInsensitiveCompare(candidate) == .orderedSame }) {
                       476→                toolName = candidate
                       477→                args = parts.dropFirst().joined(separator: " ")
                       478→            } else {
                       479→                return nil
                       480→            }
                       481→        } else if knownTools.contains(where: { $0.caseInsensitiveCompare(first) == .orderedSame }) {
                       482→            toolName = first
                       483→            args = parts.dropFirst().joined(separator: " ")
                       484→        } else {
                       485→            return nil
                       486→        }
                       487→
                       488→        return ToolCall(
                       489→            toolName: toolName,
                       490→            status: status,
                       491→            arguments: args.trimmingCharacters(in: .whitespaces)
                       492→        )
                       493→    }
