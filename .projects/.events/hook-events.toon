                      1056→// MARK: - Appearance Sheet
                      1057→
                      1058→struct SessionAppearanceSheet: View {
                      1059→    let session: ChatSession
                      1060→    let onSave: (String, String) -> Void
                      1061→
                      1062→    @State private var selectedColor: String
                      1063→    @State private var selectedIcon: String
                      1064→    @Environment(\.dismiss) private var dismiss
                      1065→
                      1066→    init(session: ChatSession, onSave: @escaping (String, String) -> Void) {
                      1067→        self.session = session
                      1068→        self.onSave = onSave
                      1069→        _selectedColor = State(initialValue: session.colorName)
                      1070→        _selectedIcon = State(initialValue: session.iconName)
                      1071→    }
                      1072→
                      1073→    var body: some View {
                      1074→        VStack(spacing: 0) {
                      1075→            // Title bar
                      1076→            HStack {
                      1077→                Text("Chat Appearance")
                      1078→                    .font(.headline)
                      1079→                Spacer()
                      1080→                Button("Done") {
                      1081→                    onSave(selectedColor, selectedIcon)
                      1082→                    dismiss()
                      1083→                }
                      1084→                .buttonStyle(.borderedProminent)
                      1085→                .controlSize(.small)
                      1086→            }
                      1087→            .padding(16)
                      1088→
                      1089→            Divider()
                      1090→
                      1091→            ScrollView {
                      1092→                VStack(alignment: .leading, spacing: 20) {
                      1093→                    // Preview
                      1094→                    HStack(spacing: 10) {
                      1095→                        ZStack {
                      1096→                            Circle()
                      1097→                                .fill(previewColor.opacity(0.15))
                      1098→                                .frame(width: 44, height: 44)
                      1099→                            Image(systemName: previewIcon)
                      1100→                                .font(.system(size: 20))
                      1101→                                .foregroundStyle(previewColor)
                      1102→                        }
                      1103→                        VStack(alignment: .leading, spacing: 2) {
                      1104→                            Text(session.title)
                      1105→                                .font(.system(size: 14, weight: .semibold))
                      1106→                            Text(session.provider)
                      1107→                                .font(.caption)
                      1108→                                .foregroundStyle(.secondary)
                      1109→                        }
                      1110→                        Spacer()
                      1111→                    }
                      1112→                    .padding(12)
                      1113→                    .background(Color.secondary.opacity(0.08), in: RoundedRectangle(cornerRadius: 10))
                      1114→
                      1115→                    // Color picker
                      1116→                    VStack(alignment: .leading, spacing: 8) {
                      1117→                        Text("Color")
                      1118→                            .font(.system(size: 12, weight: .semibold))
                      1119→                            .foregroundStyle(.secondary)
                      1120→                            .textCase(.uppercase)
                      1121→                        LazyVGrid(columns: Array(repeating: GridItem(.flexible()), count: 6), spacing: 10) {
                      1122→                            ForEach(ChatSession.colorOptions, id: \.name) { option in
                      1123→                                Circle()
                      1124→                                    .fill(option.color)
                      1125→                                    .frame(width: 32, height: 32)
                      1126→                                    .overlay(
                      1127→                                        Circle()
                      1128→                                            .strokeBorder(
                      1129→                                                selectedColor == option.name ? Color.primary : Color.clear,
                      1130→                                                lineWidth: 2
                      1131→                                            )
                      1132→                                            .padding(-3)
                      1133→                                    )
                      1134→                                    .onTapGesture { selectedColor = option.name }
                      1135→                            }
                      1136→                        }
                      1137→                    }
                      1138→
                      1139→                    // Icon picker
                      1140→                    VStack(alignment: .leading, spacing: 8) {
                      1141→                        Text("Icon")
                      1142→                            .font(.system(size: 12, weight: .semibold))
                      1143→                            .foregroundStyle(.secondary)
                      1144→                            .textCase(.uppercase)
                      1145→                        LazyVGrid(columns: Array(repeating: GridItem(.flexible()), count: 6), spacing: 10) {
                      1146→                            ForEach(ChatSession.iconOptions, id: \.self) { sym in
                      1147→                                ZStack {
                      1148→                                    RoundedRectangle(cornerRadius: 8)
                      1149→                                        .fill(selectedIcon == sym
                      1150→                                              ? previewColor.opacity(0.2)
                      1151→                                              : Color.secondary.opacity(0.1))
                      1152→                                        .frame(width: 40, height: 40)
                      1153→                                    Image(systemName: sym)
                      1154→                                        .font(.system(size: 16))
                      1155→                                        .foregroundStyle(selectedIcon == sym ? previewColor : .secondary)
                      1156→                                }
                      1157→                                .overlay(
                      1158→                                    RoundedRectangle(cornerRadius: 8)
                      1159→                                        .strokeBorder(
                      1160→                                            selectedIcon == sym ? previewColor : Color.clear,
                      1161→                                            lineWidth: 1.5
                      1162→                                        )
                      1163→                                )
                      1164→                                .onTapGesture {
                      1165→                                    selectedIcon = sym == "bubble.left" && session.iconName.isEmpty ? "" : sym
                      1166→                                }
                      1167→                            }
                      1168→                        }
                      1169→                    }
                      1170→                }
                      1171→                .padding(16)
                      1172→            }
                      1173→        }
                      1174→        #if os(macOS)
                      1175→        .frame(width: 360, height: 480)
                      1176→        #endif
                      1177→    }
                      1178→
                      1179→    private var previewColor: Color {
                      1180→        ChatSession.colorOptions.first { $0.name == selectedColor }?.color ?? .accentColor
                      1181→    }
                      1182→
                      1183→    private var previewIcon: String {
                      1184→        selectedIcon.isEmpty ? "bubble.left" : selectedIcon
                      1185→    }
                      1186→}
                      1187→
                      1188→// MARK: - Column 3: Chat Content
                      1189→
                      1190→struct ChatContentView: View {
                      1191→    @ObservedObject var plugin: ChatPlugin
                      1192→
                      1193→    var body: some View {
                      1194→        if let session = plugin.selectedSession {
                      1195→            ChatDetailView(plugin: plugin, session: session)
                      1196→        } else {
                      1197→            OrchestraEmptyState(
                      1198→                contextMessage: "Start a new chat or select one from the panel.",
                      1199→                actionLabel: "New Chat",
                      1200→                onAction: { plugin.newSession() }
                      1201→            )
                      1202→        }
                      1203→    }
                      1204→}
                      1205→
                      1206→// MARK: - Session Status Bar
                      1207→
                      1208→struct SessionStatusBar: View {
                      1209→    let metadata: SessionMetadata
                      1210→
                      1211→    var body: some View {
                      1212→        HStack(spacing: 12) {
                      1213→            if !metadata.model.isEmpty {
                      1214→                metaItem(icon: "cpu", text: metadata.model)
                      1215→            }
                      1216→            if metadata.tokenCount > 0 {
                      1217→                metaItem(icon: "number", text: "\(metadata.tokenCount) tokens")
                      1218→            }
                      1219→            if !metadata.duration.isEmpty {
                      1220→                metaItem(icon: "clock", text: metadata.duration)
                      1221→            }
                      1222→            if !metadata.cost.isEmpty {
                      1223→                metaItem(icon: "dollarsign.circle", text: metadata.cost)
                      1224→            }
                      1225→            Spacer()
                      1226→        }
                      1227→        .padding(.horizontal, 16)
                      1228→        .padding(.vertical, 5)
                      1229→    }
                      1230→
                      1231→    private func metaItem(icon: String, text: String) -> some View {
                      1232→        HStack(spacing: 4) {
                      1233→            Image(systemName: icon)
                      1234→                .font(.system(size: 9, weight: .medium))
                      1235→            Text(text)
                      1236→                .font(.system(size: 11))
                      1237→        }
                      1238→        .foregroundStyle(.secondary)
                      1239→        .padding(.horizontal, 7)
                      1240→        .padding(.vertical, 3)
                      1241→        .background(Color.secondary.opacity(0.10), in: Capsule())
                      1242→    }
                      1243→}
                      1244→
                      1245→
                      1246→// MARK: - Detail View
                      1247→
                      1248→struct ChatDetailView: View {
                      1249→    @ObservedObject var plugin: ChatPlugin
                      1250→    let session: ChatSession
                      1251→    @ObservedObject private var inputState = SmartInputState.shared
                      1252→
                      1253→    var body: some View {
                      1254→        ZStack {
                      1255→            VStack(spacing: 0) {
                      1256→                HStack(spacing: 10) {
                      1257→                    ZStack {
                      1258→                        Circle()
                      1259→                            .fill(session.resolvedColor.opacity(0.15))
                      1260→                            .frame(width: 28, height: 28)
                      1261→                        Image(systemName: session.resolvedIcon)
                      1262→                            .font(.system(size: 13))
                      1263→                            .foregroundStyle(session.resolvedColor)
                      1264→                    }
                      1265→                    Text(session.title)
                      1266→                        .font(.headline)
                      1267→                    Spacer()
                      1268→                    Text(session.modelLabel)
                      1269→                        .font(.system(size: 11))
                      1270→                        .foregroundStyle(.secondary)
                      1271→                        .padding(.horizontal, 8)
                      1272→                        .padding(.vertical, 3)
                      1273→                        .background(Color.secondary.opacity(0.12), in: Capsule())
                      1274→                    Text(session.provider)
                      1275→                        .font(.caption)
                      1276→                        .foregroundStyle(.secondary)
                      1277→                        .padding(.horizontal, 8)
                      1278→                        .padding(.vertical, 3)
                      1279→                        .background(Color.secondary.opacity(0.12), in: Capsule())
                      1280→                }
                      1281→                .padding(.horizontal, 16)
                      1282→                .padding(.vertical, 10)
                      1283→
                      1284→                Divider()
                      1285→
                      1286→                MessageList(session: session, isSending: plugin.isSending, loadingWord: plugin.loadingWord) { messageId, answer in
                      1287→                    plugin.sendQuestionAnswer(messageId: messageId, answer: answer)
                      1288→                }
                      1289→
                      1290→                // Permission request banner — shown above input bar
                      1291→                if let permission = plugin.pendingPermission {
                      1292→                    PermissionRequestView(request: permission)
                      1293→                        .padding(.horizontal, 14)
                      1294→                        .padding(.vertical, 6)
                      1295→                        .transition(.move(edge: .bottom).combined(with: .opacity))
                      1296→                }
                      1297→
                      1298→                // Docked input bar — only on macOS, only when not detached
                      1299→                #if os(macOS)
                      1300→                if !inputState.isDetached {
                      1301→                    DockedInputBar(chatPlugin: plugin, sessionId: session.id)
                      1302→                        .environment(\.colorScheme, .dark)
                      1303→                        .padding(.horizontal, 14)
                      1304→                        .padding(.vertical, 10)
                      1305→                        .transition(.move(edge: .bottom).combined(with: .opacity))
                      1306→                }
                      1307→                #endif
                      1308→
                      1309→                // Session metadata status bar
                      1310→                if let metadata = plugin.sessionMetadata, metadata.hasData {
                      1311→                    SessionStatusBar(metadata: metadata)
                      1312→                }
                      1313→            }
                      1314→
                      1315→        }
                      1316→        .animation(.spring(response: 0.35, dampingFraction: 0.82), value: inputState.isDetached)
                      1317→        .onAppear {
                      1318→            SmartInputState.shared.activeChatPlugin = plugin
                      1319→        }
                      1320→        .onDisappear {
                      1321→            SmartInputState.shared.activeChatPlugin = nil
                      1322→        }
                      1323→    }
                      1324→}
                      1325→
                      1326→
                      1327→// MARK: - Message List
                      1328→
                      1329→struct MessageList: View {
                      1330→    let session: ChatSession
                      1331→    var isSending: Bool = false
                      1332→    var loadingWord: String = "Thinking"
                      1333→    var onQuestionAnswer: ((UUID, String) -> Void)? = nil
                      1334→
                      1335→    var body: some View {
                      1336→        ScrollViewReader { proxy in
                      1337→            ScrollView {
                      1338→                LazyVStack(alignment: .leading, spacing: 8) {
                      1339→                    ForEach(session.messages) { message in
                      1340→                        ChatBubble(message: message, onQuestionAnswer: onQuestionAnswer)
                      1341→                            .id(message.id)
                      1342→                    }
                      1343→                    if isSending {
                      1344→                        TypingIndicator(loadingWord: loadingWord)
                      1345→                            .id("typing-indicator")
                      1346→                    }
                      1347→                }
                      1348→                .padding()
                      1349→            }
                      1350→            .onChange(of: session.messages.count) { _, _ in
                      1351→                if let last = session.messages.last {
                      1352→                    withAnimation(.easeOut(duration: 0.2)) {
                      1353→                        proxy.scrollTo(last.id, anchor: .bottom)
                      1354→                    }
                      1355→                }
                      1356→            }
                      1357→            .onChange(of: isSending) { _, sending in
                      1358→                if sending {
                      1359→                    withAnimation(.easeOut(duration: 0.2)) {
                      1360→                        proxy.scrollTo("typing-indicator", anchor: .bottom)
                      1361→                    }
                      1362→                }
                      1363→            }
                      1364→        }
                      1365→    }
                      1366→}
                      1367→
                      1368→// MARK: - Typing Indicator
                      1369→
                      1370→private struct TypingIndicator: View {
                      1371→    var loadingWord: String = "Thinking"
                      1372→    @State private var dotPhase = 0
                      1373→    @State private var pulseScale: CGFloat = 1.0
                      1374→    private let timer = Timer.publish(every: 0.5, on: .main, in: .common).autoconnect()
                      1375→
                      1376→    private let gradientColors: [Color] = [
                      1377→        Color(red: 0.00, green: 0.90, blue: 1.00),
                      1378→        Color(red: 0.66, green: 0.00, blue: 1.00),
                      1379→    ]
                      1380→
                      1381→    var body: some View {
                      1382→        HStack(alignment: .bottom, spacing: 0) {
                      1383→            HStack(spacing: 4) {
                      1384→                Text(loadingWord + String(repeating: ".", count: dotPhase + 1))
                      1385→                    .font(.system(size: 13, weight: .medium))
                      1386→                    .foregroundStyle(
                      1387→                        LinearGradient(
                      1388→                            colors: gradientColors,
                      1389→                            startPoint: .leading,
                      1390→                            endPoint: .trailing
                      1391→                        )
                      1392→                    )
                      1393→                    .scaleEffect(pulseScale)
                      1394→                    .animation(.easeInOut(duration: 1.0).repeatForever(autoreverses: true), value: pulseScale)
                      1395→            }
                      1396→            .padding(.horizontal, 14)
                      1397→            .padding(.vertical, 10)
                      1398→            .background(Color.secondary.opacity(0.15))
                      1399→            .clipShape(RoundedRectangle(cornerRadius: 16, style: .continuous))
