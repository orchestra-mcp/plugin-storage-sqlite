                       846→// MARK: - Session Row
                       847→
                       848→struct SessionRow: View {
                       849→    let session: ChatSession
                       850→    let isSelected: Bool
                       851→    let isChecked: Bool
                       852→    let isSelecting: Bool
                       853→    var selectionNamespace: Namespace.ID
                       854→    var onPin: (() -> Void)? = nil
                       855→    var onDelete: (() -> Void)? = nil
                       856→    var onTap: (() -> Void)? = nil
                       857→    var onLongPress: (() -> Void)? = nil
                       858→
                       859→    @State private var isHovered = false
                       860→    @State private var swipeOffset: CGFloat = 0
                       861→    @State private var isSwipingLeft = false   // trailing (delete)
                       862→    @State private var isSwipingRight = false  // leading (pin)
                       863→
                       864→    // How far to drag before revealing the action button
                       865→    private let revealThreshold: CGFloat = 64
                       866→    // Full-swipe distance to auto-trigger
                       867→    private let fullSwipeThreshold: CGFloat = 160
                       868→
                       869→    var body: some View {
                       870→        ZStack(alignment: .trailing) {
                       871→            // ── Right action (Delete) ──────────────────────────
                       872→            if isSwipingLeft {
                       873→                HStack {
                       874→                    Spacer()
                       875→                    Button(action: { onDelete?() }) {
                       876→                        VStack(spacing: 3) {
                       877→                            Image(systemName: "trash.fill")
                       878→                                .font(.system(size: 14, weight: .semibold))
                       879→                            Text("Delete")
                       880→                                .font(.system(size: 10, weight: .medium))
                       881→                        }
                       882→                        .foregroundStyle(.white)
                       883→                        .frame(width: max(0, -swipeOffset))
                       884→                        .frame(maxHeight: .infinity)
                       885→                        .background(Color.red.opacity(min(1, (-swipeOffset) / revealThreshold)))
                       886→                        .clipShape(RoundedRectangle(cornerRadius: 13, style: .continuous))
                       887→                    }
                       888→                    .buttonStyle(.plain)
                       889→                }
                       890→            }
                       891→
                       892→            // ── Left action (Pin) ──────────────────────────────
                       893→            if isSwipingRight {
                       894→                HStack {
                       895→                    Button(action: { onPin?() }) {
                       896→                        VStack(spacing: 3) {
                       897→                            Image(systemName: session.isPinned ? "pin.slash.fill" : "pin.fill")
                       898→                                .font(.system(size: 14, weight: .semibold))
                       899→                            Text(session.isPinned ? "Unpin" : "Pin")
                filePath: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/4c8aa7b3-279a-4e53-9880-b7605c240237/tool-results/toolu_01BnEDnJKDuNBy7QpUwFaqL1.txt
                numLines: 400
                startLine: 500
                totalLines: 2055
            type: text
        tool_use_id: toolu_01V2AEMmr9x9tGicHJGTAT45
        transcript_path: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/4c8aa7b3-279a-4e53-9880-b7605c240237.jsonl
      timestamp: "2026-03-02T10:47:02Z"
    - event_type: PostToolUse
      session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
      tool_name: Read
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: plan
        session_id: 4c8aa7b3-279a-4e53-9880-b7605c240237
        tool_input:
            file_path: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/4c8aa7b3-279a-4e53-9880-b7605c240237/tool-results/toolu_01BnEDnJKDuNBy7QpUwFaqL1.txt
            limit: 500
            offset: 900
        tool_name: Read
        tool_response:
            file:
                content: |4-
                       900→                                .font(.system(size: 10, weight: .medium))
                       901→                        }
                       902→                        .foregroundStyle(.white)
                       903→                        .frame(width: max(0, swipeOffset))
                       904→                        .frame(maxHeight: .infinity)
                       905→                        .background(Color.orange.opacity(min(1, swipeOffset / revealThreshold)))
                       906→                        .clipShape(RoundedRectangle(cornerRadius: 13, style: .continuous))
                       907→                    }
                       908→                    .buttonStyle(.plain)
                       909→                    Spacer()
                       910→                }
                       911→            }
                       912→
                       913→            // ── Row content ────────────────────────────────────
                       914→            rowContent
                       915→                .offset(x: swipeOffset)
                       916→                .gesture(
                       917→                    DragGesture(minimumDistance: 10)
                       918→                        .onChanged { value in
                       919→                            let dx = value.translation.width
                       920→                            // Only allow horizontal drag
                       921→                            guard abs(dx) > abs(value.translation.height) else { return }
                       922→                            withAnimation(.interactiveSpring()) {
                       923→                                swipeOffset = dx
                       924→                                isSwipingLeft  = dx < 0
                       925→                                isSwipingRight = dx > 0
                       926→                            }
                       927→                        }
                       928→                        .onEnded { value in
                       929→                            let dx = value.translation.width
                       930→                            withAnimation(.spring(response: 0.35, dampingFraction: 0.75)) {
                       931→                                if dx < -fullSwipeThreshold {
                       932→                                    // Full swipe left → immediate delete
                       933→                                    onDelete?()
                       934→                                    swipeOffset = 0
                       935→                                } else if dx < -revealThreshold {
                       936→                                    // Partial — snap to reveal delete button
                       937→                                    swipeOffset = -revealThreshold
                       938→                                } else if dx > fullSwipeThreshold {
                       939→                                    // Full swipe right → immediate pin toggle
                       940→                                    onPin?()
                       941→                                    swipeOffset = 0
                       942→                                } else if dx > revealThreshold {
                       943→                                    // Partial — snap to reveal pin button
                       944→                                    swipeOffset = revealThreshold
                       945→                                } else {
                       946→                                    swipeOffset = 0
                       947→                                }
                       948→                                isSwipingLeft  = swipeOffset < 0
                       949→                                isSwipingRight = swipeOffset > 0
                       950→                            }
                       951→                        }
                       952→                )
                       953→        }
                       954→        .clipped()
                       955→        // simultaneousGesture lets tap fire even when DragGesture is attached
                       956→        .simultaneousGesture(
                       957→            TapGesture().onEnded {
                       958→                if swipeOffset != 0 {
                       959→                    withAnimation(.spring(response: 0.3, dampingFraction: 0.8)) {
                       960→                        swipeOffset = 0
                       961→                        isSwipingLeft  = false
                       962→                        isSwipingRight = false
                       963→                    }
                       964→                } else {
                       965→                    onTap?()
                       966→                }
                       967→            }
                       968→        )
                       969→        .simultaneousGesture(
                       970→            LongPressGesture(minimumDuration: 0.4).onEnded { _ in
                       971→                if swipeOffset == 0 { onLongPress?() }
                       972→            }
                       973→        )
                       974→        .animation(.easeInOut(duration: 0.15), value: isSelected)
                       975→        .onHover { isHovered = $0 }
                       976→    }
                       977→
                       978→    // ── The actual row HStack ──────────────────────────────────
                       979→    private var rowContent: some View {
                       980→        HStack(spacing: 8) {
                       981→            if isSelecting {
                       982→                Image(systemName: isChecked ? "checkmark.circle.fill" : "circle")
                       983→                    .font(.system(size: 16))
                       984→                    .foregroundStyle(isChecked ? Color.accentColor : Color.secondary)
                       985→                    .frame(width: 20)
                       986→            } else {
                       987→                ZStack {
                       988→                    Circle()
                       989→                        .fill(session.resolvedColor.opacity(0.18))
                       990→                        .frame(width: 30, height: 30)
                       991→                    Image(systemName: session.resolvedIcon)
                       992→                        .font(.system(size: 13, weight: .medium))
                       993→                        .foregroundStyle(session.resolvedColor)
                       994→                }
                       995→            }
                       996→
                       997→            VStack(alignment: .leading, spacing: 2) {
                       998→                HStack(spacing: 4) {
                       999→                    if session.isPinned {
                      1000→                        Image(systemName: "pin.fill")
                      1001→                            .font(.system(size: 9))
                      1002→                            .foregroundStyle(.orange)
                      1003→                    }
                      1004→                    Text(session.title)
                      1005→                        .font(.system(size: 13, weight: .medium))
                      1006→                        .foregroundStyle(.primary)
                      1007→                        .lineLimit(1)
                      1008→                }
                      1009→                Text(session.provider)
                      1010→                    .font(.system(size: 11))
                      1011→                    .foregroundStyle(.secondary)
                      1012→            }
                      1013→
                      1014→            Spacer()
                      1015→
                      1016→            if !session.messages.isEmpty {
                      1017→                Text("\(session.messages.count)")
                      1018→                    .font(.system(size: 10, weight: .medium))
                      1019→                    .foregroundStyle(.secondary)
                      1020→                    .padding(.horizontal, 5)
                      1021→                    .padding(.vertical, 2)
                      1022→                    .background(Capsule().fill(Color.secondary.opacity(0.15)))
                      1023→            }
                      1024→        }
                      1025→        .padding(.horizontal, 10)
                      1026→        .padding(.vertical, 9)
                      1027→        .background {
                      1028→            if isSelected {
                      1029→                RoundedRectangle(cornerRadius: 13, style: .continuous)
                      1030→                    .fill(.ultraThinMaterial)
                      1031→                    .matchedGeometryEffect(id: "session-selection", in: selectionNamespace)
                      1032→                    .overlay(
                      1033→                        RoundedRectangle(cornerRadius: 13, style: .continuous)
                      1034→                            .strokeBorder(
                      1035→                                LinearGradient(
                      1036→                                    colors: [Color.white.opacity(0.28), Color.white.opacity(0.06)],
                      1037→                                    startPoint: .top, endPoint: .bottom
                      1038→                                ),
                      1039→                                lineWidth: 0.75
                      1040→                            )
                      1041→                    )
                      1042→                    .shadow(color: .black.opacity(0.20), radius: 6, x: 0, y: 3)
                      1043→            } else if isHovered {
                      1044→                RoundedRectangle(cornerRadius: 13, style: .continuous)
                      1045→                    .fill(Color.white.opacity(0.06))
                      1046→                    .overlay(
                      1047→                        RoundedRectangle(cornerRadius: 13, style: .continuous)
                      1048→                            .strokeBorder(Color.white.opacity(0.08), lineWidth: 0.75)
                      1049→                    )
                      1050→            }
                      1051→        }
                      1052→        .animation(.easeInOut(duration: 0.12), value: isHovered)
                      1053→    }
                      1054→}
