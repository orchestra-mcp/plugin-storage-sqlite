                | `pack-native-swift` | swift | swift-plugin agent |
                | `pack-native-kotlin` | kotlin | kotlin-plugin agent |
                | `pack-native-csharp` | csharp | csharp-plugin agent |
                | `pack-native-gtk` | c | gtk-plugin agent |

