                	go test ./libs/sdk-go/... -v
                	go test ./libs/orchestrator/... -v
                	go test ./libs/plugin-storage-markdown/... -v
                	go test ./libs/plugin-tools-features/... -v
                	go test ./libs/plugin-transport-stdio/... -v
                	go test ./libs/plugin-test-example/... -v

                test-e2e: build
                	@bash scripts/test-e2e.sh

                # === Install ===

                PREFIX ?= /usr/local
                BINARIES := orchestra orchestrator storage-markdown tools-features transport-stdio test-example

                install: build
                	@mkdir -p $(PREFIX)/bin
                	@for b in $(BINARIES); do \
