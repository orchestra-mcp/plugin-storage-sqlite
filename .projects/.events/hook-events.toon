        tool_name: Read
        tool_response:
            file:
                content: |
                    import Foundation

                    /// Observable service that wraps OrchestraClient for SwiftUI consumption.
                    /// Manages loading state and surfaces errors as published properties.
                    @MainActor
                    public final class ToolService: ObservableObject {

                        // MARK: - Singleton

                        public static let shared = ToolService()

                        // MARK: - Published State

                        /// True while a tool call is in flight.
                        @Published public private(set) var isLoading: Bool = false

                        /// The error message from the most recent failed tool call, or nil.
                        @Published public private(set) var lastError: String? = nil

                        // MARK: - Init

                        private init() {}

                        // MARK: - Tool Invocation

                        /// Call an MCP tool by name with optional arguments.
                        /// - Parameters:
                        ///   - tool: The registered tool name (e.g. `"list_features"`).
                        ///   - arguments: Key-value arguments forwarded to the tool.
                        /// - Returns: The plain-text result from the tool.
                        /// - Throws: `ToolServiceError.toolFailed(_:)` when the orchestrator
                        ///           returns a non-success response.
                        public func call(tool: String, arguments: [String: Any] = [:]) async throws -> String {
                            isLoading = true
                            lastError = nil
                            defer { isLoading = false }

                            // Extract "provider" from arguments and promote it to the Protobuf provider
                            // field so the orchestrator router can dispatch to the correct AI bridge plugin.
                            // If not present, default to "claude" for ai_prompt calls.
                            let provider = arguments["provider"] as? String
                                ?? (tool == "ai_prompt" ? "claude" : "")

                            let request = ToolRequest(toolName: tool, arguments: arguments, provider: provider)
                            let response = try await OrchestraClient.shared.callTool(request)

                            if response.success {
                                return response.resultText
                            } else {
                                let message = response.errorMessage.isEmpty ? response.errorCode : response.errorMessage
                                lastError = message
                                throw ToolServiceError.toolFailed(message)
                            }
                        }

                        // MARK: - Error Types

                        /// Errors surfaced by ToolService.
                        public enum ToolServiceError: Error, LocalizedError {
                            case toolFailed(String)

                            public var errorDescription: String? {
                                switch self {
                                case .toolFailed(let message):
                                    return "Tool call failed: \(message)"
                                }
                            }
                        }
                    }
                filePath: /Users/fadymondy/Sites/orchestra-agents/apps/swift/OrchestraKit/Sources/OrchestraKit/Services/ToolService.swift
                numLines: 70
                startLine: 1
                totalLines: 70
            type: text
