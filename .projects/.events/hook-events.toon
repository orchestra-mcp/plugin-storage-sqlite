                        62→    /// A tool call that requires user approval before execution.
                        63→    public struct PermissionRequest: Identifiable {
                        64→        public let id = UUID()
                        65→        public let toolName: String
                        66→        public let arguments: String
                        67→        public let onAccept: () -> Void
                        68→        public let onAcceptAll: () -> Void
                        69→        public let onReject: () -> Void
