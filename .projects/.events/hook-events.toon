                       128→    public func newSession(title: String = "New Chat", provider: String = "claude") {
                       129→        let session = ChatSession(title: title, provider: provider)
                       130→        // Pinned sessions stay at top; new sessions go after pinned block
                       131→        let insertIdx = sessions.firstIndex { !$0.isPinned } ?? sessions.endIndex
                       132→        sessions.insert(session, at: insertIdx)
                       133→        selectedSession = session
                       134→    }
                       135→
                       136→    public func deleteSession(_ session: ChatSession) {
                       137→        sessions.removeAll { $0.id == session.id }
                       138→        selectedIds.remove(session.id)
                       139→        if selectedSession?.id == session.id {
                       140→            selectedSession = sessions.first
                       141→        }
                       142→    }
                       143→
                       144→    public func deleteSelected() {
                       145→        sessions.removeAll { selectedIds.contains($0.id) }
                       146→        if let sel = selectedSession, selectedIds.contains(sel.id) {
                       147→            selectedSession = sessions.first
                       148→        }
                       149→        clearSelection()
                       150→    }
                       151→
                       152→    public func togglePin(_ session: ChatSession) {
                       153→        guard let idx = sessions.firstIndex(where: { $0.id == session.id }) else { return }
                       154→        sessions[idx].isPinned.toggle()
                       155→        // Re-sort: pinned first, then by date
                       156→        sessions.sort {
                       157→            if $0.isPinned != $1.isPinned { return $0.isPinned }
                       158→            return $0.createdAt > $1.createdAt
                       159→        }
                       160→        // Keep selectedSession in sync
                       161→        if let sel = selectedSession, sel.id == session.id {
                       162→            selectedSession = sessions[sessions.firstIndex { $0.id == session.id }!]
                       163→        }
                       164→    }
                       165→
                       166→    public func updateSession(_ id: UUID, colorName: String? = nil, iconName: String? = nil, title: String? = nil) {
                       167→        guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                       168→        if let c = colorName  { sessions[idx].colorName = c }
                       169→        if let i = iconName   { sessions[idx].iconName  = i }
                       170→        if let t = title      { sessions[idx].title     = t }
                       171→        if selectedSession?.id == id { selectedSession = sessions[idx] }
                       172→    }
                       173→
                       174→    public func toggleSelectMode() {
