                        // MARK: - Send

                        private func sendMessage() {
                            if state.isChatMode {
                                var prompt = state.text.trimmingCharacters(in: .whitespacesAndNewlines)
                                guard !prompt.isEmpty, let chat = state.activeChatPlugin else { return }
                                if !state.attachedFiles.isEmpty {
                                    let filePaths = state.attachedFiles.map { "- @\($0.url.path)" }.joined(separator: "\n")
                                    prompt = "Context files:\n\(filePaths)\n\n\(prompt)"
                                    state.clearFiles()
                                }
                                if let browserCtx = BrowserContextService.shared.browserContext() {
                                    prompt = "\(browserCtx)\n\n\(prompt)"
                                }
                                state.text = ""
                                Task { await chat.sendMessage(prompt) }
                            } else {
                                var prompt = state.text.trimmingCharacters(in: .whitespacesAndNewlines)
                                guard !prompt.isEmpty else { return }
                                if !state.attachedFiles.isEmpty {
                                    let filePaths = state.attachedFiles.map { "- @\($0.url.path)" }.joined(separator: "\n")
                                    prompt = "Context files:\n\(filePaths)\n\n\(prompt)"
                                    state.clearFiles()
                                }
                                if let browserCtx = BrowserContextService.shared.browserContext() {
                                    prompt = "\(browserCtx)\n\n\(prompt)"
                                }
                                state.text = ""
                                state.isLoading = true
                                let systemCtx = state.useContext ? AppContext.shared.systemContext() : nil
                                let mgr = isFloating ? SmartInputWindowManager.shared : nil
                                Task {
                                    do {
                                        var args: [String: Any] = ["prompt": prompt, "wait": true, "provider": "claude"]
                                        if let ctx = systemCtx { args["system_prompt"] = ctx }
                                        let result = try await ToolService.shared.call(tool: "ai_prompt", arguments: args)
                                        await MainActor.run {
                                            state.isLoading = false
                                            state.lastResponse = result
                                            withAnimation { state.showingResponse = true }
                                            if let mgr {
                                                let msgs = [
                                                    MiniChatMessage(role: .user, content: prompt),
                                                    MiniChatMessage(role: .assistant, content: result)
                                                ]
                                                SiriResponseWindowManager.shared.showMessages(msgs, bubbleManager: mgr)
                                            }
                                        }
                                    } catch {
                                        await MainActor.run {
                                            state.isLoading = false
                                            state.lastResponse = "Error: \(error.localizedDescription)"
                                            withAnimation { state.showingResponse = true }
                                            if let mgr {
                                                let msgs = [
                                                    MiniChatMessage(role: .user, content: prompt),
                                                    MiniChatMessage(role: .assistant, content: "Error: \(error.localizedDescription)")
                                                ]
                                                SiriResponseWindowManager.shared.showMessages(msgs, bubbleManager: mgr)
