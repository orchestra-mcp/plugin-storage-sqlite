                    		fmt.Fprintf(&b, "1. **Create project:** Use `create_project` with name '%s'", projectName)
                    		if description != "" {
                    			fmt.Fprintf(&b, " and description '%s'", description)
                    		}
                    		fmt.Fprintf(&b, "\n\n")

                    		if len(stackNames) > 0 {
