                  { href: '/dashboard', label: 'Dashboard', icon: 'bx-home-alt-2' },
                  { href: '/projects', label: 'Projects', icon: 'bx-folder' },
                  { href: '/notes', label: 'Notes', icon: 'bx-note' },
