                        71→
                        72→    // Persists the selected session ID across launches via UserDefaults
                        73→    @AppStorage("chat.selectedSessionId") private var selectedSessionId: String = ""
                        74→
                        75→    // MARK: Persistence
                        76→
                        77→    private static var sessionsURL: URL {
                        78→        let appSupport = FileManager.default.urls(for: .applicationSupportDirectory, in: .userDomainMask)[0]
                        79→        let dir = appSupport.appendingPathComponent("Orchestra", isDirectory: true)
                        80→        try? FileManager.default.createDirectory(at: dir, withIntermediateDirectories: true)
                        81→        return dir.appendingPathComponent("chat-sessions.json")
                        82→    }
                        83→
                        84→    private func persistSessions() {
                        85→        let url = Self.sessionsURL
                        86→        Task.detached(priority: .background) { [sessions] in
                        87→            guard let data = try? JSONEncoder().encode(sessions) else { return }
                        88→            try? data.write(to: url, options: .atomic)
                        89→        }
                        90→    }
                        91→
                        92→    private static func loadSessions() -> [ChatSession] {
                        93→        guard let data = try? Data(contentsOf: sessionsURL),
                        94→              let decoded = try? JSONDecoder().decode([ChatSession].self, from: data)
                        95→        else { return [] }
                        96→        return decoded
                        97→    }
                        98→
                        99→    public init() {
                       100→        let saved = Self.loadSessions()
                       101→        // Bypass didSet on init to avoid a redundant write-back on first load
                       102→        _sessions = Published(initialValue: saved)
                       103→        // Restore the previously selected session; fall back to first
                       104→        let lastId = UserDefaults.standard.string(forKey: "chat.selectedSessionId") ?? ""
                       105→        let restored = saved.first { $0.id.uuidString == lastId } ?? saved.first
                       106→        _selectedSession = Published(initialValue: restored)
                       107→    }
