            command: |-
                find libs/ -name "go.mod" -type f | while read gomod; do
                  if grep -q "orchestra-mcp/gen-go v" "$gomod" 2>/dev/null; then
                    sed -i '' 's|orchestra-mcp/gen-go v[0-9]*\.[0-9]*\.[0-9]*[^ ]*|orchestra-mcp/gen-go v1.0.0|g' "$gomod"
                  fi
                  if grep -q "orchestra-mcp/sdk-go v" "$gomod" 2>/dev/null; then
                    sed -i '' 's|orchestra-mcp/sdk-go v[0-9]*\.[0-9]*\.[0-9]*[^ ]*|orchestra-mcp/sdk-go v1.0.0|g' "$gomod"
                  fi
                done && echo "All go.mod files updated to v1.0.0"
            description: Update all go.mod internal dependency versions to v1.0.0
        tool_name: Bash
