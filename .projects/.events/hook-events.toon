            file:
                content: |4-
                        //
                        // Uses ZStack + opacity to keep the view tree stable.
                        // Swapping views via if/else crashes NSHostingView in the floating panel.

                        private var sendOrStopButton: some View {
                            ZStack {
                                // Voice stop button
                                Button {
                                    if voiceService.phase == .speaking {
                                        voiceService.interrupt()
                                    } else {
                                        voiceService.stopVoiceMode()
                                    }
                                } label: {
                                    ZStack {
                                        Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                                        Circle().fill(Color.red.opacity(0.25)).frame(width: 30, height: 30)
                                        Image(systemName: voiceService.phase == .speaking ? "hand.raised.fill" : "stop.fill")
                                            .font(.system(size: 12, weight: .bold))
                                            .foregroundStyle(.red)
                                    }
                                }
                                .buttonStyle(.plain)
                                .opacity(voiceService.voiceModeActive ? 1 : 0)
                                .allowsHitTesting(voiceService.voiceModeActive)

                                // Loading dots
                                loadingDots.frame(width: 36, height: 32)
                                    .opacity(!voiceService.voiceModeActive && state.isLoading ? 1 : 0)

                                // Send button
                                Button(action: sendMessage) {
                                    ZStack {
                                        Circle().fill(.ultraThinMaterial).frame(width: 30, height: 30)
                                        Circle().fill(Color.white.opacity(canSend ? 0.18 : 0.07)).frame(width: 30, height: 30)
                                        Image(systemName: "arrow.up")
                                            .font(.system(size: 12, weight: .bold))
                                            .foregroundStyle(canSend ? .white : Color.white.opacity(0.30))
                                    }
                                }
                                .buttonStyle(.plain)
                                .disabled(!canSend)
                                .scaleEffect(canSend ? 1.0 : 0.85)
                                .opacity(!voiceService.voiceModeActive && !state.isLoading ? 1 : 0)
                                .allowsHitTesting(!voiceService.voiceModeActive && !state.isLoading)
                            }
                            .frame(width: 36, height: 32)
                        }

                        // MARK: - Loading Dots

                        private var loadingDots: some View {
                            InputBarLoadingDots()
                        }

                        // MARK: - Dock / Detach Button

                        private var dockDetachButton: some View {
                            Button {
                                if isFloating {
                                    onDock?()
                                } else {
                                    onDetach?()
                                }
                            } label: {
                                Image(systemName: isFloating
                                    ? "arrow.down.right.and.arrow.up.left"
                                    : "arrow.up.left.and.arrow.down.right")
                                    .font(.system(size: 10, weight: .medium))
                                    .foregroundStyle(Color.white.opacity(0.45))
                                    .frame(width: 24, height: 24)
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(0.07)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(Color.white.opacity(0.12), lineWidth: 0.75).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .glassTooltip(isFloating ? "Dock" : "Detach")
                        }

                        // MARK: - Quick Action Toggle

                        private var quickActionToggle: some View {
                            Button {
                                if isFloating {
                                    // Floating: animate chevron only (safe -- does not change layout)
                                    let willShow = !state.showQuickActions
                                    withAnimation(.spring(response: 0.35, dampingFraction: 0.78)) {
                                        chevronRotation = willShow ? 180 : 0
                                    }
                                    if willShow {
                                        state.showQuickActions = true
                                        onHeightChange?()
                                    } else {
                                        state.showQuickActions = false
                                        DispatchQueue.main.async {
                                            onHeightChange?()
                                        }
                                    }
                                } else {
                                    // Docked: safe to use withAnimation
                                    withAnimation(.spring(response: 0.35, dampingFraction: 0.78)) {
                                        state.showQuickActions.toggle()
                                        chevronRotation = state.showQuickActions ? 180 : 0
                                    }
                                }
                            } label: {
                                Image(systemName: "chevron.down")
                                    .font(.system(size: 11, weight: .semibold))
                                    .foregroundStyle(state.showQuickActions ? .white : .white.opacity(0.35))
                                    .rotationEffect(.degrees(chevronRotation))
                                    .frame(width: 28, height: 28)
                                    .contentShape(Circle())
                                    .background(.ultraThinMaterial, in: Circle())
                                    .overlay(Circle().fill(Color.white.opacity(state.showQuickActions ? 0.07 : 0.0)).allowsHitTesting(false))
                                    .overlay(Circle().strokeBorder(
                                        LinearGradient(colors: [Color.white.opacity(0.12)],
                                                       startPoint: .leading, endPoint: .trailing),
                                        lineWidth: 0.75
                                    ).allowsHitTesting(false))
                            }
                            .buttonStyle(.plain)
                            .glassTooltip(state.showQuickActions ? "Hide toolbar" : "Show toolbar")
                        }

                        // MARK: - Quick Actions Row

                        /// Resolve session ID: explicit param or active chat session.
                        private var resolvedSessionId: UUID? {
                            sessionId ?? chatPlugin?.selectedSession?.id
                        }

                        private var quickActionsRow: some View {
                            HStack(spacing: 8) {
                                // Model / Mode / Think pickers -- only when chat session available
                                if let plugin = chatPlugin, let sid = resolvedSessionId {
                                    SessionModelButton(plugin: plugin, sessionId: sid)
                                    SessionModeButton(plugin: plugin, sessionId: sid)
                                    SessionThinkingButton(plugin: plugin, sessionId: sid)
                                }

                                // Vision (context) — right after thinking
                                contextButton
                                suggestionsButton
                                browserButton
                                screenshotButton

                                Spacer()

                                micButton
                                sendOrStopButton
