                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        public func updateSessionThinking(_ id: UUID, enabled: Bool) {
                            guard let idx = sessions.firstIndex(where: { $0.id == id }) else { return }
                            sessions[idx].thinkingEnabled = enabled
                            if selectedSession?.id == id { selectedSession = sessions[idx] }
                        }

                        // MARK: Messaging

                        public func sendMessage(_ text: String) async {
                            guard var session = selectedSession else { return }

                            let userMsg = ChatMessage(sessionId: session.id, role: .user, content: text)
                            append(userMsg, to: &session)

                            isSending = true
                            defer { isSending = false }

                            do {
                                // Ensure we have a bridge session ID (create on first message)
                                if session.bridgeSessionId == nil {
                                    let bridgeId = try await createBridgeSession(for: session)
                                    session.bridgeSessionId = bridgeId
                                    // Persist the bridge ID
                                    if let idx = sessions.firstIndex(where: { $0.id == session.id }) {
                                        sessions[idx].bridgeSessionId = bridgeId
                                    }
                                    selectedSession = session
                                }

                                guard let bridgeId = session.bridgeSessionId else {
                                    throw ChatError.noBridgeSession
                                }

                                // Prepend thinking instruction when enabled
                                var messageText = text
                                if session.thinkingEnabled {
                                    messageText = "Think step by step before answering.\n\n\(messageText)"
                                }

                                let result = try await ToolService.shared.call(
                                    tool: "send_message",
                                    arguments: ["session_id": bridgeId, "message": messageText]
                                )

                                // Extract metadata from response tail (if present)
                                let (cleanContent, metadata) = Self.extractMetadata(from: result)
                                if metadata.hasData {
                                    sessionMetadata = metadata
                                }

                                // Parse tool calls and user questions from the response content
                                let toolCalls = Self.parseToolCalls(from: cleanContent)
