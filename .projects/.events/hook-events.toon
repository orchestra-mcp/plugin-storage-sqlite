            new_string: |-
                private struct MiniChatCard: View {
                    let messages: [MiniChatMessage]
                    var isLoading: Bool = false
                    var metadata: SessionMetadata?
                    @ObservedObject var typewriterState: TypewriterState
                    let onDismiss: () -> Void

                    @State private var appeared = false
                    @State private var copied = false

                    private let radius: CGFloat = 16

                    private var latestAssistant: String {
                        if typewriterState.isAnimating { return typewriterState.displayedText }
                        return messages.last(where: { $0.role == .assistant })?.content ?? ""
                    }

                    var body: some View {
                        VStack(alignment: .leading, spacing: 0) {
                            // Header bar: logo + title + skip/copy + dismiss
                            HStack(spacing: 10) {
                                Image("OrchestraLogo")
                                    .resizable()
                                    .scaledToFit()
                                    .frame(width: 20, height: 20)
                                    .colorMultiply(.white)
                                    .brightness(1)

                                Text("Orchestra")
                                    .font(.system(size: 12, weight: .semibold))
                                    .foregroundStyle(.white.opacity(0.70))

                                Spacer()

                                // Skip button (during typewriter)
                                if typewriterState.isAnimating {
                                    Button {
                                        typewriterState.skipToEnd()
                                    } label: {
                                        HStack(spacing: 4) {
                                            Image(systemName: "forward.fill")
                                                .font(.system(size: 10, weight: .medium))
                                            Text("Skip")
                                                .font(.system(size: 11, weight: .medium))
                                        }
                                        .foregroundStyle(.white.opacity(0.55))
                                        .padding(.horizontal, 8)
                                        .padding(.vertical, 4)
                                        .background(.ultraThinMaterial, in: Capsule())
                                        .overlay(Capsule().fill(Color.white.opacity(0.06)))
                                        .overlay(Capsule().strokeBorder(Color.white.opacity(0.12), lineWidth: 0.5))
                                    }
                                    .buttonStyle(.plain)
                                }

                                // Copy last assistant response
                                Button {
                                    let textToCopy = typewriterState.isAnimating ? typewriterState.displayedText : (messages.last(where: { $0.role == .assistant })?.content ?? "")
                                    NSPasteboard.general.clearContents()
                                    NSPasteboard.general.setString(textToCopy, forType: .string)
                                    copied = true
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 1.5) { copied = false }
                                } label: {
                                    HStack(spacing: 4) {
                                        Image(systemName: copied ? "checkmark" : "doc.on.doc")
                                            .font(.system(size: 10, weight: .medium))
                                        Text(copied ? "Copied" : "Copy")
                                            .font(.system(size: 11, weight: .medium))
                                    }
                                    .foregroundStyle(.white.opacity(0.55))
                                    .padding(.horizontal, 8)
                                    .padding(.vertical, 4)
                                    .background(.ultraThinMaterial, in: Capsule())
                                    .overlay(Capsule().fill(Color.white.opacity(0.06)))
                                    .overlay(Capsule().strokeBorder(Color.white.opacity(0.12), lineWidth: 0.5))
                                }
                                .buttonStyle(.plain)
                                .onHover { inside in if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() } }

                                // Dismiss
                                Button(action: onDismiss) {
                                    ZStack {
                                        Circle()
                                            .fill(.ultraThinMaterial)
                                            .frame(width: 24, height: 24)
                                        Circle()
                                            .fill(Color.white.opacity(0.10))
                                            .frame(width: 24, height: 24)
                                        Image(systemName: "xmark")
                                            .font(.system(size: 9, weight: .bold))
                                            .foregroundStyle(Color.white.opacity(0.55))
                                    }
                                }
                                .buttonStyle(.plain)
                                .onHover { inside in if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() } }
                            }
                            .padding(.horizontal, 16)
                            .padding(.top, 12)
                            .padding(.bottom, 8)

                            // Thin divider
                            Rectangle()
                                .fill(Color.white.opacity(0.10))
                                .frame(height: 0.5)
                                .padding(.horizontal, 12)

                            // Scrollable full chat session
                            ScrollViewReader { proxy in
                                ScrollView {
                                    VStack(alignment: .leading, spacing: 8) {
                                        ForEach(Array(messages.enumerated()), id: \.offset) { i, msg in
                                            // For the last assistant message, use typewriter text if animating
                                            if msg.role == .assistant && i == messages.indices.last(where: { messages[$0].role == .assistant }) && typewriterState.isAnimating {
                                                MiniChatBubble(message: MiniChatMessage(role: .assistant, content: typewriterState.displayedText))
                                                    .id(i)
                                            } else {
                                                MiniChatBubble(message: msg)
                                                    .id(i)
                                            }
                                        }

                                        // Typing indicator when loading
                                        if isLoading {
                                            MiniTypingIndicator()
                                                .id("mini-typing")
                                        }
                                    }
                                    .padding(.horizontal, 14)
                                    .padding(.vertical, 10)
                                }
                                .onAppear {
                                    if isLoading {
                                        proxy.scrollTo("mini-typing", anchor: .bottom)
                                    } else if !messages.isEmpty {
                                        proxy.scrollTo(messages.count - 1, anchor: .bottom)
                                    }
                                }
                                .onChange(of: typewriterState.displayedText) { _, _ in
                                    if let lastIdx = messages.indices.last(where: { messages[$0].role == .assistant }) {
                                        proxy.scrollTo(lastIdx, anchor: .bottom)
                                    }
                                }
                            }

                            // Status bar -- shown when metadata is available and not loading
                            if let meta = metadata, meta.hasData, !isLoading, !typewriterState.isAnimating {
                                Rectangle()
                                    .fill(Color.white.opacity(0.10))
                                    .frame(height: 0.5)
                                    .padding(.horizontal, 12)

                                MiniStatusBar(metadata: meta)
                                    .padding(.horizontal, 14)
                                    .padding(.vertical, 6)
                            }
                        }
                        .frame(maxWidth: .infinity, maxHeight: .infinity)
                        .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: radius, style: .continuous))
                        .overlay(RoundedRectangle(cornerRadius: radius, style: .continuous).fill(Color.white.opacity(0.08)))
                        .overlay(RoundedRectangle(cornerRadius: radius, style: .continuous).strokeBorder(Color.white.opacity(0.20), lineWidth: 0.75))
                        .shadow(color: .black.opacity(0.20), radius: 10, x: 0, y: 5)
                        .scaleEffect(appeared ? 1.0 : 0.92, anchor: .bottomTrailing)
                        .opacity(appeared ? 1.0 : 0)
                        .onAppear {
                            withAnimation(.spring(response: 0.30, dampingFraction: 0.75)) { appeared = true }
                        }
                    }
                }
