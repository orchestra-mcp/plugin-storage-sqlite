            originalFile: |
                #if os(macOS)
                import AppKit
                import SwiftUI
                #if !XCODE_BUILD
                import OrchestraKit
                #endif

                // MARK: - ClearHostingView
                // NSHostingView subclass that stays transparent and clips to a live capsule mask.
                // The mask path updates on every layout pass so it tracks the panel resize animation.
                private final class ClearHostingView<Content: View>: NSHostingView<Content> {
                    private let maskLayer = CAShapeLayer()

                    override var isOpaque: Bool { false }

                    override func updateLayer() {
                        super.updateLayer()
                        layer?.backgroundColor = CGColor.clear
                        updateMask()
                    }

                    override func layout() {
                        super.layout()
                        updateMask()
                    }

                    private func updateMask() {
                        guard let layer else { return }
                        let b = layer.bounds
                        // Use capsule radius for bubble (circle), 22pt for expanded card
                        let r = b.height <= 64 ? min(b.width, b.height) / 2 : 22.0
                        maskLayer.path = CGPath(roundedRect: b, cornerWidth: r, cornerHeight: r, transform: nil)
                        layer.mask = maskLayer
                    }
                }

                // MARK: - TransparentPanel
                private final class TransparentPanel: NSPanel {
                    var bubbleMode: Bool = true
                    /// Called during drag with cumulative (dx, dy) delta from drag start.
                    var onDrag: ((_ dx: CGFloat, _ dy: CGFloat) -> Void)?
                    /// Called when drag starts — use to capture companion panel origins.
                    var onDragStart: (() -> Void)?
                    private var dragMouseStart: NSPoint?
                    private var dragOriginStart: NSPoint?
                    private var isDraggingCard: Bool = false
                    // Width of the logo hit zone at the left edge of the expanded card.
                    private let dragZoneWidth: CGFloat = 46
                    // Dock button zone: starts after logo zone, covers the dock button area.
                    // Layout: 20pt pad + 26pt logo + 14pt spacing + 24pt button = 84pt
                    private let dockButtonEnd: CGFloat = 84

                    override var isOpaque: Bool { get { false } set {} }
                    override var canBecomeKey: Bool { true }
                    override var canBecomeMain: Bool { false }

                    override func sendEvent(_ event: NSEvent) {
                        if bubbleMode {
                            // Bubble mode: whole panel is draggable
                            switch event.type {
                            case .leftMouseDown:
                                dragMouseStart = NSEvent.mouseLocation
                                dragOriginStart = frame.origin
                                onDragStart?()
                                super.sendEvent(event)
                            case .leftMouseDragged:
                                guard let start = dragMouseStart, let origin = dragOriginStart else {
                                    super.sendEvent(event); return
                                }
                                let cur = NSEvent.mouseLocation
                                let dx = cur.x - start.x
                                let dy = cur.y - start.y
                                if sqrt(dx*dx + dy*dy) > 4 {
                                    NSCursor.closedHand.set()
                                    setFrameOrigin(NSPoint(x: origin.x + dx, y: origin.y + dy))
                                    onDrag?(dx, dy)
                                }
                            case .leftMouseUp:
                                NSCursor.pointingHand.set()
                                SmartInputWindowManager.shared.savePosition()
                                dragMouseStart = nil
                                dragOriginStart = nil
                                super.sendEvent(event)
                            default:
                                super.sendEvent(event)
                            }
                        } else {
                            // Expanded mode: logo zone (left edge) is tap-to-collapse AND drag-to-move.
                            // Distinguish tap vs drag by tracking movement distance.
                            // Only intercept logo/dock zones in the input row (top portion).
                            // The toolbar row at the bottom needs full pass-through for button clicks.
                            let toolbarVisible = SmartInputState.shared.showQuickActions
                            let toolbarH: CGFloat = toolbarVisible ? 48 : 0
                            switch event.type {
                            case .leftMouseDown:
                                let loc = event.locationInWindow
                                let inToolbarRow = toolbarVisible && loc.y < toolbarH
                                let inLogoZone = loc.x <= dragZoneWidth && !inToolbarRow
                                let inDockZone = loc.x > dragZoneWidth && loc.x <= dockButtonEnd && !inToolbarRow
                                if inLogoZone {
                                    isDraggingCard = true
                                    dragMouseStart = NSEvent.mouseLocation
                                    dragOriginStart = frame.origin
                                    onDragStart?()
                                    super.sendEvent(event)
                                } else if inDockZone && !SmartInputWindowManager.isTrayMode {
                                    // Dock button zone — consume mouseDown, wait for mouseUp to confirm tap
                                    isDraggingCard = false
                                    dragMouseStart = NSEvent.mouseLocation
                                } else {
                                    super.sendEvent(event)
                                }
                            case .leftMouseDragged:
                                if isDraggingCard,
                                   let start = dragMouseStart, let origin = dragOriginStart {
                                    let cur = NSEvent.mouseLocation
                                    let dx = cur.x - start.x
                                    let dy = cur.y - start.y
                                    if sqrt(dx*dx + dy*dy) > 4 {
                                        NSCursor.closedHand.set()
                                        setFrameOrigin(NSPoint(x: origin.x + dx, y: origin.y + dy))
                                        onDrag?(dx, dy)
                                    } else {
                                        super.sendEvent(event)
                                    }
                                } else {
                                    super.sendEvent(event)
                                }
                            case .leftMouseUp:
                                if isDraggingCard {
                                    let cur = NSEvent.mouseLocation
                                    let start = dragMouseStart ?? cur
                                    let dx = cur.x - start.x
                                    let dy = cur.y - start.y
                                    let didDrag = sqrt(dx*dx + dy*dy) > 4
                                    isDraggingCard = false
                                    dragMouseStart = nil
                                    dragOriginStart = nil
                                    if didDrag {
                                        NSCursor.pointingHand.set()
                                        SmartInputWindowManager.shared.savePosition()
                                        super.sendEvent(event)
                                    } else {
                                        // Pure tap on logo zone — spin logo, then collapse
                                        super.sendEvent(event)
                                        NotificationCenter.default.post(name: .orchestraCollapseSmartInput, object: nil)
                                        DispatchQueue.main.asyncAfter(deadline: .now() + 0.25) {
                                            SmartInputWindowManager.shared.collapse()
                                        }
                                    }
                                } else if let start = dragMouseStart {
                                    // Tap in dock button zone — dock back to chat
                                    let cur = NSEvent.mouseLocation
                                    let dx = cur.x - start.x
                                    let dy = cur.y - start.y
                                    let didDrag = sqrt(dx*dx + dy*dy) > 4
                                    dragMouseStart = nil
                                    if !didDrag {
                                        SmartInputWindowManager.shared.dockToChat()
                                    }
                                } else {
                                    super.sendEvent(event)
                                }
                            default:
                                super.sendEvent(event)
                            }
                        }
                    }
                }

                // MARK: - SmartInputWindowManager
                @MainActor
                public final class SmartInputWindowManager: NSObject, ObservableObject {
                    public static let shared = SmartInputWindowManager()

                    private var panel: TransparentPanel?
                    public var chatPlugin: ChatPlugin?
                    private var messagePollingTimer: Timer?
                    private var lastSeenMessageCount: Int = 0
                    private var lastSeenSessionID: UUID? = nil

                    @Published public var isExpanded: Bool = false

                    /// Whether the floating panel (bubble or expanded) is currently visible on screen.
                    public var isPanelVisible: Bool {
                        panel != nil && (panel?.isVisible ?? false)
                    }

                    /// Whether the app is running in tray-only mode (no main window).
                    public static var isTrayMode: Bool = false

                    private var globalHotkeyMonitor: Any?
                    private var localHotkeyMonitor: Any?
                    /// Origin of the SiriResponseWindowManager panel at drag start, for co-movement.
                    private var miniPanelDragOrigin: NSPoint?

                    /// Current screen frame of the bubble panel (used by SiriResponseWindowManager to position the card)
                    public var currentBubbleFrame: NSRect {
                        panel?.frame ?? bubbleRect
                    }

                    private func defaultOrigin() -> CGPoint {
                        let screen = NSScreen.main?.visibleFrame ?? CGRect(x: 0, y: 0, width: 1280, height: 800)
                        // Default: bottom-right corner, bubble sits at right edge
                        return CGPoint(x: screen.maxX - bubbleSize - 20, y: screen.minY + 20)
                    }

                    private var panelOrigin: CGPoint {
                        get {
                            let x = UserDefaults.standard.double(forKey: "smartInput.x")
                            let y = UserDefaults.standard.double(forKey: "smartInput.y")
                            guard x != 0 || y != 0 else { return defaultOrigin() }
                            let origin = CGPoint(x: x, y: y)
                            let testRect = NSRect(origin: origin, size: CGSize(width: bubbleSize, height: bubbleSize))
                            let onScreen = NSScreen.screens.contains { $0.frame.intersects(testRect) }
                            return onScreen ? origin : defaultOrigin()
                        }
                        set {
                            UserDefaults.standard.set(newValue.x, forKey: "smartInput.x")
                            UserDefaults.standard.set(newValue.y, forKey: "smartInput.y")
                        }
                    }

                    let bubbleSize: CGFloat = 64
                    private let expandedWidth: CGFloat = 700

                    private var expandedHeight: CGFloat {
                        var h: CGFloat = 60  // text field row (14pt padding top/bottom + 30pt content + 2pt safety)
                        let state = SmartInputState.shared
                        if state.showQuickActions {
                            h += 48  // quick actions row: 1pt divider + 6pt pad top + 28pt buttons + 6pt pad bottom + 7pt extra
                        }
                        if state.activeTrigger != nil {
                            // Trigger autocomplete: header + result rows (up to 6 x 28pt)
                            let rows = min(state.triggerResults.count, 6)
                            h += 28 + CGFloat(max(rows, 1)) * 28
                        }
                        return h
                    }

                    private var bubbleRect: NSRect {
                        let o = panelOrigin
                        return NSRect(x: o.x, y: o.y, width: bubbleSize, height: bubbleSize)
                    }

                    public func setup(chatPlugin: ChatPlugin?) {
                        self.chatPlugin = chatPlugin
                        // Only create the floating panel when detached.
                        // In docked mode the input bar lives inside ChatDetailView.
                        if SmartInputState.shared.isDetached {
                            createPanelIfNeeded()
                        }
                        startPollingIfNeeded()

                        NotificationCenter.default.addObserver(
                            forName: .orchestraInputHeightChanged,
                            object: nil,
                            queue: .main
                        ) { [weak self] _ in
                            Task { @MainActor in
                                self?.resizeIfNeeded()
                            }
                        }
                    }

                    private func startPollingIfNeeded() {
                        guard messagePollingTimer == nil else { return }
                        let timer = Timer(timeInterval: 0.5, repeats: true) { [weak self] _ in
                            Task { @MainActor [weak self] in
                                self?.pollMessages()
                            }
                        }
                        RunLoop.main.add(timer, forMode: .common)
                        messagePollingTimer = timer
                    }

                    private func pollMessages() {
                        guard let plugin = chatPlugin else { return }
                        guard let session = plugin.selectedSession else {
                            lastSeenMessageCount = 0
                            lastSeenSessionID = nil
                            return
                        }

                        // If session changed, reset the baseline
                        if session.id != lastSeenSessionID {
                            lastSeenSessionID = session.id
                            lastSeenMessageCount = session.messages.filter { $0.role == .assistant }.count
                            return
                        }

                        let newCount = session.messages.filter { $0.role == .assistant }.count
                        guard newCount > lastSeenMessageCount else { return }
                        lastSeenMessageCount = newCount

                        // Don't show card when the chat window is open and visible
                        let chatIsOpen = SmartInputState.shared.activeChatPlugin != nil
                        guard !chatIsOpen else { return }

                        SiriResponseWindowManager.shared.showChat(session: session, bubbleManager: self)
                    }

                    public func expand() {
                        guard let p = panel else { return }
                        isExpanded = true
                        SiriResponseWindowManager.shared.dismiss()
                        p.bubbleMode = false

                        // Expand leftward: RIGHT edge stays fixed at bubble's right edge.
                        // Card grows to the left. The logo ends up at the left end of the card.
                        let bubbleRight = p.frame.maxX
                        let cy = p.frame.midY
                        let startRect = p.frame
                        let newRect = NSRect(
                            x: bubbleRight - expandedWidth,
                            y: cy - expandedHeight / 2,
                            width: expandedWidth,
                            height: expandedHeight
                        )

                        // Hide during content swap to avoid flash.
                        p.alphaValue = 0
                        p.setFrame(newRect, display: false)
                        refreshContent(panel: p)
                        p.setFrame(startRect, display: false)
                        p.makeKeyAndOrderFront(nil)
                        p.alphaValue = 1

                        NSAnimationContext.runAnimationGroup { ctx in
                            ctx.duration = 0.30
                            ctx.timingFunction = CAMediaTimingFunction(name: .easeInEaseOut)
                            p.animator().setFrame(newRect, display: true)
                        }

                        DispatchQueue.main.asyncAfter(deadline: .now() + 0.34) {
                            NotificationCenter.default.post(name: .orchestraActivateSmartInput, object: nil)
                        }
                    }

                    public func collapse() {
                        guard let p = panel, isExpanded else { return }
                        // Keep isExpanded = true so SwiftUI keeps rendering the expanded card
                        // during the shrink animation. Flip it only after the animation ends.
                        SmartInputState.shared.text = ""

                        // Collapse rightward: RIGHT edge stays fixed, width shrinks back to bubble.
                        let cardRight = p.frame.maxX
                        let cy = p.frame.midY
                        let newOrigin = CGPoint(x: cardRight - bubbleSize, y: cy - bubbleSize / 2)
                        let newRect = NSRect(x: newOrigin.x, y: newOrigin.y, width: bubbleSize, height: bubbleSize)
                        panelOrigin = newOrigin

                        // Shrink the card back into the bubble position (mirrors the expand animation)
                        NSAnimationContext.runAnimationGroup { ctx in
                            ctx.duration = 0.30
                            ctx.timingFunction = CAMediaTimingFunction(name: .easeInEaseOut)
                            p.animator().setFrame(newRect, display: true)
                        } completionHandler: { [weak self] in
                            guard let self else { return }
                            DispatchQueue.main.async {
                                self.isExpanded = false
                                p.alphaValue = 0
                                p.bubbleMode = true
                                self.refreshContent(panel: p)
                                p.alphaValue = 1
                                p.orderFrontRegardless()
                            }
                        }
                    }

                    /// Fully hide and destroy the floating panel (used when re-docking).
                    public func dismissPanel() {
                        guard let p = panel else { return }
                        SmartInputState.shared.text = ""
                        NSAnimationContext.runAnimationGroup { ctx in
                            ctx.duration = 0.20
                            ctx.timingFunction = CAMediaTimingFunction(name: .easeIn)
                            p.animator().alphaValue = 0
                        } completionHandler: { [weak self] in
                            guard let self else { return }
                            DispatchQueue.main.async {
                                p.orderOut(nil)
                                self.panel = nil
                                self.isExpanded = false
                            }
                        }
                    }

                    /// Dock the floating panel back into the chat view.
                    /// Hides the panel immediately, then flips `isDetached` so ChatDetailView
                    /// shows the docked bar. The state change happens *after* the panel is
                    /// torn down to avoid the SwiftUI view being destroyed mid-update.
                    public func dockToChat() {
                        guard let p = panel else {
                            SmartInputState.shared.isDetached = false
                            return
                        }
                        SmartInputState.shared.text = ""
                        // Immediately hide the panel (no animation delay that could race)
                        p.alphaValue = 0
                        p.orderOut(nil)
                        self.panel = nil
                        self.isExpanded = false
                        // Now that the panel is fully gone, flip the state so ChatDetailView
                        // picks up the change and shows the docked bar.
                        withAnimation(.spring(response: 0.35, dampingFraction: 0.82)) {
                            SmartInputState.shared.isDetached = false
                        }
                    }

                    public func savePosition() {
                        if let p = panel {
                            panelOrigin = p.frame.origin
                        }
                    }

                    /// Resize the expanded panel when toolbar content changes height.
                    /// Uses instant (non-animated) frame change to avoid NSHostingView crash
                    /// where SwiftUI animations collide with AppKit's layout pass.
                    public func resizeIfNeeded() {
                        guard let p = panel, isExpanded else { return }
                        let newHeight = expandedHeight
                        let currentFrame = p.frame
                        guard abs(currentFrame.height - newHeight) > 1 else { return }

                        // Keep right edge fixed, grow/shrink upward from bottom edge
                        let newRect = NSRect(
                            x: currentFrame.origin.x,
                            y: currentFrame.maxY - newHeight,
                            width: expandedWidth,
                            height: newHeight
                        )

                        // Instant resize — no NSAnimationContext. Animated resize triggers
                        // NSHostingView.updateAnimatedWindowSize which crashes during layout.
                        p.setFrame(newRect, display: true)
                    }

                    public func openPanel(chatPlugin: ChatPlugin?) {
                        self.chatPlugin = chatPlugin
                        SmartInputState.shared.isDetached = true
                        createPanelIfNeeded()
                        if !isExpanded { expand() }
                    }

                    /// Toggle the floating panel: if visible → fully hide (destroy panel); if hidden → show and expand.
                    public func togglePanel() {
                        if let p = panel, p.isVisible {
                            // Fully hide — destroy the panel so isPanelVisible becomes false
                            dismissPanel()
                        } else {
                            SmartInputState.shared.isDetached = true
                            createPanelIfNeeded()
                            expand()
                        }
                    }

                    /// Show the bubble on app launch (tray-only mode). Does not expand.
                    public func showOnLaunch() {
                        SmartInputState.shared.isDetached = true
                        createPanelIfNeeded()
                    }

                    /// Register global Cmd+K hotkey that works even when the app has no focused window.
                    public func registerGlobalHotkey() {
                        // Global monitor: fires when the app is NOT frontmost
                        globalHotkeyMonitor = NSEvent.addGlobalMonitorForEvents(matching: .keyDown) { [weak self] event in
                            if event.modifierFlags.contains(.command) && event.charactersIgnoringModifiers == "k" {
                                Task { @MainActor [weak self] in
                                    NSApp.activate(ignoringOtherApps: true)
                                    self?.togglePanel()
                                }
                            }
                        }
                        // Local monitor: fires when the app IS frontmost
                        localHotkeyMonitor = NSEvent.addLocalMonitorForEvents(matching: .keyDown) { [weak self] event in
                            if event.modifierFlags.contains(.command) && event.charactersIgnoringModifiers == "k" {
                                Task { @MainActor [weak self] in
                                    self?.togglePanel()
                                }
                                return nil // consume the event
                            }
                            return event
                        }
                    }

                    /// Remove global hotkey monitors.
                    public func removeGlobalHotkey() {
                        if let monitor = globalHotkeyMonitor {
                            NSEvent.removeMonitor(monitor)
                            globalHotkeyMonitor = nil
                        }
                        if let monitor = localHotkeyMonitor {
                            NSEvent.removeMonitor(monitor)
                            localHotkeyMonitor = nil
                        }
                    }

                    private func createPanelIfNeeded() {
                        guard panel == nil else { return }

                        let p = TransparentPanel(
                            contentRect: bubbleRect,
                            styleMask: [.nonactivatingPanel, .borderless],
                            backing: .buffered,
                            defer: false
                        )
                        p.level = .floating
                        p.isOpaque = false
                        p.backgroundColor = .clear
                        p.hasShadow = false
                        p.appearance = NSAppearance(named: .vibrantDark)
                        p.collectionBehavior = [.canJoinAllSpaces, .fullScreenAuxiliary]
                        p.isMovableByWindowBackground = false
                        p.bubbleMode = true

                        // Co-move the mini-chat card when dragging the input bar
                        p.onDragStart = { [weak self] in
                            self?.miniPanelDragOrigin = SiriResponseWindowManager.shared.panel?.frame.origin
                        }
                        p.onDrag = { [weak self] dx, dy in
                            guard let self, let origin = self.miniPanelDragOrigin,
                                  let miniPanel = SiriResponseWindowManager.shared.panel,
                                  miniPanel.isVisible else { return }
                            miniPanel.setFrameOrigin(NSPoint(x: origin.x + dx, y: origin.y + dy))
                        }

                        refreshContent(panel: p)
                        p.orderFrontRegardless()

                        self.panel = p
                    }

                    private func refreshContent(panel: TransparentPanel) {
                        let size = panel.frame.size
                        let bounds = NSRect(origin: .zero, size: size)

                        // Use a plain clear NSView as root — SwiftUI's .ultraThinMaterial handles
                        // all glass rendering. No NSVisualEffectView tint/rect bleeds through.
                        let hosting = ClearHostingView(rootView: SmartFloatingContent(manager: self, chatPlugin: chatPlugin))
                        hosting.frame = bounds
                        hosting.autoresizingMask = [NSView.AutoresizingMask.width, .height]
                        // Force dark appearance so .ultraThinMaterial renders as dark frosted glass
                        hosting.appearance = NSAppearance(named: .vibrantDark)
                        panel.contentView = hosting
                    }

                }

                // MARK: - Notification name

                extension Notification.Name {
                    static let siriResponseNewMessage = Notification.Name("orchestra.siriResponseNewMessage")
                    static let orchestraInputHeightChanged = Notification.Name("orchestra.inputHeightChanged")
                }

                // MARK: - ClickablePanel
                // NSPanel subclass for the mini-chat card.
                // Intercepts leftMouseUp in the dismiss button zone (rightmost 50pt) and fires
                // the dismiss notification directly — no need to become key, so the user's app
                // keeps focus.
                private final class ClickablePanel: NSPanel {
                    /// Called by SiriResponseWindowManager so the panel can fire dismissal.
                    var onDismiss: (() -> Void)?

                    override var canBecomeKey: Bool { false }
                    override var canBecomeMain: Bool { false }
                    override var isOpaque: Bool { get { false } set {} }

                    private let dismissZoneWidth: CGFloat = 50

                    override func sendEvent(_ event: NSEvent) {
                        if event.type == .leftMouseUp {
                            let loc = event.locationInWindow
                            if loc.x >= frame.width - dismissZoneWidth {
                                onDismiss?()
                                return   // consumed — don't forward to SwiftUI
                            }
                        }
                        super.sendEvent(event)
                    }
                }

                // MARK: - TypewriterState

                @MainActor
                final class TypewriterState: ObservableObject {
                    @Published var displayedText: String = ""
                    @Published var isAnimating: Bool = false

                    private var fullText: String = ""
                    private var currentIndex: String.Index?
                    private var timer: Timer?
                    private var charCount: Int = 0

                    func startTypewriter(fullText: String) {
                        self.fullText = fullText
                        self.displayedText = ""
                        self.currentIndex = fullText.startIndex
                        self.charCount = 0
                        self.isAnimating = true

                        timer?.invalidate()
                        timer = Timer.scheduledTimer(withTimeInterval: 0.016, repeats: true) { [weak self] _ in
                            Task { @MainActor [weak self] in
                                self?.advance()
                            }
                        }
                    }

                    func skipToEnd() {
                        timer?.invalidate()
                        timer = nil
                        displayedText = fullText
                        isAnimating = false
                    }

                    func reset() {
                        timer?.invalidate()
                        timer = nil
                        displayedText = ""
                        fullText = ""
                        isAnimating = false
                    }

                    private func advance() {
                        guard var idx = currentIndex, idx < fullText.endIndex else {
                            timer?.invalidate()
                            timer = nil
                            isAnimating = false
                            return
                        }

                        // Ramp speed: 3 chars/tick for first 200 chars, then 6 chars/tick
                        let charsPerTick = charCount > 200 ? 6 : 3

                        for _ in 0..<charsPerTick {
                            guard idx < fullText.endIndex else { break }
                            idx = fullText.index(after: idx)
                            charCount += 1
                        }

                        currentIndex = idx
                        displayedText = String(fullText[fullText.startIndex..<idx])
                    }
                }

                // MARK: - SiriResponseWindowManager
                // Manages the floating mini-chat card above the bubble for background message notifications.

                @MainActor
                final class SiriResponseWindowManager: NSObject, ObservableObject {
                    static let shared = SiriResponseWindowManager()

                    fileprivate var panel: ClickablePanel?
                    private var dismissTimer: Timer?

                    @Published var isMiniPanelVisible: Bool = false
                    @Published var isLoading: Bool = false
                    var currentMetadata: SessionMetadata?
                    let typewriterState = TypewriterState()

                    /// Show mini panel immediately with user message + loading indicator.
                    func showPendingChat(session: ChatSession, bubbleManager: SmartInputWindowManager) {
                        let messages = session.messages
                            .filter { $0.role != .system }
                            .map { MiniChatMessage(role: $0.role == .user ? .user : .assistant, content: $0.content) }
                        isLoading = true
                        currentMetadata = nil
                        typewriterState.reset()
                        showMessages(messages, bubbleManager: bubbleManager)
                    }

                    func showChat(session: ChatSession, bubbleManager: SmartInputWindowManager, metadata: SessionMetadata? = nil) {
                        let messages = session.messages
                            .filter { $0.role != .system }
                            .map { MiniChatMessage(role: $0.role == .user ? .user : .assistant, content: $0.content) }
                        guard !messages.isEmpty else { return }
                        isLoading = false
                        currentMetadata = metadata

                        // Start typewriter for the latest assistant message
                        if let lastAssistant = messages.last(where: { $0.role == .assistant }) {
                            typewriterState.startTypewriter(fullText: lastAssistant.content)
                        }

                        showMessages(Array(messages), bubbleManager: bubbleManager)
                    }

                    func showMessages(_ messages: [MiniChatMessage], bubbleManager: SmartInputWindowManager) {
                        dismissTimer?.invalidate()
                        dismissTimer = nil
                        guard !messages.isEmpty else { return }
                        createOrUpdate(messages: messages, bubbleManager: bubbleManager)
                    }

                    func dismiss() {
                        dismissTimer?.invalidate()
                        dismissTimer = nil
                        typewriterState.skipToEnd()
                        guard let p = panel else { return }
                        NSAnimationContext.runAnimationGroup { ctx in
                            ctx.duration = 0.22
                            ctx.timingFunction = CAMediaTimingFunction(name: .easeIn)
                            p.animator().alphaValue = 0
                        } completionHandler: { [weak self] in
                            p.orderOut(nil)
                            self?.isMiniPanelVisible = false
                        }
                    }

                    private func createOrUpdate(messages: [MiniChatMessage], bubbleManager: SmartInputWindowManager) {
                        // Full markdown card: 700 wide, up to 360 tall, rounded rect
                        let cardW: CGFloat = 700
                        let cardH: CGFloat = 360
                        let bf = bubbleManager.currentBubbleFrame
                        // Right-edge aligned with bubble right edge, positioned above the bubble
                        let x = bf.maxX - cardW
                        let y = bf.maxY + 12
                        let rect = NSRect(x: x, y: y, width: cardW, height: cardH)

                        if panel == nil {
                            let p = ClickablePanel(
                                contentRect: rect,
                                styleMask: [.nonactivatingPanel, .borderless],
                                backing: .buffered,
                                defer: false
                            )
                            p.level = .floating
                            p.isOpaque = false
                            p.backgroundColor = .clear
                            p.hasShadow = false
                            p.appearance = NSAppearance(named: .vibrantDark)
                            p.collectionBehavior = [.canJoinAllSpaces, .fullScreenAuxiliary]
                            p.onDismiss = { [weak self] in self?.dismiss() }
                            panel = p
                        }

                        guard let p = panel else { return }
                        let mgr = SiriResponseWindowManager.shared
                        let hosting = NSHostingView(rootView: MiniChatCard(
                            messages: messages,
                            isLoading: mgr.isLoading,
                            metadata: mgr.currentMetadata,
                            typewriterState: mgr.typewriterState
                        ) {
                            SiriResponseWindowManager.shared.dismiss()
                        })
                        hosting.frame = NSRect(origin: .zero, size: CGSize(width: cardW, height: cardH))
                        hosting.appearance = NSAppearance(named: .vibrantDark)
                        p.contentView = hosting
                        p.setFrame(rect, display: false)
                        p.alphaValue = 0
                        p.orderFrontRegardless()
                        NSAnimationContext.runAnimationGroup { ctx in
                            ctx.duration = 0.28
                            ctx.timingFunction = CAMediaTimingFunction(name: .easeOut)
                            p.animator().alphaValue = 1
                        }
                        isMiniPanelVisible = true
                    }
                }

                // MARK: - MiniChatMessage

                struct MiniChatMessage {
                    enum Role { case user, assistant }
                    let role: Role
                    let content: String
                }

                // MARK: - MiniChatCard
                // Full chat session card: 560×360, rounded rect, glass style.
                // Shows the full conversation with markdown rendering for assistant messages,
                // a copy button for the last response, and a dismiss button.

                private struct MiniChatCard: View {
                    let messages: [MiniChatMessage]
                    let onDismiss: () -> Void

                    @State private var appeared = false
                    @State private var copied = false

                    private let radius: CGFloat = 16

                    private var latestAssistant: String {
                        messages.last(where: { $0.role == .assistant })?.content ?? ""
                    }

                    var body: some View {
                        VStack(alignment: .leading, spacing: 0) {
                            // Header bar: logo + title + copy + dismiss
                            HStack(spacing: 10) {
                                Image("OrchestraLogo")
                                    .resizable()
                                    .scaledToFit()
                                    .frame(width: 20, height: 20)
                                    .colorMultiply(.white)
                                    .brightness(1)

                                Text("Orchestra")
                                    .font(.system(size: 12, weight: .semibold))
                                    .foregroundStyle(.white.opacity(0.70))

                                Spacer()

                                // Copy last assistant response
                                Button {
                                    NSPasteboard.general.clearContents()
                                    NSPasteboard.general.setString(latestAssistant, forType: .string)
                                    copied = true
                                    DispatchQueue.main.asyncAfter(deadline: .now() + 1.5) { copied = false }
                                } label: {
                                    HStack(spacing: 4) {
                                        Image(systemName: copied ? "checkmark" : "doc.on.doc")
                                            .font(.system(size: 10, weight: .medium))
                                        Text(copied ? "Copied" : "Copy")
                                            .font(.system(size: 11, weight: .medium))
                                    }
                                    .foregroundStyle(.white.opacity(0.55))
                                    .padding(.horizontal, 8)
                                    .padding(.vertical, 4)
                                    .background(.ultraThinMaterial, in: Capsule())
                                    .overlay(Capsule().fill(Color.white.opacity(0.06)))
                                    .overlay(Capsule().strokeBorder(Color.white.opacity(0.12), lineWidth: 0.5))
                                }
                                .buttonStyle(.plain)
                                .onHover { inside in if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() } }

                                // Dismiss
                                Button(action: onDismiss) {
                                    ZStack {
                                        Circle()
                                            .fill(.ultraThinMaterial)
                                            .frame(width: 24, height: 24)
                                        Circle()
                                            .fill(Color.white.opacity(0.10))
                                            .frame(width: 24, height: 24)
                                        Image(systemName: "xmark")
                                            .font(.system(size: 9, weight: .bold))
                                            .foregroundStyle(Color.white.opacity(0.55))
                                    }
                                }
                                .buttonStyle(.plain)
                                .onHover { inside in if inside { NSCursor.pointingHand.push() } else { NSCursor.pop() } }
                            }
                            .padding(.horizontal, 16)
                            .padding(.top, 12)
                            .padding(.bottom, 8)

                            // Thin divider
                            Rectangle()
                                .fill(Color.white.opacity(0.10))
                                .frame(height: 0.5)
                                .padding(.horizontal, 12)

                            // Scrollable full chat session
                            ScrollViewReader { proxy in
                                ScrollView {
                                    VStack(alignment: .leading, spacing: 8) {
                                        ForEach(Array(messages.enumerated()), id: \.offset) { i, msg in
                                            MiniChatBubble(message: msg)
                                                .id(i)
                                        }
                                    }
                                    .padding(.horizontal, 14)
                                    .padding(.vertical, 10)
                                }
                                .onAppear {
                                    // Scroll to the last message
                                    if !messages.isEmpty {
                                        proxy.scrollTo(messages.count - 1, anchor: .bottom)
                                    }
                                }
                            }
                        }
                        .frame(maxWidth: .infinity, maxHeight: .infinity)
                        .background(.ultraThinMaterial, in: RoundedRectangle(cornerRadius: radius, style: .continuous))
                        .overlay(RoundedRectangle(cornerRadius: radius, style: .continuous).fill(Color.white.opacity(0.08)))
                        .overlay(RoundedRectangle(cornerRadius: radius, style: .continuous).strokeBorder(Color.white.opacity(0.20), lineWidth: 0.75))
                        .shadow(color: .black.opacity(0.20), radius: 10, x: 0, y: 5)
                        .scaleEffect(appeared ? 1.0 : 0.92, anchor: .bottomTrailing)
                        .opacity(appeared ? 1.0 : 0)
                        .onAppear {
                            withAnimation(.spring(response: 0.30, dampingFraction: 0.75)) { appeared = true }
                        }
                    }
                }

                // MARK: - MiniChatBubble (for floating card)

                private struct MiniChatBubble: View {
                    let message: MiniChatMessage
                    private var isUser: Bool { message.role == .user }

                    var body: some View {
                        HStack(alignment: .top, spacing: 0) {
                            if isUser { Spacer(minLength: 40) }
                            VStack(alignment: isUser ? .trailing : .leading, spacing: 0) {
                                if isUser {
                                    Text(message.content)
                                        .font(.system(size: 12.5))
                                        .foregroundStyle(.white)
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 6)
                                        .background(Color.accentColor.opacity(0.85))
                                        .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                                        .textSelection(.enabled)
                                } else {
                                    MarkdownContentView(markdown: message.content)
                                        .padding(.horizontal, 10)
                                        .padding(.vertical, 6)
                                        .background(Color.white.opacity(0.08))
                                        .clipShape(RoundedRectangle(cornerRadius: 12, style: .continuous))
                                }
                            }
                            if !isUser { Spacer(minLength: 40) }
                        }
                    }
                }
                #endif
