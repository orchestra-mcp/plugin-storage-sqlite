                    ```vala
                    // Standard Linux paths
                    namespace Orchestra.Paths {
                        public string config_dir () {
                            // ~/.config/orchestra/
                            return Path.build_filename (Environment.get_user_config_dir (), "orchestra");
                        }

                        public string data_dir () {
