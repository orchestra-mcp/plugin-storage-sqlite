                      },
            originalFile: |
                'use client'
                import { create } from 'zustand'
                import { persist } from 'zustand/middleware'
                import { apiFetch } from '@/lib/api'

                export type Role = 'admin' | 'team_owner' | 'team_manager' | 'user'

                export interface TeamMember {
                  id: number
                  name: string
                  email: string
                  role: Role
                  avatar_url?: string | null
                  joined_at: string
                  status: 'active' | 'invited' | 'suspended'
                }

                export interface Team {
                  id: string
                  name: string
                  slug: string
                  description?: string
                  plan: 'free' | 'pro' | 'enterprise'
                  member_count: number
                  created_at: string
                  owner_id: number
                }

                export interface RolePermissions {
                  canManageUsers: boolean
                  canManageRoles: boolean
                  canManageTeam: boolean
                  canViewAdmin: boolean
                  canInviteMembers: boolean
                  canRemoveMembers: boolean
                  canChangeRoles: boolean
                  canViewBilling: boolean
                  canManageBilling: boolean
                  canDeleteTeam: boolean
                }

                export const ROLE_PERMISSIONS: Record<Role, RolePermissions> = {
                  admin: {
                    canManageUsers: true,
                    canManageRoles: true,
                    canManageTeam: true,
                    canViewAdmin: true,
                    canInviteMembers: true,
                    canRemoveMembers: true,
                    canChangeRoles: true,
                    canViewBilling: true,
                    canManageBilling: true,
                    canDeleteTeam: true,
                  },
                  team_owner: {
                    canManageUsers: false,
                    canManageRoles: false,
                    canManageTeam: true,
                    canViewAdmin: false,
                    canInviteMembers: true,
                    canRemoveMembers: true,
                    canChangeRoles: true,
                    canViewBilling: true,
                    canManageBilling: true,
                    canDeleteTeam: true,
                  },
                  team_manager: {
                    canManageUsers: false,
                    canManageRoles: false,
                    canManageTeam: false,
                    canViewAdmin: false,
                    canInviteMembers: true,
                    canRemoveMembers: false,
                    canChangeRoles: false,
                    canViewBilling: false,
                    canManageBilling: false,
                    canDeleteTeam: false,
                  },
                  user: {
                    canManageUsers: false,
                    canManageRoles: false,
                    canManageTeam: false,
                    canViewAdmin: false,
                    canInviteMembers: false,
                    canRemoveMembers: false,
                    canChangeRoles: false,
                    canViewBilling: false,
                    canManageBilling: false,
                    canDeleteTeam: false,
                  },
                }

                export const ROLE_LABELS: Record<Role, string> = {
                  admin: 'Admin',
                  team_owner: 'Team Owner',
                  team_manager: 'Team Manager',
                  user: 'User',
                }

                export const ROLE_COLORS: Record<Role, { bg: string; color: string; border: string }> = {
                  admin: { bg: 'rgba(239,68,68,0.1)', color: '#ef4444', border: 'rgba(239,68,68,0.25)' },
                  team_owner: { bg: 'rgba(169,0,255,0.1)', color: '#a900ff', border: 'rgba(169,0,255,0.25)' },
                  team_manager: { bg: 'rgba(0,229,255,0.1)', color: '#00e5ff', border: 'rgba(0,229,255,0.25)' },
                  user: { bg: 'rgba(128,128,128,0.1)', color: 'rgba(128,128,128,0.8)', border: 'rgba(128,128,128,0.2)' },
                }

                // Seed data for dev/demo — realistic mock users and team
                const SEED_USERS: TeamMember[] = [
                  { id: 1, name: 'Alice Admin', email: 'admin@orchestra.dev', role: 'admin', joined_at: '2024-01-01T00:00:00Z', status: 'active' },
                  { id: 2, name: 'Owen Owner', email: 'owner@orchestra.dev', role: 'team_owner', joined_at: '2024-01-05T00:00:00Z', status: 'active' },
                  { id: 3, name: 'Mia Manager', email: 'manager@orchestra.dev', role: 'team_manager', joined_at: '2024-02-10T00:00:00Z', status: 'active' },
                  { id: 4, name: 'Bob Builder', email: 'bob@orchestra.dev', role: 'user', joined_at: '2024-03-01T00:00:00Z', status: 'active' },
                  { id: 5, name: 'Sam Spencer', email: 'sam@orchestra.dev', role: 'user', joined_at: '2024-03-15T00:00:00Z', status: 'invited' },
                  { id: 6, name: 'Zoe Zhang', email: 'zoe@orchestra.dev', role: 'user', joined_at: '2024-04-01T00:00:00Z', status: 'suspended' },
                  { id: 7, name: 'Carlos Cruz', email: 'carlos@orchestra.dev', role: 'team_manager', joined_at: '2024-04-10T00:00:00Z', status: 'active' },
                  { id: 8, name: 'Dana Doe', email: 'dana@orchestra.dev', role: 'user', joined_at: '2024-05-01T00:00:00Z', status: 'active' },
                ]

                const SEED_TEAM: Team = {
                  id: 'team_orchestra_dev_01',
                  name: 'Orchestra Dev',
                  slug: 'orchestra-dev',
                  description: 'Core product team building the Orchestra platform.',
                  plan: 'pro',
                  member_count: 8,
                  created_at: '2024-01-01T00:00:00Z',
                  owner_id: 2,
                }

                interface RolesState {
                  currentRole: Role
                  roleLoaded: boolean       // true once fetchMyRole has resolved at least once
                  team: Team | null
                  teams: Team[]             // all teams the user belongs to
                  members: TeamMember[]
                  allUsers: TeamMember[]  // admin view
                  loading: boolean
                  error: string | null
                }

                interface RolesActions {
                  setCurrentRole: (role: Role) => void  // dev/demo helper
                  seedAdmin: () => void                 // inject seed data + set role to admin (dev/demo)
                  fetchMyRole: () => Promise<void>
                  fetchTeam: () => Promise<void>
                  fetchAllTeams: () => Promise<void>    // fetch all teams user belongs to
                  fetchMembers: () => Promise<void>
                  fetchAllUsers: () => Promise<void>  // admin only
                  inviteMember: (email: string, role: Role) => Promise<void>
                  updateMemberRole: (memberId: number, role: Role) => Promise<void>
                  removeMember: (memberId: number) => Promise<void>
                  suspendUser: (userId: number) => Promise<void>
                  unsuspendUser: (userId: number) => Promise<void>
                  updateTeam: (data: Partial<Pick<Team, 'name' | 'description'>>) => Promise<void>
                  clearError: () => void
                  can: (permission: keyof RolePermissions) => boolean
                }

                export const useRoleStore = create<RolesState & RolesActions>()(
                  persist(
                    (set, get) => ({
                      currentRole: 'user',
                      roleLoaded: false,
                      team: null,
                      teams: [],
                      members: [],
                      allUsers: [],
                      loading: false,
                      error: null,

                      setCurrentRole: (role) => set({ currentRole: role }),

                      seedAdmin: () => {
                        set({
                          currentRole: 'admin',
                          roleLoaded: true,
                          allUsers: SEED_USERS,
                          members: SEED_USERS.filter(u => u.status !== 'suspended'),
                          team: SEED_TEAM,
                        })
                      },

                      can: (permission) => ROLE_PERMISSIONS[get().currentRole][permission],

                      fetchMyRole: async () => {
                        // Skip API call for dev seed sessions — role is already set
                        const token = typeof window !== 'undefined' ? localStorage.getItem('orchestra_token') : null
                        if (token === 'dev_seed_token') {
                          set({ roleLoaded: true })
                          return
                        }
                        try {
                          const res = await apiFetch<{ role: Role }>('/api/auth/me/role')
                          set({ currentRole: res.role, roleLoaded: true })
                        } catch {
                          // On error (e.g. no backend), keep existing role but mark as loaded
                          set({ roleLoaded: true })
                        }
                      },

                      fetchTeam: async () => {
                        set({ loading: true, error: null })
                        try {
                          const res = await apiFetch<Team | { team: Team }>('/api/team')
                          const team = ('team' in res && res.team) ? res.team : res as Team
                          set({ team, loading: false })
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); return }
                          set({ error: (e as Error).message, loading: false })
                        }
                      },

                      fetchAllTeams: async () => {
                        try {
                          const res = await apiFetch<Team[] | { teams: Team[] }>('/api/teams/')
                          const teams = Array.isArray(res) ? res : (res.teams ?? [])
                          set({ teams, team: teams[0] ?? get().team })
                        } catch (e) {
                          if ((e as any).devSeed) return
                          // Non-fatal: keep existing teams
                        }
                      },

                      fetchMembers: async () => {
                        set({ loading: true, error: null })
                        try {
                          const res = await apiFetch<{ members: TeamMember[] }>('/api/team/members')
                          set({ members: res.members, loading: false })
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); return }
                          set({ error: (e as Error).message, loading: false })
                        }
                      },

                      fetchAllUsers: async () => {
                        set({ loading: true, error: null })
                        try {
                          const res = await apiFetch<{ users: TeamMember[] }>('/api/admin/users')
                          set({ allUsers: res.users, loading: false })
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); return }
                          set({ error: (e as Error).message, loading: false })
                        }
                      },

                      inviteMember: async (email, role) => {
                        set({ loading: true, error: null })
                        const teamId = get().team?.id
                        if (!teamId) { set({ error: 'No team found', loading: false }); throw new Error('No team found') }
                        try {
                          await apiFetch(`/api/teams/${teamId}/invite`, {
                            method: 'POST',
                            body: JSON.stringify({ email, role }),
                          })
                          set({ loading: false })
                          await get().fetchMembers()
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      updateMemberRole: async (memberId, role) => {
                        set({ loading: true, error: null })
                        try {
                          await apiFetch(`/api/team/members/${memberId}/role`, {
                            method: 'PATCH',
                            body: JSON.stringify({ role }),
                          })
                          set(state => ({
                            members: state.members.map(m => m.id === memberId ? { ...m, role } : m),
                            allUsers: state.allUsers.map(m => m.id === memberId ? { ...m, role } : m),
                            loading: false,
                          }))
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      removeMember: async (memberId) => {
                        set({ loading: true, error: null })
                        try {
                          await apiFetch(`/api/team/members/${memberId}`, { method: 'DELETE' })
                          set(state => ({
                            members: state.members.filter(m => m.id !== memberId),
                            loading: false,
                          }))
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      suspendUser: async (userId) => {
                        set({ loading: true, error: null })
                        try {
                          await apiFetch(`/api/admin/users/${userId}/suspend`, { method: 'POST' })
                          set(state => ({
                            allUsers: state.allUsers.map(u => u.id === userId ? { ...u, status: 'suspended' as const } : u),
                            loading: false,
                          }))
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      unsuspendUser: async (userId) => {
                        set({ loading: true, error: null })
                        try {
                          await apiFetch(`/api/admin/users/${userId}/unsuspend`, { method: 'POST' })
                          set(state => ({
                            allUsers: state.allUsers.map(u => u.id === userId ? { ...u, status: 'active' as const } : u),
                            loading: false,
                          }))
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      updateTeam: async (data) => {
                        set({ loading: true, error: null })
                        try {
                          const res = await apiFetch<{ team: Team }>('/api/team', {
                            method: 'PATCH',
                            body: JSON.stringify(data),
                          })
                          set({ team: res.team, loading: false })
                        } catch (e) {
                          if ((e as any).devSeed) { set({ loading: false }); throw e }
                          set({ error: (e as Error).message, loading: false })
                          throw e
                        }
                      },

                      clearError: () => set({ error: null }),
                    }),
                    {
                      name: 'orchestra-roles',
                      partialize: (state) => ({ currentRole: state.currentRole, roleLoaded: state.roleLoaded, team: state.team, teams: state.teams }),
                    }
                  )
                )
            replaceAll: false
            structuredPatch:
                - lines:
                    - '           allUsers: SEED_USERS,'
                    - '           members: SEED_USERS.filter(u => u.status !== ''suspended''),'
                    - '           team: SEED_TEAM,'
                    - '+          teams: [SEED_TEAM],'
                    - '         })'
                    - '       },'
                    - ' '
                  newLines: 7
                  newStart: 177
                  oldLines: 6
                  oldStart: 177
            userModified: false
        tool_use_id: toolu_01QCDtdUjYVptDLtLPC7kVeV
        transcript_path: /Users/fadymondy/.claude/projects/-Users-fadymondy-Sites-orchestra-agents/699c140c-f58a-4c9e-85ef-b3ec2c825fd9.jsonl
      timestamp: "2026-03-01T01:55:26Z"
    - event_type: PostToolUse
      session_id: 66cf890a-3e7b-49cb-930d-7b128b2daeeb
      tool_name: Read
      data:
        cwd: /Users/fadymondy/Sites/orchestra-agents
        hook_event_name: PostToolUse
        permission_mode: acceptEdits
        session_id: 66cf890a-3e7b-49cb-930d-7b128b2daeeb
        tool_input:
            file_path: /Users/fadymondy/Sites/orchestra-agents/apps/swift/Shared/Sources/Shared/Plugins/SettingsPlugin.swift
        tool_name: Read
        tool_response:
            file:
                content: |
                    import SwiftUI
                    #if !XCODE_BUILD
                    import OrchestraKit
                    #endif

                    @MainActor
                    public final class SettingsPlugin: OrchestraPlugin {
                        public let id = "settings"
                        public let name = "Settings"
                        public let icon = "gearshape"
                        public let section: AppSection = .settings
                        public let order = 100
                        public let supportedPlatforms: Set<Platform> = [.macOS, .iOS, .iPadOS, .watchOS, .tvOS, .visionOS]

                        public init() {}

                        public func makeView() -> AnyView {
                            AnyView(SettingsPluginView())
                        }
                    }

                    // MARK: - Settings Tabs

                    private enum SettingsTab: String, CaseIterable, Identifiable {
                        case general = "General"
                        case ai = "AI"
                        case prompts = "Prompts"
                        case actions = "Actions"
                        case about = "About"

                        var id: String { rawValue }

                        var icon: String {
                            switch self {
                            case .general:  return "gearshape"
                            case .ai:       return "sparkles"
                            case .prompts:  return "text.bubble"
                            case .actions:  return "bolt.fill"
                            case .about:    return "info.circle"
                            }
                        }
                    }

                    // MARK: - Root View

                    struct SettingsPluginView: View {
                        @State private var selectedTab: SettingsTab = .general

                        var body: some View {
                            VStack(spacing: 0) {
                                // Tab bar (Raycast style)
                                HStack(spacing: 2) {
                                    ForEach(SettingsTab.allCases) { tab in
                                        SettingsTabButton(tab: tab, isSelected: selectedTab == tab) {
                                            withAnimation(.easeInOut(duration: 0.15)) { selectedTab = tab }
                                        }
                                    }
                                }
                                .padding(.horizontal, 16)
                                .padding(.top, 16)
                                .padding(.bottom, 12)

                                Divider()

                                // Tab content
                                ScrollView {
                                    Group {
                                        switch selectedTab {
                                        case .general:  GeneralSettingsTab()
                                        case .ai:       AISettingsTab()
                                        case .prompts:  PromptsSettingsTab()
                                        case .actions:  ActionsSettingsTab()
                                        case .about:    AboutSettingsTab()
                                        }
                                    }
                                    .padding(24)
                                }
                            }
                            .navigationTitle("Settings")
                            .frame(maxWidth: .infinity, maxHeight: .infinity, alignment: .top)
                        }
                    }

                    // MARK: - Tab Button

                    private struct SettingsTabButton: View {
                        let tab: SettingsTab
                        let isSelected: Bool
                        let action: () -> Void

                        var body: some View {
                            Button(action: action) {
                                VStack(spacing: 4) {
                                    Image(systemName: tab.icon)
                                        .font(.system(size: 18, weight: .medium))
                                        .frame(width: 32, height: 32)
                                    Text(tab.rawValue)
                                        .font(.system(size: 11, weight: .medium))
                                }
                                .foregroundStyle(isSelected ? .primary : .secondary)
                                .frame(maxWidth: .infinity)
                                .padding(.vertical, 8)
                                .background(
                                    RoundedRectangle(cornerRadius: 8, style: .continuous)
                                        .fill(isSelected ? Color.primary.opacity(0.08) : Color.clear)
                                )
                            }
                            .buttonStyle(.plain)
                        }
                    }

                    // MARK: - Helpers

                    private struct SettingsSectionHeader: View {
                        let title: String

                        var body: some View {
                            Text(title)
                                .font(.system(size: 13, weight: .semibold))
                                .foregroundStyle(.secondary)
                                .frame(maxWidth: .infinity, alignment: .leading)
                                .padding(.bottom, 8)
                        }
                    }

                    private struct SettingsRow<Content: View>: View {
                        let label: String
                        @ViewBuilder let content: () -> Content

                        var body: some View {
                            HStack {
                                Text(label)
                                    .font(.system(size: 13))
                                Spacer()
                                content()
                            }
                            .padding(.vertical, 4)
                        }
                    }

                    // MARK: - General Tab

                    private struct GeneralSettingsTab: View {
                        @AppStorage("orchestrator_host") private var host = "127.0.0.1"
                        @AppStorage("orchestrator_port") private var port = 50100
                        #if os(macOS)
                        @AppStorage("appearance") private var appearance = "system"
                        @AppStorage("launchAtLogin") private var launchAtLogin = false
                        @AppStorage("smartInput.isDetached") private var isDetached = false
                        #endif

                        var body: some View {
                            VStack(alignment: .leading, spacing: 20) {
                                #if os(macOS)
                                SettingsSectionHeader(title: "Startup")
                                Toggle("Launch Orchestra at login", isOn: $launchAtLogin)
                                    .font(.system(size: 13))

                                Divider()

                                SettingsSectionHeader(title: "Appearance")
                                SettingsRow(label: "Appearance") {
                                    Picker("", selection: $appearance) {
                                        Label("Light", systemImage: "sun.max").tag("light")
                                        Label("Dark", systemImage: "moon").tag("dark")
                                        Label("System", systemImage: "circle.lefthalf.filled").tag("system")
                                    }
                                    .pickerStyle(.segmented)
                                    .frame(width: 240)
                                }

                                Divider()

                                SettingsSectionHeader(title: "Input Bar")
                                SettingsRow(label: "Default mode") {
                                    Picker("", selection: $isDetached) {
                                        Text("Docked").tag(false)
                                        Text("Floating").tag(true)
                                    }
                                    .pickerStyle(.segmented)
                                    .frame(width: 180)
                                }

                                Divider()
                                #endif

                                SettingsSectionHeader(title: "Connection")
                                SettingsRow(label: "Orchestrator Host") {
                                    TextField("Host", text: $host)
                                        .textFieldStyle(.roundedBorder)
                                        .frame(width: 180)
                                        .multilineTextAlignment(.trailing)
                                }
                                SettingsRow(label: "Orchestrator Port") {
                                    TextField("Port", value: $port, format: .number)
                                        .textFieldStyle(.roundedBorder)
                                        .frame(width: 100)
                                        .multilineTextAlignment(.trailing)
                                }
                            }
                        }
                    }

                    // MARK: - AI Tab

                    private struct AISettingsTab: View {
                        @AppStorage("default_provider") private var provider = "claude"
                        @AppStorage("ai.temperature") private var temperature = 0.7
                        @AppStorage("ai.maxTokens") private var maxTokens = 4096
                        @AppStorage("ai.systemPrompt") private var systemPrompt = ""
                        @AppStorage("ai.includeContext") private var includeContext = true

                        var body: some View {
                            VStack(alignment: .leading, spacing: 20) {
                                SettingsSectionHeader(title: "Provider")
                                SettingsRow(label: "Default Provider") {
                                    Picker("", selection: $provider) {
                                        Text("Claude").tag("claude")
                                        Text("OpenAI").tag("openai")
                                        Text("Gemini").tag("gemini")
                                        Text("Ollama").tag("ollama")
                                        Text("Grok").tag("grok")
                                        Text("DeepSeek").tag("deepseek")
                                        Text("Perplexity").tag("perplexity")
                                    }
                                    .frame(width: 160)
                                }

                                Divider()

                                SettingsSectionHeader(title: "Model Settings")
                                SettingsRow(label: "Temperature") {
                                    HStack(spacing: 8) {
                                        Slider(value: $temperature, in: 0...2, step: 0.1)
                                            .frame(width: 140)
                                        Text(String(format: "%.1f", temperature))
                                            .font(.system(size: 12, design: .monospaced))
                                            .foregroundStyle(.secondary)
                                            .frame(width: 30)
                                    }
                                }
                                SettingsRow(label: "Max Tokens") {
                                    TextField("", value: $maxTokens, format: .number)
                                        .textFieldStyle(.roundedBorder)
                                        .frame(width: 100)
                                        .multilineTextAlignment(.trailing)
                                }

                                Divider()

                                SettingsSectionHeader(title: "Context")
                                Toggle("Include screen context by default", isOn: $includeContext)
                                    .font(.system(size: 13))

                                Divider()

                                SettingsSectionHeader(title: "System Prompt")
                                Text("Custom instructions sent with every AI request")
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)
                                TextEditor(text: $systemPrompt)
                                    .font(.system(size: 13))
                                    .frame(minHeight: 100, maxHeight: 200)
                                    .overlay(
                                        RoundedRectangle(cornerRadius: 6, style: .continuous)
                                            .strokeBorder(Color.primary.opacity(0.1), lineWidth: 1)
                                    )
                            }
                        }
                    }

                    // MARK: - Prompts Tab

                    private struct CustomPrompt: Identifiable, Codable {
                        var id: String = UUID().uuidString
                        var text: String
                        var icon: String
                        var context: String  // Plugin name (empty = all)
                    }

                    private struct PromptsSettingsTab: View {
                        @AppStorage("prompts.custom") private var customPromptsJSON = "[]"
                        @State private var customPrompts: [CustomPrompt] = []
                        @State private var editingPrompt: CustomPrompt?
                        @State private var showAddSheet = false

                        var body: some View {
                            VStack(alignment: .leading, spacing: 20) {
                                SettingsSectionHeader(title: "Startup Prompts")
                                Text("Custom prompts shown as suggestions when the input field is empty. These appear alongside context-aware suggestions.")
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)

                                ForEach(customPrompts) { prompt in
                                    HStack(spacing: 12) {
                                        Image(systemName: prompt.icon)
                                            .font(.system(size: 14, weight: .medium))
                                            .foregroundStyle(.secondary)
                                            .frame(width: 24)

                                        VStack(alignment: .leading, spacing: 2) {
                                            Text(prompt.text)
                                                .font(.system(size: 13))
                                                .lineLimit(1)
                                            if !prompt.context.isEmpty {
                                                Text("Context: \(prompt.context)")
                                                    .font(.system(size: 11))
                                                    .foregroundStyle(.tertiary)
                                            }
                                        }

                                        Spacer()

                                        Button {
                                            editingPrompt = prompt
                                        } label: {
                                            Image(systemName: "pencil")
                                                .font(.system(size: 11))
                                                .foregroundStyle(.secondary)
                                        }
                                        .buttonStyle(.plain)

                                        Button {
                                            customPrompts.removeAll { $0.id == prompt.id }
                                            savePrompts()
                                        } label: {
                                            Image(systemName: "trash")
                                                .font(.system(size: 11))
                                                .foregroundStyle(.red.opacity(0.7))
                                        }
                                        .buttonStyle(.plain)
                                    }
                                    .padding(.vertical, 6)
                                    .padding(.horizontal, 10)
                                    .background(
                                        RoundedRectangle(cornerRadius: 8, style: .continuous)
                                            .fill(Color.primary.opacity(0.03))
                                    )
                                }

                                Button {
                                    showAddSheet = true
                                } label: {
                                    Label("Add Prompt", systemImage: "plus")
                                        .font(.system(size: 13))
                                }
                                .buttonStyle(.bordered)

                                Divider()

                                SettingsSectionHeader(title: "Built-in Prompts")
                                Text("Context-aware prompts are automatically shown based on the active plugin (Chat, Notes, Projects, Wiki). These cannot be edited.")
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)

                                VStack(alignment: .leading, spacing: 4) {
                                    BuiltInPromptRow(context: "Chat", prompts: "Summarize, Key takeaways, Follow-up, Action plan")
                                    BuiltInPromptRow(context: "Notes", prompts: "Proofread, Expand, Summarize, Bullet points")
                                    BuiltInPromptRow(context: "Projects", prompts: "Break down, Criteria, Estimate, Edge cases")
                                    BuiltInPromptRow(context: "Wiki", prompts: "Improve, Code examples, Simplify, TOC")
                                }
                            }
                            .onAppear { loadPrompts() }
                            .sheet(isPresented: $showAddSheet) {
                                PromptEditSheet(prompt: nil) { newPrompt in
                                    customPrompts.append(newPrompt)
                                    savePrompts()
                                }
                            }
                            .sheet(item: $editingPrompt) { prompt in
                                PromptEditSheet(prompt: prompt) { updated in
                                    if let idx = customPrompts.firstIndex(where: { $0.id == updated.id }) {
                                        customPrompts[idx] = updated
                                    }
                                    savePrompts()
                                }
                            }
                        }

                        private func loadPrompts() {
                            guard let data = customPromptsJSON.data(using: .utf8),
                                  let decoded = try? JSONDecoder().decode([CustomPrompt].self, from: data) else { return }
                            customPrompts = decoded
                        }

                        private func savePrompts() {
                            guard let data = try? JSONEncoder().encode(customPrompts),
                                  let json = String(data: data, encoding: .utf8) else { return }
                            customPromptsJSON = json
                        }
                    }

                    private struct BuiltInPromptRow: View {
                        let context: String
                        let prompts: String

                        var body: some View {
                            HStack {
                                Text(context)
                                    .font(.system(size: 12, weight: .medium))
                                    .frame(width: 70, alignment: .leading)
                                Text(prompts)
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)
                            }
                            .padding(.vertical, 2)
                        }
                    }

                    private struct PromptEditSheet: View {
                        let prompt: CustomPrompt?
                        let onSave: (CustomPrompt) -> Void

                        @Environment(\.dismiss) private var dismiss
                        @State private var text = ""
                        @State private var icon = "sparkles"
                        @State private var context = ""

                        private let iconOptions = [
                            "sparkles", "text.quote", "lightbulb", "pencil", "wrench",
                            "questionmark.circle", "checklist", "doc.text", "globe", "bolt.fill"
                        ]

                        var body: some View {
                            VStack(alignment: .leading, spacing: 16) {
                                Text(prompt == nil ? "Add Prompt" : "Edit Prompt")
                                    .font(.system(size: 15, weight: .semibold))

                                TextField("Prompt text", text: $text)
                                    .textFieldStyle(.roundedBorder)

                                HStack {
                                    Text("Icon")
                                        .font(.system(size: 13))
                                    Spacer()
                                    Picker("", selection: $icon) {
                                        ForEach(iconOptions, id: \.self) { opt in
                                            Label(opt, systemImage: opt).tag(opt)
                                        }
                                    }
                                    .frame(width: 180)
                                }

                                HStack {
                                    Text("Context")
                                        .font(.system(size: 13))
                                    Spacer()
                                    Picker("", selection: $context) {
                                        Text("All Plugins").tag("")
                                        Text("Chat").tag("Chat")
                                        Text("Notes").tag("Notes")
                                        Text("Projects").tag("Projects")
                                        Text("Wiki").tag("Wiki")
                                    }
                                    .frame(width: 140)
                                }

                                HStack {
                                    Spacer()
                                    Button("Cancel") { dismiss() }
                                        .buttonStyle(.bordered)
                                    Button("Save") {
                                        let p = CustomPrompt(
                                            id: prompt?.id ?? UUID().uuidString,
                                            text: text,
                                            icon: icon,
                                            context: context
                                        )
                                        onSave(p)
                                        dismiss()
                                    }
                                    .buttonStyle(.borderedProminent)
                                    .disabled(text.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
                                }
                            }
                            .padding(20)
                            .frame(width: 400)
                            .onAppear {
                                if let p = prompt {
                                    text = p.text
                                    icon = p.icon
                                    context = p.context
                                }
                            }
                        }
                    }

                    // MARK: - Actions Tab

                    private struct CustomAction: Identifiable, Codable {
                        var id: String = UUID().uuidString
                        var name: String
                        var prompt: String
                        var icon: String
                    }

                    private struct ActionsSettingsTab: View {
                        @AppStorage("actions.custom") private var customActionsJSON = "[]"
                        @State private var customActions: [CustomAction] = []
                        @State private var showAddSheet = false

                        var body: some View {
                            VStack(alignment: .leading, spacing: 20) {
                                SettingsSectionHeader(title: "Quick Actions (!)")
                                Text("Custom quick actions triggered with ! in the input bar. Built-in actions: Summarize, Explain, Code, Fix, Translate.")
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)

                                ForEach(customActions) { action in
                                    HStack(spacing: 12) {
                                        Image(systemName: action.icon)
                                            .font(.system(size: 14, weight: .medium))
                                            .foregroundStyle(.secondary)
                                            .frame(width: 24)

                                        VStack(alignment: .leading, spacing: 2) {
                                            Text("!\(action.name)")
                                                .font(.system(size: 13, weight: .medium, design: .monospaced))
                                            Text(action.prompt)
                                                .font(.system(size: 11))
                                                .foregroundStyle(.secondary)
                                                .lineLimit(2)
                                        }

                                        Spacer()

                                        Button {
                                            customActions.removeAll { $0.id == action.id }
                                            saveActions()
                                        } label: {
                                            Image(systemName: "trash")
                                                .font(.system(size: 11))
                                                .foregroundStyle(.red.opacity(0.7))
                                        }
                                        .buttonStyle(.plain)
                                    }
                                    .padding(.vertical, 6)
                                    .padding(.horizontal, 10)
                                    .background(
                                        RoundedRectangle(cornerRadius: 8, style: .continuous)
                                            .fill(Color.primary.opacity(0.03))
                                    )
                                }

                                Button {
                                    showAddSheet = true
                                } label: {
                                    Label("Add Action", systemImage: "plus")
                                        .font(.system(size: 13))
                                }
                                .buttonStyle(.bordered)

                                Divider()

                                SettingsSectionHeader(title: "Trigger Characters")
                                Text("These prefixes activate autocomplete in the input bar.")
                                    .font(.system(size: 12))
                                    .foregroundStyle(.secondary)

                                VStack(spacing: 6) {
                                    TriggerInfoRow(char: "/", label: "Commands", description: "Search available MCP tools and agents")
                                    TriggerInfoRow(char: "@", label: "Files", description: "Search indexed files via engine-rag")
                                    TriggerInfoRow(char: "#", label: "Memory", description: "Search saved memories and observations")
                                    TriggerInfoRow(char: "!", label: "Actions", description: "Quick actions (built-in + custom)")
                                }
                            }
                            .onAppear { loadActions() }
                            .sheet(isPresented: $showAddSheet) {
                                ActionEditSheet { newAction in
                                    customActions.append(newAction)
                                    saveActions()
                                }
                            }
                        }

                        private func loadActions() {
                            guard let data = customActionsJSON.data(using: .utf8),
                                  let decoded = try? JSONDecoder().decode([CustomAction].self, from: data) else { return }
                            customActions = decoded
                        }

                        private func saveActions() {
                            guard let data = try? JSONEncoder().encode(customActions),
                                  let json = String(data: data, encoding: .utf8) else { return }
                            customActionsJSON = json
                        }
                    }

                    private struct TriggerInfoRow: View {
                        let char: String
                        let label: String
                        let description: String

                        var body: some View {
                            HStack(spacing: 12) {
                                Text(char)
                                    .font(.system(size: 14, weight: .bold, design: .monospaced))
                                    .frame(width: 24, height: 24)
                                    .background(
                                        RoundedRectangle(cornerRadius: 6, style: .continuous)
                                            .fill(Color.primary.opacity(0.06))
                                    )
                                VStack(alignment: .leading, spacing: 1) {
                                    Text(label)
                                        .font(.system(size: 13, weight: .medium))
                                    Text(description)
                                        .font(.system(size: 11))
                                        .foregroundStyle(.secondary)
                                }
                                Spacer()
                            }
                            .padding(.vertical, 4)
                        }
                    }

                    private struct ActionEditSheet: View {
                        let onSave: (CustomAction) -> Void

                        @Environment(\.dismiss) private var dismiss
                        @State private var name = ""
                        @State private var prompt = ""
                        @State private var icon = "bolt.fill"

                        private let iconOptions = [
                            "bolt.fill", "wand.and.stars", "arrow.triangle.2.circlepath", "text.magnifyingglass",
                            "paintbrush", "scissors", "arrow.uturn.backward", "doc.plaintext", "globe", "hammer"
                        ]

                        var body: some View {
                            VStack(alignment: .leading, spacing: 16) {
                                Text("Add Quick Action")
                                    .font(.system(size: 15, weight: .semibold))

                                HStack {
                                    Text("!")
                                        .font(.system(size: 15, weight: .bold, design: .monospaced))
                                    TextField("Action name (e.g. refactor)", text: $name)
                                        .textFieldStyle(.roundedBorder)
                                }

                                Text("Prompt")
                                    .font(.system(size: 13))
                                TextEditor(text: $prompt)
                                    .font(.system(size: 13))
                                    .frame(minHeight: 80, maxHeight: 150)
                                    .overlay(
                                        RoundedRectangle(cornerRadius: 6, style: .continuous)
                                            .strokeBorder(Color.primary.opacity(0.1), lineWidth: 1)
                                    )

                                HStack {
                                    Text("Icon")
                                        .font(.system(size: 13))
                                    Spacer()
                                    Picker("", selection: $icon) {
                                        ForEach(iconOptions, id: \.self) { opt in
                                            Label(opt, systemImage: opt).tag(opt)
                                        }
                                    }
                                    .frame(width: 200)
                                }

                                HStack {
                                    Spacer()
                                    Button("Cancel") { dismiss() }
                                        .buttonStyle(.bordered)
                                    Button("Save") {
                                        let a = CustomAction(name: name, prompt: prompt, icon: icon)
                                        onSave(a)
                                        dismiss()
                                    }
                                    .buttonStyle(.borderedProminent)
                                    .disabled(name.isEmpty || prompt.isEmpty)
                                }
                            }
                            .padding(20)
                            .frame(width: 420)
                        }
                    }

                    // MARK: - About Tab

                    private struct AboutSettingsTab: View {
                        @ObservedObject private var appState = AppState.shared

                        var body: some View {
                            VStack(alignment: .leading, spacing: 20) {
                                HStack(spacing: 14) {
                                    Image("OrchestraLogo")
                                        .resizable()
                                        .scaledToFit()
                                        .frame(width: 48, height: 48)

                                    VStack(alignment: .leading, spacing: 2) {
                                        Text("Orchestra")
                                            .font(.system(size: 20, weight: .semibold))
                                        Text("AI-Agentic IDE")
                                            .font(.system(size: 13))
                                            .foregroundStyle(.secondary)
                                    }
                                }

                                Divider()

                                SettingsSectionHeader(title: "Info")
                                SettingsRow(label: "Version") {
                                    Text("0.1.0")
                                        .font(.system(size: 13, design: .monospaced))
                                        .foregroundStyle(.secondary)
                                }
                                SettingsRow(label: "Protocol") {
                                    Text("QUIC + Protobuf")
                                        .font(.system(size: 13))
                                        .foregroundStyle(.secondary)
                                }
                                SettingsRow(label: "Connection") {
                                    HStack(spacing: 6) {
                                        Circle()
                                            .fill(connectionColor)
                                            .frame(width: 8, height: 8)
                                        Text(connectionLabel)
                                            .font(.system(size: 13))
                                            .foregroundStyle(.secondary)
                                    }
                                }
                                SettingsRow(label: "Tools Available") {
                                    Text("\(appState.availableTools.count)")
                                        .font(.system(size: 13, design: .monospaced))
                                        .foregroundStyle(.secondary)
                                }

                                Divider()

                                SettingsSectionHeader(title: "Platforms")
                                Text("macOS, iOS, watchOS, tvOS, visionOS, CarPlay")
                                    .font(.system(size: 13))
                                    .foregroundStyle(.secondary)
                            }
                        }

                        private var connectionColor: Color {
                            switch appState.connectionState {
                            case .connected:      return .green
                            case .connecting:     return .orange
                            case .reconnecting:   return .orange
                            case .disconnected:   return .red
                            case .failed:         return .red
                            }
                        }

                        private var connectionLabel: String {
                            switch appState.connectionState {
                            case .connected:      return "Connected"
                            case .connecting:     return "Connecting..."
                            case .reconnecting:   return "Reconnecting..."
                            case .disconnected:   return "Disconnected"
                            case .failed(let e):  return "Failed: \(e.localizedDescription)"
                            }
                        }
                    }
