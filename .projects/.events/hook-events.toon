                content: |
                    import Foundation

                    // MARK: - Enums

                    /// Workflow lifecycle status for a feature.
                    public enum FeatureStatus: String, Codable, Hashable, CaseIterable, Sendable {
                        case backlog          = "backlog"
                        case todo             = "todo"
                        case inProgress       = "in-progress"
                        case readyForTesting  = "ready-for-testing"
                        case inTesting        = "in-testing"
                        case readyForDocs     = "ready-for-docs"
                        case inDocs           = "in-docs"
                        case documented       = "documented"
                        case inReview         = "in-review"
                        case done             = "done"

                        /// Human-readable display label.
                        public var label: String {
                            switch self {
                            case .backlog:         return "Backlog"
                            case .todo:            return "Todo"
                            case .inProgress:      return "In Progress"
                            case .readyForTesting: return "Ready for Testing"
                            case .inTesting:       return "In Testing"
                            case .readyForDocs:    return "Ready for Docs"
                            case .inDocs:          return "In Docs"
                            case .documented:      return "Documented"
                            case .inReview:        return "In Review"
                            case .done:            return "Done"
                            }
                        }
                    }

                    /// Priority level for a feature.
                    public enum FeaturePriority: String, Codable, Hashable, CaseIterable, Sendable {
                        case p0 = "P0"
                        case p1 = "P1"
                        case p2 = "P2"
                        case p3 = "P3"

                        /// Short label (e.g. "P0").
                        public var label: String { rawValue }
                    }

                    /// Role of a participant in a chat session.
                    public enum MessageRole: String, Codable, Hashable, CaseIterable, Sendable {
                        case user      = "user"
                        case assistant = "assistant"
                        case system    = "system"
                    }

                    // MARK: - Project

                    /// An Orchestra project that groups features and notes.
                    public struct Project: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        /// MCP slug identifier (e.g. "my-project"). Used for all MCP tool calls.
                        public var slug: String
                        public var name: String
                        public var description: String
                        public var createdAt: Date
                        public var updatedAt: Date

                        public init(
                            id: UUID = UUID(),
                            slug: String = "",
                            name: String,
                            description: String = "",
                            createdAt: Date = Date(),
                            updatedAt: Date = Date()
                        ) {
                            self.id = id
                            self.slug = slug.isEmpty ? Project.slugify(name) : slug
                            self.name = name
                            self.description = description
                            self.createdAt = createdAt
                            self.updatedAt = updatedAt
                        }

                        /// Derive a URL-safe slug from a project name.
                        public static func slugify(_ name: String) -> String {
                            name.lowercased()
                                .replacingOccurrences(of: " ", with: "-")
                                .filter { $0.isLetter || $0.isNumber || $0 == "-" }
                        }
                    }

                    // MARK: - Feature

                    /// A feature (task) within a project.
                    public struct Feature: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var projectId: UUID
                        /// MCP feature ID (e.g. "FEAT-A1B2"). Used for MCP tool calls.
                        public var featureId: String
                        public var title: String
                        public var description: String
                        public var status: FeatureStatus
                        public var priority: FeaturePriority
                        public var assignee: String?
                        public var labels: [String]
                        public var createdAt: Date
                        public var updatedAt: Date

                        public init(
                            id: UUID = UUID(),
                            projectId: UUID = UUID(),
                            featureId: String = "",
                            title: String,
                            description: String = "",
                            status: FeatureStatus = .backlog,
                            priority: FeaturePriority = .p2,
                            assignee: String? = nil,
                            labels: [String] = [],
                            createdAt: Date = Date(),
                            updatedAt: Date = Date()
                        ) {
                            self.id = id
                            self.projectId = projectId
                            self.featureId = featureId
                            self.title = title
                            self.description = description
                            self.status = status
                            self.priority = priority
                            self.assignee = assignee
                            self.labels = labels
                            self.createdAt = createdAt
                            self.updatedAt = updatedAt
                        }
                    }

                    // MARK: - Note

                    /// A markdown note attached to a project.
                    public struct Note: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var projectId: UUID
                        public var title: String
                        public var body: String
                        public var isPinned: Bool
                        /// Named color token (maps to a SwiftUI Color). Empty string = default accent.
                        public var colorName: String
                        public var createdAt: Date
                        public var updatedAt: Date
                        /// MCP memory ID (e.g. "MEM-1234") for syncing with engine.rag. Nil for unsynced notes.
                        public var memoryId: String?

                        public init(
                            id: UUID = UUID(),
                            projectId: UUID = UUID(),
                            title: String,
                            body: String = "",
                            isPinned: Bool = false,
                            colorName: String = "",
                            createdAt: Date = Date(),
                            updatedAt: Date = Date(),
                            memoryId: String? = nil
                        ) {
                            self.id = id
                            self.projectId = projectId
                            self.title = title
                            self.body = body
                            self.isPinned = isPinned
                            self.colorName = colorName
                            self.createdAt = createdAt
                            self.updatedAt = updatedAt
                            self.memoryId = memoryId
                        }
                    }

                    // MARK: - ToolCall

                    /// A tool invocation recorded in an assistant message.
                    public struct ToolCall: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var toolName: String
                        public var status: ToolCallStatus
                        public var arguments: String   // human-readable summary
                        public var result: String      // truncated result
                        public var createdAt: Date

                        public enum ToolCallStatus: String, Codable, Hashable, Sendable {
                            case running, completed, error
                        }

                        public init(
                            id: UUID = UUID(),
                            toolName: String,
                            status: ToolCallStatus = .completed,
                            arguments: String = "",
                            result: String = "",
                            createdAt: Date = Date()
                        ) {
                            self.id = id
                            self.toolName = toolName
                            self.status = status
                            self.arguments = arguments
                            self.result = result
                            self.createdAt = createdAt
                        }

                        /// SF Symbol name for the tool icon.
                        public var iconName: String {
                            switch toolName.lowercased() {
                            case "read":              return "doc.text"
                            case "edit":              return "pencil"
                            case "write":             return "square.and.pencil"
                            case "bash":              return "terminal"
                            case "glob":              return "folder.badge.gearshape"
                            case "grep":              return "magnifyingglass"
                            case "webfetch":          return "globe"
                            case "websearch":         return "globe.magnifyingglass"
                            case "todowrite":         return "checklist"
                            case "askuserquestion":   return "questionmark.bubble"
                            case "task":              return "person.3"
                            default:                  return "wrench"
                            }
                        }
                    }

                    // MARK: - ChatMessage

                    /// A single message in a chat session.
                    public struct ChatMessage: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var sessionId: UUID
                        public var role: MessageRole
                        public var content: String
                        public var toolCalls: [ToolCall]
                        public var pendingQuestion: UserQuestion?
                        public var createdAt: Date

                        public init(
                            id: UUID = UUID(),
                            sessionId: UUID,
                            role: MessageRole,
                            content: String,
                            toolCalls: [ToolCall] = [],
                            pendingQuestion: UserQuestion? = nil,
                            createdAt: Date = Date()
                        ) {
                            self.id = id
                            self.sessionId = sessionId
                            self.role = role
                            self.content = content
                            self.toolCalls = toolCalls
                            self.pendingQuestion = pendingQuestion
                            self.createdAt = createdAt
                        }

                        // Custom decoding to handle existing persisted data without newer fields.
                        enum CodingKeys: String, CodingKey {
                            case id, sessionId, role, content, toolCalls, pendingQuestion, createdAt
                        }

                        public init(from decoder: Decoder) throws {
                            let container = try decoder.container(keyedBy: CodingKeys.self)
                            id = try container.decode(UUID.self, forKey: .id)
                            sessionId = try container.decode(UUID.self, forKey: .sessionId)
                            role = try container.decode(MessageRole.self, forKey: .role)
                            content = try container.decode(String.self, forKey: .content)
                            toolCalls = try container.decodeIfPresent([ToolCall].self, forKey: .toolCalls) ?? []
                            pendingQuestion = try container.decodeIfPresent(UserQuestion.self, forKey: .pendingQuestion)
                            createdAt = try container.decode(Date.self, forKey: .createdAt)
                        }
                    }

                    // MARK: - ChatSession

                    /// A conversation session with an AI provider.
                    public struct ChatSession: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var title: String
                        public var provider: String
                        public var isPinned: Bool
                        /// Named color token (maps to a SwiftUI Color). Empty string = default accent.
                        public var colorName: String
                        /// SF Symbol override for the row icon. Empty string = default bubble.
                        public var iconName: String
                        public var createdAt: Date
                        public var messages: [ChatMessage]
                        /// MCP bridge session ID (e.g. "s-XXXXXX"). Nil until first message creates a session.
                        public var bridgeSessionId: String?
                        /// AI model identifier (e.g. "claude-sonnet-4-6").
                        public var model: String
                        /// Permission mode for the bridge session ("auto", "plan", "manual").
                        public var mode: String
                        /// Whether extended/step-by-step thinking is enabled for this session.
                        public var thinkingEnabled: Bool

                        public init(
                            id: UUID = UUID(),
                            title: String,
                            provider: String = "claude",
                            isPinned: Bool = false,
                            colorName: String = "",
                            iconName: String = "",
                            createdAt: Date = Date(),
                            messages: [ChatMessage] = [],
                            bridgeSessionId: String? = nil,
                            model: String = "claude-sonnet-4-6",
                            mode: String = "auto",
                            thinkingEnabled: Bool = false
                        ) {
                            self.id = id
                            self.title = title
                            self.provider = provider
                            self.isPinned = isPinned
                            self.colorName = colorName
                            self.iconName = iconName
                            self.createdAt = createdAt
                            self.messages = messages
                            self.bridgeSessionId = bridgeSessionId
                            self.model = model
                            self.mode = mode
                            self.thinkingEnabled = thinkingEnabled
                        }

                        // Custom decoding to handle existing persisted data without new fields.
                        enum CodingKeys: String, CodingKey {
                            case id, title, provider, isPinned, colorName, iconName
                            case createdAt, messages, bridgeSessionId, model, mode, thinkingEnabled
                        }

                        public init(from decoder: Decoder) throws {
                            let container = try decoder.container(keyedBy: CodingKeys.self)
                            id = try container.decode(UUID.self, forKey: .id)
                            title = try container.decode(String.self, forKey: .title)
                            provider = try container.decode(String.self, forKey: .provider)
                            isPinned = try container.decode(Bool.self, forKey: .isPinned)
                            colorName = try container.decode(String.self, forKey: .colorName)
                            iconName = try container.decode(String.self, forKey: .iconName)
                            createdAt = try container.decode(Date.self, forKey: .createdAt)
                            messages = try container.decode([ChatMessage].self, forKey: .messages)
                            bridgeSessionId = try container.decodeIfPresent(String.self, forKey: .bridgeSessionId)
                            model = try container.decodeIfPresent(String.self, forKey: .model) ?? "claude-sonnet-4-6"
                            mode = try container.decodeIfPresent(String.self, forKey: .mode) ?? "auto"
                            thinkingEnabled = try container.decodeIfPresent(Bool.self, forKey: .thinkingEnabled) ?? false
                        }

                        // MARK: - Model & Mode Display Helpers

                        /// Available model options with human-readable labels.
                        public static let modelOptions: [(id: String, label: String)] = [
                            ("claude-opus-4-6",              "Opus 4.6"),
                            ("claude-sonnet-4-6",            "Sonnet 4.6"),
                            ("claude-haiku-4-5-20251001",    "Haiku 4.5"),
                        ]

                        /// Available mode options with human-readable labels.
                        public static let modeOptions: [(id: String, label: String)] = [
                            ("auto",   "Auto"),
                            ("plan",   "Plan"),
                            ("manual", "Manual"),
                        ]

                        /// Models that support extended thinking.
                        public static let thinkingModels: Set<String> = [
                            "claude-opus-4-6",
                            "claude-sonnet-4-6",
                        ]

                        /// Whether the current model supports extended thinking.
                        public var supportsThinking: Bool {
                            Self.thinkingModels.contains(model)
                        }

                        /// Human-readable label for the current model.
                        public var modelLabel: String {
                            Self.modelOptions.first { $0.id == model }?.label ?? model
                        }

                        /// Human-readable label for the current mode.
                        public var modeLabel: String {
                            Self.modeOptions.first { $0.id == mode }?.label ?? mode
                        }
                    }

                    // MARK: - UserQuestion

                    /// An interactive question from the AI that requires user input.
                    public struct UserQuestion: Identifiable, Codable, Hashable, Sendable {
                        public var id: UUID
                        public var question: String
                        public var options: [QuestionOption]
                        public var selectedAnswer: String?

                        public struct QuestionOption: Identifiable, Codable, Hashable, Sendable {
                            public var id: UUID
                            public var label: String
                            public var description: String

                            public init(id: UUID = UUID(), label: String, description: String = "") {
                                self.id = id; self.label = label; self.description = description
                            }
                        }

                        public init(id: UUID = UUID(), question: String, options: [QuestionOption], selectedAnswer: String? = nil) {
                            self.id = id; self.question = question; self.options = options; self.selectedAnswer = selectedAnswer
                        }
                    }

                    // MARK: - SessionMetadata

                    /// Metadata extracted from the tail of a Claude response.
                    public struct SessionMetadata: Equatable, Sendable {
                        public var model: String
                        public var tokenCount: Int
                        public var duration: String
                        public var cost: String

                        public init(model: String = "", tokenCount: Int = 0, duration: String = "", cost: String = "") {
                            self.model = model
                            self.tokenCount = tokenCount
                            self.duration = duration
                            self.cost = cost
                        }

                        /// True if at least one field is populated.
                        public var hasData: Bool {
                            !model.isEmpty || tokenCount > 0 || !duration.isEmpty || !cost.isEmpty
                        }
                    }
