                  ok "Build passed"
                else
                  info "(dry-run) would run: make build"
                fi

                info "Running tests..."
                if ! $DRY_RUN; then
                  make test 2>&1 | tail -20 | sed 's/^/  /'
                  ok "Tests passed"
                else
                  info "(dry-run) would run: make test"
