                       228→
                       229→    // MARK: - Send or Stop Button
                       230→    //
                       231→    // Uses ZStack + opacity to keep the view tree stable.
                       232→    // Swapping views via if/else crashes NSHostingView in the floating panel.
                       233→
                       234→    private var sendOrStopButton: some View {
                       235→        ZStack {
                       236→            // Voice stop button
                       237→            Button {
                       238→                if voiceService.phase == .speaking {
